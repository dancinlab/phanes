{
  "project": "phanes",
  "stack": [
    "node"
  ],
  "lockdown": {
    "files": [],
    "fromMarkdown": "CLAUDE.md",
    "onEditReminder": "L0 file edited — update CHANGELOG + issue tracker in the same change."
  },
  "enforcementFile": ".harness/enforcement.json",
  "keywordsFile": ".harness/keywords.json",
  "severityMapFile": ".harness/severity-map.json",
  "verify": {
    "checks": [
      {
        "id": "test",
        "cmd": "npm test",
        "timeoutMs": 240000
      }
    ]
  },
  "lint": {
    "freshnessFiles": [],
    "changelog": {
      "file": "CHANGELOG.jsonl",
      "triggerPattern": "\\.(ts|tsx|js|jsx|mjs|cjs)$",
      "ignore": [
        "(^|/)(tests?|__tests__|spec)/",
        "\\.(test|spec)\\.[a-z]+$",
        "(^|/)\\.harness(-engine)?/"
      ]
    },
    "protectedBranches": [
      "main",
      "master"
    ],
    "injectEnglishOnly": [
      "CLAUDE.md"
    ]
  },
  "guides": [
    "CLAUDE.md",
    "AGENTS.md",
    "README.md"
  ],
  "ledger": {
    "staleSec": 1800
  },
  "docs": {
    "architecture": "ARCHITECTURE.json"
  }
}
