{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "[ -x ../../.harness/cli/bin/harness ] && CLAUDE_TOOL_INPUT=\"$CLAUDE_TOOL_INPUT\" bash ../../.harness/cli/bin/harness pre bash || true"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "[ -x ../../.harness/cli/bin/harness ] && CLAUDE_TOOL_INPUT=\"$CLAUDE_TOOL_INPUT\" bash ../../.harness/cli/bin/harness pre write || true"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "[ -x ../../.harness/cli/bin/harness ] && bash ../../.harness/cli/bin/harness pre askq || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "[ -x ../../.harness/cli/bin/harness ] && bash ../../.harness/cli/bin/harness post edit \"$CLAUDE_FILE_PATH\" || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x ../../.harness/cli/bin/harness ] && bash ../../.harness/cli/bin/harness prompt \"$CLAUDE_USER_PROMPT\" || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x ../../.harness/cli/bin/harness ] && bash ../../.harness/cli/bin/harness commons inject || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x ../../.harness/cli/bin/harness ] && bash ../../.harness/cli/bin/harness prefs inject || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x ../../.harness/cli/bin/harness ] && bash ../../.harness/cli/bin/harness easy inject || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x ../../.harness/cli/bin/harness ] && bash ../../.harness/cli/bin/harness recommend inject || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x ../../.harness/cli/bin/harness ] && bash ../../.harness/cli/bin/harness easy inject || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x ../../.harness/cli/bin/harness ] && bash ../../.harness/cli/bin/harness recommend inject || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x ../../.harness/cli/bin/harness ] && bash ../../.harness/cli/bin/harness worktree gc || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x ../../.harness/cli/bin/harness ] && bash ../../.harness/cli/bin/harness handoff inject || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x ../../.harness/cli/bin/harness ] && bash ../../.harness/cli/bin/harness ing inject || true"
          }
        ]
      }
    ]
  }
}
