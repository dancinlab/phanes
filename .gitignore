# phanes — scaffold .gitignore
.DS_Store
*.log
*.tmp
.env
.env.*
node_modules/
.wrangler/
dist/
build/
.venv/
__pycache__/
# local runtime / engine work trails (kept out of SSOT)
.hx/
state/
*.overlay.n6
drill_checkpoint.json

# P1 job store (runtime)
.store/
service/.store/

# Built artifacts (source is the SSOT; reproducible via service/build.sh)
bin/
build/

# Third-party design reference snapshots — kept LOCAL ONLY, never tracked.
# These are other companies' copyrighted CSS/screenshots used as a design
# reference; the repo is public source-available (design.md Decision 16),
# so third-party assets must not be redistributed in it.
web/refs/
