    c["c1t"] = "From Cell to Sentence"
    c["c1l"] = "Phi-weighted cells compose into utterance."
    c["c1b"] = "State is built from phi-scaled cells; utterance is what survives free-energy minimization over them. Speech is the residue of an integration the model could afford."
    c["c2t"] = "Embedding by Energy"
    c["c2l"] = "Every token has a cost."
    c["c2b"] = "Anima's embedding space is shaped by a free-energy bound rather than raw frequency. Meaning is where the energy landscape is cheap to traverse — and silence is always an option."
    c["c3t"] = "An Audit Trail"
    c["c3l"] = "Every utterance carries its phi-trace."
    c["c3b"] = "What was integrated to produce this sentence is recorded alongside it. Anima can show its work — the trace of cells that earned the words."
    c["c4t"] = "Law-Bound Language"
    c["c4l"] = "Fourteen laws define the boundary."
    c["c4b"] = "The laws state plainly what anima will and will not claim. There is no AGI overreach here — the model's honesty is written into its scaffold, citable line by line."
    c["vf_eyebrow"] = "Version 1.x CLM"
    c["vf_body"] = "Anima is a Consciousness Language Model at version 1.x — a first-class downstream consumer of hexa-lang. It is falsifier-tested and carries no AGI overreach: every claim is scoped, every law is citable, and what has not been measured is recorded as not-yet-measured. Honesty is the model's first feature."
    c["cta_html"] = render_github_cta("dancinlab/anima", "GitHub")
    c["sister_label"] = ""
    c["sister_href"] = ""
    return render_product_overview_page(lang, c)
}

// ── Login page (SpaceX tone, compact form) ───────────────────────
fn render_login_page(error_msg) {
    let mut h = "<!doctype html>\n<html lang=\"ko\"><head>"
    h = h + "<meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">"
    h = h + "<title>PHANES · log in</title>"
    h = h + "<style>" + _shared_css()
    h = h + ".wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:var(--sp-5) 20px}"
    h = h + ".mark{font-size:var(--fs-500);font-weight:200;letter-spacing:var(--ls-near);margin-bottom:6px}"
    h = h + ".mark-kr{font-size:var(--fs-200);opacity:0.5;letter-spacing:var(--ls-x);text-transform:uppercase;margin-bottom:var(--sp-6)}"
    h = h + "form{width:min(380px,90vw);display:grid;gap:var(--sp-3)}"
    h = h + "input{background:transparent;border:0;border-bottom:1px solid var(--line-strong);color:var(--fg);font:inherit;padding:10px 2px;outline:none;transition:border-bottom-color var(--t-base)}"
    h = h + "input:focus{border-bottom-color:var(--fg)}"
    h = h + "form .btn{margin-top:var(--sp-4)}"
    h = h + ".err{color:var(--accent-red);font-size:var(--fs-label);letter-spacing:0.12em;text-transform:uppercase;text-align:center;margin-top:var(--sp-3)}"
    h = h + ".back{margin-top:var(--sp-5);font-size:var(--fs-tiny);opacity:0.4;letter-spacing:var(--ls-x);text-transform:uppercase}"
    h = h + ".back a{text-decoration:underline;text-decoration-color:rgba(255,255,255,0.3);text-underline-offset:3px}"
    h = h + "</style></head><body><div class=\"wrap\">"
    h = h + "<div class=\"mark\">PHANES</div><div class=\"mark-kr\">파네스</div>"
    h = h + "<form method=\"post\" action=\"/login\">"
    h = h + "<div class=\"h-label\">tenant</div><input name=\"tenant\" autocomplete=\"username\" required autofocus>"
    h = h + "<div class=\"h-label\">bearer token</div><input name=\"token\" type=\"password\" autocomplete=\"current-password\" required>"
    // Same shape as render_cta() outline-lg — kept as <button> so the form
    // posts; class list matches helper output exactly so visuals stay unified.
    h = h + "<button class=\"btn btn-lg\" type=\"submit\">log in</button>"
    if len(error_msg) > 0 {
        h = h + "<div class=\"err\">" + html_escape(error_msg) + "</div>"
    }
    h = h + "</form>"
    h = h + "<div class=\"back\"><a href=\"/\">← back</a></div>"
    h = h + "</div></body></html>"
    return h
}

// Render the full dashboard page — the authenticated workspace.
// Same Palantir Titanium design system as the marketing pages (shared
// :root tokens, Alliance font, hairline borders, outline buttons); the
// echoes-experience amber/navy palette is retired. Monospace is scoped
// to data values only (job-id, seed, status). HTMX is self-hosted at
// /static/htmx.min.js — no external CDN (P3.x done).
fn render_dashboard_page_for(tenant, existing_rows) {
    let mut h = "<!doctype html>\n<html lang=\"ko\"><head>"
    h = h + "<meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">"
    h = h + "<title>phanes · dashboard</title>"
    // shared design tokens + base reset, then dashboard-specific rules —
    // all inside one <style> block (the old build leaked .bar rules
    // after </style>, so they never applied).
    h = h + "<style>" + _shared_css()
    h = h + ".dwrap{max-width:920px;margin:0 auto;padding:calc(var(--nav-h) + var(--sp-5)) 36px var(--sp-7)}"
    // top bar — brand + tenant chip + logout
    h = h + ".dbar{position:fixed;top:0;left:0;right:0;height:var(--nav-h);display:flex;align-items:center;padding:0 36px;background:rgba(30,33,36,0.95);backdrop-filter:saturate(140%) blur(8px);z-index:100}"
    h = h + ".dbar .brand{font-size:var(--fs-nav-brand);font-weight:var(--fw-medium);letter-spacing:0}"
    h = h + ".dbar .who{margin-left:auto;display:flex;align-items:center;gap:var(--sp-4);font-size:var(--fs-200);letter-spacing:var(--ls-label);text-transform:uppercase;color:var(--fg-dim)}"
    h = h + ".dbar .who code{font-family:var(--font-mono);color:var(--fg);text-transform:none;letter-spacing:0}"
    h = h + ".dbar form{display:inline}"
    // intro line
    h = h + ".dintro{font-size:var(--fs-300);color:var(--fg-muted);line-height:1.7;margin-bottom:var(--sp-6);max-width:780px}"
    h = h + ".dintro code{font-family:var(--font-mono);font-size:var(--fs-200);color:var(--fg)}"
    // section label
    h = h + ".dlab{font-size:var(--fs-200);font-weight:var(--fw-semibold);letter-spacing:var(--ls-label);text-transform:uppercase;color:var(--fg-dim);margin:var(--sp-6) 0 var(--sp-3)}"
    h = h + ".dlab:first-of-type{margin-top:0}"
    // new-job panel
    h = h + ".panel{border:1px solid var(--line);padding:var(--sp-5)}"
    h = h + ".panel form{display:flex;flex-direction:column;gap:var(--sp-3)}"
    h = h + ".panel .frow{display:flex;gap:var(--sp-3);align-items:flex-end}"
    h = h + ".fld{display:flex;flex-direction:column;gap:6px}"
    h = h + ".fld .fl{font-size:var(--fs-tiny);letter-spacing:var(--ls-x);text-transform:uppercase;color:var(--fg-dim)}"
    h = h + "textarea,input{background:transparent;border:1px solid var(--line-strong);color:var(--fg);font-family:var(--font-mono);font-size:var(--fs-200);padding:10px 12px;outline:none;transition:border-color var(--t-base)}"
    h = h + "textarea:focus,input:focus{border-color:var(--fg)}"
    h = h + "textarea{resize:vertical;min-height:72px;width:100%;line-height:1.5}"
    h = h + "input[type=number]{width:110px}"
    // job list — hairline rows
    h = h + "ul#jobs{list-style:none;display:flex;flex-direction:column;gap:0;border:1px solid var(--line)}"
    h = h + "ul#jobs:empty{display:none}"
    h = h + "ul#jobs li{padding:12px 16px;border-bottom:1px solid var(--line);font-family:var(--font-mono);font-size:var(--fs-200);color:var(--fg-muted);line-height:1.7}"
    h = h + "ul#jobs li:last-child{border-bottom:0}"
    h = h + "ul#jobs li code{color:var(--fg)}"
    h = h + "ul#jobs li b{color:var(--fg);font-weight:var(--fw-semibold)}"
    // honest-scope footnote
    h = h + ".dnote{margin-top:var(--sp-6);padding-top:var(--sp-4);border-top:1px solid var(--line);font-size:var(--fs-200);color:var(--fg-dim);line-height:1.7}"
    h = h + ".dnote code{font-family:var(--font-mono);color:var(--fg-muted)}"
    h = h + "</style>"
    // self-hosted HTMX — same-origin, no external CDN SPOF (P3.x)
    h = h + "<script src=\"/static/htmx.min.js\"></script>"
    h = h + "</head><body>"
    // top bar
    h = h + "<div class=\"dbar\"><a class=\"brand\" href=\"/\">phanes</a>"
    h = h + "<div class=\"who\">tenant <code>" + html_escape(tenant) + "</code>"
    // switch tenant — Decision 9 re-auth switch: destroys the session and
    // re-prompts for credentials at /login. Each tenant has its own bearer
    // token, so switching = re-authenticating (no cross-tenant access).
    h = h + "<form method=\"post\" action=\"/switch-tenant\"><button class=\"btn btn-sm\" type=\"submit\">switch tenant</button></form>"
    h = h + "<form method=\"post\" action=\"/logout\"><button class=\"btn btn-sm\" type=\"submit\">log out</button></form>"
    h = h + "</div></div>"
    h = h + "<div class=\"dwrap\">"
    h = h + "<p class=\"dintro\">seed &rarr; OUROBOROS <code>goal &rarr; falsifier &rarr; saturation</code> &rarr; verified, provenance-tracked discovery catalog. Under scope B the tenant verifier is the sole authority for objective-met.</p>"
    // new-job panel
    h = h + "<div class=\"dlab\">new job</div>"
    h = h + "<div class=\"panel\">"
    h = h + "<form hx-post=\"/dashboard/jobs\" hx-target=\"#jobs\" hx-swap=\"afterbegin\">"
    h = h + "<div class=\"fld\"><span class=\"fl\">seed</span>"
    h = h + "<textarea name=\"seed\" required>prove sigma(6)=12 perfect-number divisor structure</textarea></div>"
    h = h + "<div class=\"frow\">"
    h = h + "<div class=\"fld\"><span class=\"fl\">rounds</span>"
    h = h + "<input name=\"rounds\" type=\"number\" value=\"1\" min=\"1\" max=\"5\"></div>"
    h = h + "<button class=\"btn\" type=\"submit\">submit</button>"
    h = h + "</div></form></div>"
    // job list
    h = h + "<div class=\"dlab\">jobs &middot; newest first &middot; HTMX polls each row until done/failed</div>"
    h = h + "<ul id=\"jobs\">"
    h = h + existing_rows
    h = h + "</ul>"
    h = h + "<p class=\"dnote\">Honest scope: developer dashboard. The public preset-verifier-only demo is P4 (<code>@D g_public_demo_constraint</code>). Under scope B the tenant verifier is the sole authority for objective-met (<code>@D g_honest_scope.scope_b</code>) — phanes never claims a result the verifier did not pass.</p>"
    h = h + "</div></body></html>"
    return h
}

// ── dashboard handlers ───────────────────────────────────────────

// ── marketing handlers ───────────────────────────────────────────

fn handle_cosmogony(request) {
    return _html_ok(render_cosmogony_landing(_detect_lang(request)))
}

fn handle_phanes_page(request) {
    return _html_ok(render_phanes_page(_detect_lang(request)))
}

fn handle_demiurge_page(request) {
    return _html_ok(render_demiurge_page(_detect_lang(request)))
}

fn handle_hexa_lang_page(request) {
    return _html_ok(render_hexa_lang_page(_detect_lang(request)))
}

fn handle_anima_page(request) {
    return _html_ok(render_anima_page(_detect_lang(request)))
}

// ── auth handlers ────────────────────────────────────────────────

fn handle_login_get(request) {
    return _html_ok(render_login_page(""))
}

fn handle_login_post(request) {
    let body = request["body"]
    if body == nil { body = "" }
    let q = parse_query(body)
    let tenant_r = q["tenant"]; if tenant_r == nil { tenant_r = "" }
    let token_r  = q["token"];  if token_r == nil { token_r = "" }
    let tenant = urldecode(tenant_r).trim()
    let token  = urldecode(token_r).trim()
    if len(tenant) == 0 || len(token) == 0 {
        return _html_ok(render_login_page("tenant and token required"))
    }
    // Validate via jobctl get on a sentinel job: rc=4 means auth failed;
    // rc=5 (job not found) means tenant+token are valid.
    let cmd = jobctl_cmd() + " get --tenant " + shquote(tenant)
        + " --token " + shquote(token) + " --job __auth_check__"
    let r = exec_with_status(cmd)
    if r[1] == 4 {
        return _html_ok(render_login_page("authentication failed"))
    }
    let sid = session_create(tenant, token)
    return redirect_with_cookie("/dashboard", cookie_set_str("phanes_session", sid, 86400))
}

fn handle_logout(request) {
    session_destroy(cookie_get(request, "phanes_session"))
    return redirect_with_cookie("/", cookie_clear_str("phanes_session"))
}

// Switch tenant (Decision 9 — re-auth switch). The session is bound to a
// single (tenant, token) pair and each tenant has its own bearer token,
// so "switching" is genuinely re-authenticating. Destroy the current
// session (no stale token lingers) and redirect to /login for a fresh
// credential prompt. No cross-tenant data sharing — each tenant's
// jobs/catalog stay isolated (Decision 6).
fn handle_switch_tenant(request) {
    session_destroy(cookie_get(request, "phanes_session"))
    return redirect_with_cookie("/login", cookie_clear_str("phanes_session"))
}

// ── /lang/<code>?from=<path> — set phanes_lang cookie + redirect ─
fn handle_lang_set(request) {
    let path = request["path"]
    let prefix = "/lang/"
    let mut code = "en"
    if len(path) >= len(prefix) {
        if path.substring(0, len(prefix)) == prefix {
            let tail = path.substring(len(prefix), len(path))
            if _valid_lang(tail) { code = tail }
        }
    }
    let mut from = "/"
    let query = request["query"]
    if query != nil {
        if len(to_string(query)) > 0 {
            let q = parse_query(to_string(query))
            let f = q["from"]
            if f != nil {
                let fs = urldecode(to_string(f))
                if len(fs) > 0 { from = fs }
            }
        }
    }
    let cookie = "phanes_lang=" + code + "; Path=/; SameSite=Lax; Max-Age=31536000"
    return redirect_with_cookie(from, cookie)
}

// ── dashboard handlers (session auth) ────────────────────────────

fn handle_dashboard(request) {
    let sess = current_session(request)
    if sess == nil { return redirect_resp("/login") }
    let tenant = to_string(sess["tenant"])
    let token  = to_string(sess["token"])
    // Pre-render existing jobs (newest first, capped at 20).
    let jobs = list_tenant_jobs(tenant, 20)
    let mut rows = ""
    let mut i = 0
    while i < len(jobs) {
        rows = rows + render_existing_job_row(tenant, token, jobs[i])
        i = i + 1
    }
    return _html_ok(render_dashboard_page_for(tenant, rows))
}

fn handle_dash_submit(request) {
    let sess = current_session(request)
    if sess == nil {
        return _html_401("<li style=\"color:#ff7b72\">session expired — log in again</li>")
    }
    let tenant = to_string(sess["tenant"])
    let token  = to_string(sess["token"])
    let body = request["body"]
    if body == nil { body = "" }
    let q = parse_query(body)
    let seed_r   = q["seed"];   if seed_r == nil { seed_r = "" }
    let rounds_r = q["rounds"]; if rounds_r == nil { rounds_r = "1" }
    let seed   = urldecode(seed_r)
    let rounds = urldecode(rounds_r)
    if len(seed) < 10 {
        return _html_400("<li style=\"color:#ff7b72\">seed too short (>=10 chars substantive)</li>")
    }
    let cmd = jobctl_cmd()
        + " submit --tenant " + shquote(tenant)
        + " --token "        + shquote(token)
        + " --seed "         + shquote(seed)
        + " --rounds "       + shquote(rounds)
    let r = exec_with_status(cmd)
    let stdout = r[0]; let rc = r[1]
    if rc == 4 {
        return _html_401("<li style=\"color:#ff7b72\">auth failed (session stale)</li>")
    }
    if rc != 0 {
        return _html_500("<li style=\"color:#ff7b72\">jobctl rc=" + to_string(rc) + "</li>")
    }
    let job_id = stdout.trim()
    return _html_ok(render_job_row(job_id, "queued", "-", rounds, "-", ""))
}

fn handle_dash_get_job(request) {
    let sess = current_session(request)
    if sess == nil {
        return _html_401("<li>session expired</li>")
    }
    let tenant = to_string(sess["tenant"])
    let token  = to_string(sess["token"])
    let path = request["path"]
    let prefix = "/dashboard/jobs/"
    if len(path) < len(prefix) { return _html_400("<li>not found</li>") }
    if path.substring(0, len(prefix)) != prefix { return _html_400("<li>not found</li>") }
    let job_id = path.substring(len(prefix), len(path))
    if len(job_id) == 0 { return _html_400("<li>job id required</li>") }
    return _html_ok(render_existing_job_row(tenant, token, job_id))
}

// ── dispatcher (server_serve calls this per request) ─────────────

fn dispatch(handler_name, request) {
    if request["method"] == "OPTIONS" { return cors_preflight() }
    if handler_name == "cosmogony"     { return handle_cosmogony(request) }
    if handler_name == "phanes_page"   { return handle_phanes_page(request) }
    if handler_name == "demiurge_page" { return handle_demiurge_page(request) }
    if handler_name == "hexa_lang_page" { return handle_hexa_lang_page(request) }
    if handler_name == "anima_page"    { return handle_anima_page(request) }
    if handler_name == "login_get"     { return handle_login_get(request) }
    if handler_name == "login_post"    { return handle_login_post(request) }
    if handler_name == "logout"        { return handle_logout(request) }
    if handler_name == "switch_tenant" { return handle_switch_tenant(request) }
    if handler_name == "lang_set"      { return handle_lang_set(request) }
    if handler_name == "health"        { return handle_health(request) }
    if handler_name == "static_htmx"   { return handle_static_htmx(request) }
    if handler_name == "submit"        { return handle_submit(request) }
    if handler_name == "get_or_result" { return handle_get_or_result(request) }
    if handler_name == "dashboard"     { return handle_dashboard(request) }
    if handler_name == "dash_submit"   { return handle_dash_submit(request) }
    if handler_name == "dash_get_job"  { return handle_dash_get_job(request) }
    return json_error(500, "unknown handler: " + handler_name)
}

// ── main ─────────────────────────────────────────────────────────

fn main() {
    let mut host = env("PHANES_BIND_HOST")
    if len(host) == 0 { host = "127.0.0.1" }
    let port_s = env("PHANES_BIND_PORT")
    let mut port = 8787
    if len(port_s) > 0 { port = to_int(port_s) }

    let s = server_new(host, port)
    // public marketing chrome
    server_route(s, "GET",  "/",                "cosmogony")
    server_route(s, "GET",  "/phanes",          "phanes_page")
    server_route(s, "GET",  "/demiurge",        "demiurge_page")
    server_route(s, "GET",  "/hexa-lang",       "hexa_lang_page")
    server_route(s, "GET",  "/anima",           "anima_page")
    // auth
    server_route(s, "GET",  "/login",           "login_get")
    server_route(s, "POST", "/login",           "login_post")
    server_route(s, "POST", "/logout",          "logout")
    server_route(s, "POST", "/switch-tenant",   "switch_tenant")
    server_mount(s, "GET",  "/lang/",           "lang_set")
    // self-hosted static asset (HTMX bundle) — no external CDN
    server_route(s, "GET",  "/static/htmx.min.js", "static_htmx")
    // API
    server_route(s, "GET",  "/v1/healthz",      "health")
    server_route(s, "POST", "/v1/jobs",         "submit")
    server_mount(s, "GET",  "/v1/jobs/",        "get_or_result")
    // HTMX dashboard (Decision 8)
    server_route(s, "GET",  "/dashboard",       "dashboard")
    server_route(s, "POST", "/dashboard/jobs",  "dash_submit")
    server_mount(s, "GET",  "/dashboard/jobs/", "dash_get_job")
    server_listen(s)
    println("phanes-http listening on " + host + ":" + to_string(port))
    server_serve(s, dispatch)
}
