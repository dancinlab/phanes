    h = h + "<div class=\"sub\">Reach the team behind Phanes — for early access, enterprise plans, or the source itself</div>"
    h = h + "<div class=\"cue\">↓ scroll</div>"
    h = h + "</section>"
    // overview
    h = h + "<section class=\"sec\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">Get In Touch</h2>"
    h = h + "<p class=\"lead\">Phanes is a dancinlab product, built downstream of the open hexa-lang toolchain. The source is public and source-available — the fastest way to reach us is through the repository.</p>"
    h = h + "<p class=\"ov-p2\">Whether you want early-access pricing, a plan sized for your team, to report something, or just to read the code that backs every honesty claim on this site — the channels below are the way in.</p>"
    h = h + "</div></section>"
    // channels — cards
    h = h + "<section class=\"sec\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">Channels</h2>"
    h = h + "<div class=\"cards\">"
    h = h + render_feat_card("01", "GitHub — Issues",
        "Bugs, questions, and feature requests.",
        "Open an issue on the public <a href=\"https://github.com/dancinlab/phanes/issues\">dancinlab/phanes</a> repository. This is the primary channel — public, tracked, and the same place the source itself lives. A reproducible bug, a concrete feature request, an open-ended question: all of it goes here.")
    h = h + render_feat_card("02", "GitHub — The Source",
        "Read the code behind the claims.",
        "Phanes is source-available at <a href=\"https://github.com/dancinlab/phanes\">dancinlab/phanes</a>: every honest-scope claim on this site — verifier-as-sole-authority, no over-claim — is auditable in the repository. Browsing the code is itself a way to evaluate us.")
    h = h + render_feat_card("03", "Email — hello@dancinlab.org",
        "Early access, enterprise, private inquiries.",
        "Anything that does not belong in a public channel — early-access pricing, a plan sized for your team, security disclosures, or larger objectives — goes to <a href=\"mailto:hello@dancinlab.org\">hello@dancinlab.org</a>. Tell us the kind of objective, the verifier you have in mind, and the scale; we will follow up.")
    h = h + render_feat_card("04", "The Demo",
        "See it before you ask.",
        "The public demo runs three curated discovery scenarios end to end — the quickest way to understand what Phanes does before getting in touch.")
    h = h + "</div></div></section>"
    // closer CTA
    h = h + "<section class=\"sec vf\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">Start Here</h2>"
    h = h + "<p class=\"lead\">New to Phanes? Run the demo first, then reach out — or jump straight to the dashboard if you already have access.</p>"
    h = h + "<div class=\"vf-cta\">" + render_github_cta("dancinlab/phanes", "GitHub")
    h = h + "<span class=\"vf-sister\">or — <a href=\"/demo?lang=" + lang + "\">see the demo</a></span>"
    h = h + "</div></div></section>"
    h = h + render_site_footer(lang)
    h = h + "</body></html>"
    return h
}

// ── 4 product pages — each builds a config dict for the 5-section
//    overview template. Section copy stays English (user directive:
//    only UI chrome + phonetic translate; descriptions do not). ──────

fn render_phanes_page(lang) {
    let c = #{}
    c["slug"] = "phanes"
    c["mark"] = "PHANES"
    c["phonetic"] = _t("phanes_phonetic", lang)
    c["hero_tag"] = "Autonomous Discovery · SaaS"
    c["hero_sub"] = "Enterprise-grade autonomous discovery — for any measurable objective"
    c["s1v"] = "6"
    c["s1l"] = "stage discovery chain"
    c["s2v"] = "100%"
    c["s2l"] = "provenance tracked"
    c["s3v"] = "0"
    c["s3l"] = "over-claim, by rule"
    c["ov_eyebrow"] = "Next-Generation Discovery"
    c["ov_lead"] = "Phanes wraps hexa-lang's OUROBOROS engine — the loop goal, falsifier, saturation, run in rounds with a per-round honesty gate — as a hosted web product. A company brings a measurable objective and a verifier; Phanes drives the engine against it and returns a verified, provenance-tracked discovery catalog. Their own private echoes."
    c["ov_p2"] = "The engine is not a black box. Every round is a goal proposed, a falsifier fired against it, and a saturation check — and every step is written to an audit trail you can inspect. What Phanes sells is not a promise that your objective is met; it is a verified record of exactly what the engine found and exactly how hard it tried to break it."
    c["kf_eyebrow"] = "Key Features"
    c["f1l"] = "Pluggable Seed and Verifier:"
    c["f1b"] = "Bring a seed and a verifier oracle. Under scope B the tenant verifier is the sole authority for objective-met — Phanes never substitutes its own advisory gate."
    c["f2l"] = "Provenance Track:"
    c["f2b"] = "Every round is logged with its falsification audit trail. The result is an exportable, per-tenant catalog you can verify line by line."
    c["f3l"] = "Sandboxed Compute:"
    c["f3b"] = "Each job runs in a per-tenant home-jail with an arena-free runtime. Isolation holds at concurrency; defense-in-depth, measured."
    c["hw_eyebrow"] = "How It Works"
    c["w1t"] = "Submit a Seed"
    c["w1b"] = "Bring a measurable objective and a verifier script. The seed is the starting point the engine reasons from."
    c["w2t"] = "OUROBOROS Runs"
    c["w2b"] = "The engine runs rounds — goal, falsifier, saturation — reseeding each round from the last round's findings."
    c["w3t"] = "Honesty Gate"
    c["w3b"] = "Every round passes a falsification gate. A claim that cannot survive its own falsifier does not advance."
    c["w4t"] = "Verified Catalog"
    c["w4b"] = "Saturation returns a provenance-tracked catalog — your own private echoes, exportable and auditable."
    c["cn_eyebrow"] = "A Connected Discovery Loop"
    c["c1t"] = "Harness the Engine"
    c["c1l"] = "Drive the full OUROBOROS loop from the web."
    c["c1b"] = "Phanes connects the seed, the rounds, and the saturation check into one hosted workflow — the same drill engine that powers hexa-lang's own discovery cycles, behind an authenticated control plane."
    c["c2t"] = "Customize the Workspace"
    c["c2l"] = "A live dashboard, no page reloads."
    c["c2b"] = "Submit jobs and watch them progress through an HTMX-polled dashboard. Polling auto-stops the instant a job reaches done or failed — the interface knows when to be quiet."
    c["c3t"] = "Security Powering Trust"
    c["c3l"] = "Per-tenant isolation across every job."
    c["c3b"] = "Hybrid multi-tenant isolation — a per-job home-jail now, a first-class data-dir boundary upstream. Session cookies and bearer tokens gate every authenticated surface."
    c["c4t"] = "Enabling Developers"
    c["c4l"] = "Bring your own verifier."
    c["c4b"] = "The seed format is open and the verifier is just a script that exits zero on PASS. Wire any measurable objective into the loop without forking the engine."
    c["vf_eyebrow"] = "A Verified Solution"
    c["vf_body"] = "Phanes operates under scope B: the tenant-supplied verifier is the sole authority for objective-met, and Phanes never claims a result the verifier did not pass. It is built on hexa-lang — OUROBOROS cycle h36 complete, a bit-stable self-host fixpoint, tier-1 codegen-correctness verified — and inherits its real-limits-first honesty rule. No over-claim, no project-completion promise. Saturation is the only hard stop."
    c["cta_html"] = render_cta("/login", _t("enter", lang), "primary-lg")
    c["sister_label"] = "DEMIURGE"
    c["sister_href"] = "/demiurge?lang=" + lang
    return render_product_overview_page(lang, c)
}

fn render_demiurge_page(lang) {
