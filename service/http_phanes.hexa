// ── auth handlers ────────────────────────────────────────────────

fn handle_login_get(request) {
    return _html_ok(render_login_page(""))
}

fn handle_login_post(request) {
    let body = request["body"]
    if body == nil { body = "" }
    let q = parse_query(body)
    let tenant_r = q["tenant"]; if tenant_r == nil { tenant_r = "" }
    let token_r  = q["token"];  if token_r == nil { token_r = "" }
    let tenant = urldecode(tenant_r).trim()
    let token  = urldecode(token_r).trim()
    if len(tenant) == 0 || len(token) == 0 {
        return _html_ok(render_login_page("tenant and token required"))
    }
    // Rate limit: cap bearer-token guessing — 5 attempts / 5 min per
    // tenant name. The dominant attack (brute-forcing one tenant's
    // token) shares a key, so it is throttled.
    if !rate_limit_ok("login:" + tenant, 5, 300) {
        return _html_429(render_login_page("too many attempts — wait a few minutes"))
    }
    // Validate via jobctl get on a sentinel job: rc=4 means auth failed;
    // rc=5 (job not found) means tenant+token are valid.
    let cmd = jobctl_cmd() + " get --tenant " + shquote(tenant)
        + " --token " + shquote(token) + " --job __auth_check__"
    let r = exec_with_status(cmd)
    if r[1] == 4 {
        return _html_ok(render_login_page("authentication failed"))
    }
    let sid = session_create(tenant, token)
    return redirect_with_cookie("/dashboard", cookie_set_str("phanes_session", sid, 86400))
}

fn handle_logout(request) {
    session_destroy(cookie_get(request, "phanes_session"))
    return redirect_with_cookie("/", cookie_clear_str("phanes_session"))
}

// Switch tenant (Decision 9 — re-auth switch). The session is bound to a
// single (tenant, token) pair and each tenant has its own bearer token,
// so "switching" is genuinely re-authenticating. Destroy the current
// session (no stale token lingers) and redirect to /login for a fresh
// credential prompt. No cross-tenant data sharing — each tenant's
// jobs/catalog stay isolated (Decision 6).
fn handle_switch_tenant(request) {
    session_destroy(cookie_get(request, "phanes_session"))
    return redirect_with_cookie("/login", cookie_clear_str("phanes_session"))
}

// ── /lang/<code>?from=<path> — set phanes_lang cookie + redirect ─
fn handle_lang_set(request) {
    let path = request["path"]
    let prefix = "/lang/"
    let mut code = "en"
    if len(path) >= len(prefix) {
        if path.substring(0, len(prefix)) == prefix {
            let tail = path.substring(len(prefix), len(path))
            if _valid_lang(tail) { code = tail }
        }
    }
    let mut from = "/"
    let query = request["query"]
    if query != nil {
        if len(to_string(query)) > 0 {
            let q = parse_query(to_string(query))
            let f = q["from"]
            if f != nil {
                let fs = urldecode(to_string(f))
                if len(fs) > 0 { from = fs }
            }
        }
    }
    let cookie = "phanes_lang=" + code + "; Path=/; SameSite=Lax; Max-Age=31536000"
    return redirect_with_cookie(from, cookie)
}

// ── dashboard handlers (session auth) ────────────────────────────

fn handle_dashboard(request) {
    let sess = current_session(request)
    if sess == nil { return redirect_resp("/login") }
    let tenant = to_string(sess["tenant"])
    let token  = to_string(sess["token"])
    // Pre-render existing jobs (newest first, capped at 20).
    let jobs = list_tenant_jobs(tenant, 20)
    let mut rows = ""
    let mut i = 0
    while i < len(jobs) {
        rows = rows + render_existing_job_row(tenant, token, jobs[i])
        i = i + 1
    }
    return _html_ok(render_dashboard_page_for(tenant, rows))
}

fn handle_dash_submit(request) {
    let sess = current_session(request)
    if sess == nil {
        return _html_401("<li style=\"color:var(--accent-red)\">session expired — log in again</li>")
    }
    let tenant = to_string(sess["tenant"])
    let token  = to_string(sess["token"])
    // Rate limit: same kick-job compute cost as the API submit — shares
    // the per-tenant "submit:" counter so the API and dashboard paths
    // are capped together (20 / 60 s).
    if !rate_limit_ok("submit:" + tenant, 20, 60) {
        return _html_429("<li style=\"color:var(--accent-red)\">rate limit — too many submits, wait a moment</li>")
    }
    let body = request["body"]
    if body == nil { body = "" }
    let q = parse_query(body)
    let seed_r   = q["seed"];   if seed_r == nil { seed_r = "" }
    let rounds_r = q["rounds"]; if rounds_r == nil { rounds_r = "1" }
    let seed   = urldecode(seed_r)
    let rounds = urldecode(rounds_r)
    if len(seed) < 10 {
        return _html_400("<li style=\"color:var(--accent-red)\">seed too short (>=10 chars substantive)</li>")
    }
    let cmd = jobctl_cmd()
        + " submit --tenant " + shquote(tenant)
        + " --token "        + shquote(token)
        + " --seed "         + shquote(seed)
        + " --rounds "       + shquote(rounds)
    let r = exec_with_status(cmd)
    let stdout = r[0]; let rc = r[1]
    if rc == 4 {
        return _html_401("<li style=\"color:var(--accent-red)\">auth failed (session stale)</li>")
    }
    if rc != 0 {
        return _html_500("<li style=\"color:var(--accent-red)\">jobctl rc=" + to_string(rc) + "</li>")
    }
    let job_id = stdout.trim()
    return _html_ok(render_job_row(job_id, "queued", "-", rounds, "-", ""))
}

fn handle_dash_get_job(request) {
    let sess = current_session(request)
    if sess == nil {
        return _html_401("<li>session expired</li>")
    }
    let tenant = to_string(sess["tenant"])
    let token  = to_string(sess["token"])
    let path = request["path"]
    let prefix = "/dashboard/jobs/"
    if len(path) < len(prefix) { return _html_400("<li>not found</li>") }
    if path.substring(0, len(prefix)) != prefix { return _html_400("<li>not found</li>") }
    let job_id = path.substring(len(prefix), len(path))
    if len(job_id) == 0 { return _html_400("<li>job id required</li>") }
    return _html_ok(render_existing_job_row(tenant, token, job_id))
}

// ── dispatcher (server_serve calls this per request) ─────────────

fn dispatch(handler_name, request) {
    if request["method"] == "OPTIONS" { return cors_preflight() }
    if handler_name == "cosmogony"     { return handle_cosmogony(request) }
    if handler_name == "phanes_page"   { return handle_phanes_page(request) }
    if handler_name == "demiurge_page" { return handle_demiurge_page(request) }
    if handler_name == "hexa_lang_page" { return handle_hexa_lang_page(request) }
    if handler_name == "anima_page"    { return handle_anima_page(request) }
    if handler_name == "demo_page"     { return handle_demo_page(request) }
    if handler_name == "pricing_page"  { return handle_pricing_page(request) }
    if handler_name == "contact_page"  { return handle_contact_page(request) }
    if handler_name == "login_get"     { return handle_login_get(request) }
    if handler_name == "login_post"    { return handle_login_post(request) }
    if handler_name == "logout"        { return handle_logout(request) }
    if handler_name == "switch_tenant" { return handle_switch_tenant(request) }
    if handler_name == "lang_set"      { return handle_lang_set(request) }
    if handler_name == "health"        { return handle_health(request) }
    if handler_name == "static_htmx"   { return handle_static_htmx(request) }
    if handler_name == "submit"        { return handle_submit(request) }
    if handler_name == "get_or_result" { return handle_get_or_result(request) }
    if handler_name == "dashboard"     { return handle_dashboard(request) }
    if handler_name == "dash_submit"   { return handle_dash_submit(request) }
    if handler_name == "dash_get_job"  { return handle_dash_get_job(request) }
    return json_error(500, "unknown handler: " + handler_name)
}

// ── main ─────────────────────────────────────────────────────────

// PHANES_R2_SELFTEST=1 — exercise the real r2_put/get/delete path
// against the live bucket then exit (ops health check; no duplicated
// signing code). Round-trips a unique key, asserts body byte-equality,
// deletes it, asserts the delete took. Prints `R2-SELFTEST: PASS|FAIL`.
fn r2_selftest() {
    let stamp = env("PHANES_R2_SELFTEST_STAMP")
    let backend = "filesystem"
    if _r2_enabled() { backend = "R2(" + _r2_bucket() + "@" + _r2_host() + ")" }
    println("R2-SELFTEST: kv-backend=" + backend)
    // Raw-R2 object probe — only when R2 is the backend (no-op under the
    // filesystem degrade path, where the _kv_* seam below is the test).
    if !_r2_enabled() {
        println("  (R2 disabled — skipping raw-object probe, testing _kv_* seam only)")
        r2_selftest_session(stamp)
        return
    }
    let key   = "_selftest/" + stamp + ".txt"
    let body  = "phanes-r2-selftest-" + stamp
    let p = r2_put(key, body)
    println("  put    -> ok=" + to_string(p["ok"]) + " status=" + to_string(p["status"]) + " err=" + p["error"])
    if !p["ok"] { println("R2-SELFTEST: FAIL (put)"); return }
    let g = r2_get(key)
    println("  get    -> ok=" + to_string(g["ok"]) + " status=" + to_string(g["status"]) + " bytes=" + to_string(len(g["body"])))
    if !g["ok"] { println("R2-SELFTEST: FAIL (get)"); return }
    if g["body"] != body {
        println("  body MISMATCH: got [" + g["body"] + "] want [" + body + "]")
        println("R2-SELFTEST: FAIL (roundtrip)"); return
    }
    let d = r2_delete(key)
    println("  delete -> ok=" + to_string(d["ok"]) + " status=" + to_string(d["status"]))
    if !d["ok"] { println("R2-SELFTEST: FAIL (delete)"); return }
    let g2 = r2_get(key)
    println("  get'   -> status=" + to_string(g2["status"]) + " (expect 404)")
    if g2["ok"] { println("R2-SELFTEST: FAIL (delete did not take)"); return }
    r2_selftest_session(stamp)
}

// Session lifecycle through the real _kv_* seam — mode-agnostic, so it
// proves both the R2-backed and the filesystem-degrade path.
fn r2_selftest_session(stamp) {
    let sid = session_create("selftest-tenant", "selftest-token-" + stamp)
    println("  sess+  -> sid=" + sid.substring(0, 8) + "…")
    let sl = session_load(sid)
    if sl == nil { println("R2-SELFTEST: FAIL (session_load nil)"); return }
    if sl["tenant"] != "selftest-tenant" || sl["token"] != "selftest-token-" + stamp {
        println("R2-SELFTEST: FAIL (session roundtrip mismatch)"); return
    }
    println("  sess=  -> tenant=" + sl["tenant"] + " ok")
    session_destroy(sid)
    if session_load(sid) != nil { println("R2-SELFTEST: FAIL (session_destroy did not take)"); return }
    println("  sess-  -> destroyed ok")
    println("R2-SELFTEST: PASS")
}

// R2 object CLI op (Phase B3 storage primitive). Lets the bash
// substrate (jobctl.sh / job_runner.sh) read+write tenant/job records
// to R2 *through the already-measured r2_*/_kv_* code* — one SigV4
// signer SSOT, no hand-rolled bash curl+signing (which would duplicate
// stdlib/aws/sigv4.hexa, against @D g_stdlib_ownership). Queue-
// independent: this is storage only; the CF-Queue consumer loop is the
// F-D23-gated remainder of B3.
//   PHANES_R2_OP=get   PHANES_R2_KEY=k     -> stdout = body, exit 0; 1 if absent
//   PHANES_R2_OP=put   PHANES_R2_KEY=k     -> body from stdin, exit 0/1
//   PHANES_R2_OP=del   PHANES_R2_KEY=k     -> exit 0
//   PHANES_R2_OP=list  PHANES_R2_KEY=prefix-> stdout = ListObjectsV2 XML, exit 0/1
// Honours the same _kv_* degrade (filesystem when R2 creds absent).
fn r2_op() {
    let op  = env("PHANES_R2_OP")
    let key = env("PHANES_R2_KEY")
    if op == "get" {
        let v = _kv_get(key)
        if v == nil { exit(1) }
        print(v)
        exit(0)
    }
    if op == "put" {
        if _kv_put(key, read_stdin()) { exit(0) }
        exit(1)
    }
    if op == "del" { _kv_del(key); exit(0) }
    if op == "list" {
        let r = r2_list(key)
        if !r["ok"] { exit(1) }
        print(r["body"])
        exit(0)
    }
    eprintln("phanes r2-op: unknown PHANES_R2_OP '" + op + "' (get|put|del|list)")
    exit(2)
}

fn main() {
    if env("PHANES_R2_SELFTEST") == "1" { r2_selftest(); return }
    if len(env("PHANES_R2_OP")) > 0 { r2_op(); return }
    let mut host = env("PHANES_BIND_HOST")
    if len(host) == 0 { host = "127.0.0.1" }
    let port_s = env("PHANES_BIND_PORT")
    let mut port = 8787
    if len(port_s) > 0 { port = to_int(port_s) }

    let s = server_new(host, port)
    // public marketing chrome
    server_route(s, "GET",  "/",                "cosmogony")
    server_route(s, "GET",  "/phanes",          "phanes_page")
    server_route(s, "GET",  "/demiurge",        "demiurge_page")
    server_route(s, "GET",  "/hexa-lang",       "hexa_lang_page")
    server_route(s, "GET",  "/anima",           "anima_page")
    // public demo funnel (Decision 3 = 가 · P4) — preset scenarios,
    // cached results, zero live compute (Decision 10)
    server_route(s, "GET",  "/demo",            "demo_page")
    server_route(s, "GET",  "/pricing",         "pricing_page")
    server_route(s, "GET",  "/contact",         "contact_page")
    // auth
    server_route(s, "GET",  "/login",           "login_get")
    server_route(s, "POST", "/login",           "login_post")
    server_route(s, "POST", "/logout",          "logout")
    server_route(s, "POST", "/switch-tenant",   "switch_tenant")
    server_mount(s, "GET",  "/lang/",           "lang_set")
    // self-hosted static asset (HTMX bundle) — no external CDN
    server_route(s, "GET",  "/static/htmx.min.js", "static_htmx")
    // API
    server_route(s, "GET",  "/v1/healthz",      "health")
    server_route(s, "POST", "/v1/jobs",         "submit")
    server_mount(s, "GET",  "/v1/jobs/",        "get_or_result")
    // HTMX dashboard (Decision 8)
    server_route(s, "GET",  "/dashboard",       "dashboard")
    server_route(s, "POST", "/dashboard/jobs",  "dash_submit")
    server_mount(s, "GET",  "/dashboard/jobs/", "dash_get_job")
    server_listen(s)
    println("phanes-http listening on " + host + ":" + to_string(port))
    server_serve(s, dispatch)
}
