    h = h + render_cosmo_card("demiurge", "DEMIURGE", _t("demiurge_phonetic", lang), _tr(lang, "design · meta-conductor", "설계 · 메타 컨덕터", "設計 · メタコンダクター", "设计 · 元指挥", "проектирование · мета-дирижёр"), _tr(lang, "universal technical-design — a seven-verb engineering spine", "범용 기술 설계 — 7개 동사의 엔지니어링 척추", "汎用的な技術設計 — 7つの動詞のエンジニアリング背骨", "通用技术设计 — 一条七动词的工程脊柱", "универсальное техническое проектирование — семиглагольный инженерный хребет"), _t("read_more", lang), lang)
    h = h + render_cosmo_card("hexa-lang", "HEXA-LANG", "", _tr(lang, "substrate · compiler", "기반 · 컴파일러", "基盤 · コンパイラ", "底层 · 编译器", "субстрат · компилятор"), _tr(lang, "native compiler with atlas-bound theorems · no LLVM", "atlas 에 묶인 정리를 갖춘 네이티브 컴파일러 · LLVM 없음", "atlas に束縛された定理を持つネイティブコンパイラ · LLVM なし", "带 atlas 绑定定理的原生编译器 · 无 LLVM", "нативный компилятор с теоремами, привязанными к atlas · без LLVM"), _t("read_more", lang), lang)
    h = h + render_cosmo_card("anima", "ANIMA", "", _tr(lang, "consciousness · model", "의식 · 모델", "意識 · モデル", "意识 · 模型", "сознание · модель"), _tr(lang, "consciousness language model · phi-scaled, law-bound", "의식 언어 모델 · phi 스케일, 법칙에 묶임", "意識言語モデル · phi スケール、法則に束縛", "意识语言模型 · phi 缩放、受法则约束", "языковая модель сознания · phi-масштабированная, связанная законами"), _t("read_more", lang), lang)
    h = h + "</div></div></section>"
