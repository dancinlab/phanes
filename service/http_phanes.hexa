// phanes — P1b HTTP transport (hexa-native; stdlib/net)
//
// A thin 1:1 skin over the verified jobctl substrate (service/jobctl.sh).
// Per service/API.md. Downstream invariant: this program INVOKES the
// upstream `hexa` toolchain at build time and the upstream `hexa kick`
// binary at run time (via jobctl) — it does not vendor or fork hexa-lang.
//
// Build:  service/build.sh   (HEXA_HOME defaults to ~/core/hexa-lang)
// Run:    PHANES_HOME=<phanes repo> ./bin/phanes-http
// Env:    PHANES_HOME · PHANES_BIND_HOST (default 127.0.0.1) ·
//         PHANES_BIND_PORT (default 8787)
//
// Routes (see service/API.md):
//   GET  /v1/healthz                 -> "ok"
//   POST /v1/jobs                    -> submit { seed, rounds } (form-encoded body)
//   GET  /v1/jobs/<id>               -> job.json
//   GET  /v1/jobs/<id>/result        -> DrillResult JSON
//
// Auth: Authorization: Bearer <token>  +  X-Phanes-Tenant: <tenant>
//       (validated by jobctl; this layer just passes through.)

import "stdlib/net/http_server.hexa"
import "stdlib/net/http_request.hexa"
import "stdlib/net/http_response.hexa"
import "stdlib/aws/sigv4.hexa"

// ── small helpers ────────────────────────────────────────────────

fn shquote(s) {
    // POSIX single-quote wrap: ' -> '\''
    return "'" + s.replace("'", "'\\''") + "'"
}

fn header_get(request, key_lower) {
    let headers = request["headers"]
    if headers == nil { return "" }
    let v = headers[key_lower]
    if v == nil { return "" }
    return to_string(v)
}

fn bearer_token(request) {
    let auth = header_get(request, "authorization")
    if len(auth) < 7 { return "" }
    if auth.substring(0, 7) == "Bearer " {
        return auth.substring(7, len(auth))
    }
    return ""
}

fn jobctl_cmd() {
    let here = env("PHANES_HOME")
    if len(here) == 0 { here = "." }
    return here + "/service/jobctl.sh"
}

// ── handlers ─────────────────────────────────────────────────────

fn handle_health(request) {
    return text_ok("ok\n")
}

// Serve the self-hosted HTMX bundle (web/static/htmx.min.js). Replaces
// the unpkg CDN <script> so the only interactive page has no external
// SPOF and runs no third-party-origin script. The file is version-
// pinned (htmx 1.9.10, sha384 verified at vendor time), so it is served
// with a hard immutable cache — distinct from the no-store HTML resp.
fn handle_static_htmx(request) {
    let mut home = env("PHANES_HOME")
    if len(home) == 0 { home = "." }
    let p = home + "/web/static/htmx.min.js"
    if !file_exists(p) {
        return json_error(404, "static asset not found: htmx.min.js")
    }
    let resp = #{}
    resp["status"] = 200
    resp["content_type"] = "application/javascript; charset=utf-8"
    let hdr = #{}
    hdr["Cache-Control"] = "public, max-age=31536000, immutable"
    resp["headers"] = hdr
    resp["body"] = read_file(p)
    return resp
}

fn handle_submit(request) {
    let tenant = header_get(request, "x-phanes-tenant")
    let token  = bearer_token(request)
    if len(tenant) == 0 { return json_error(401, "X-Phanes-Tenant header required") }
    if len(token)  == 0 { return json_error(401, "Authorization: Bearer <token> required") }
    // Rate limit: each submit spawns a kick job (real EC2 compute) —
    // 20 submits / 60 s per tenant caps a leaked/buggy client from
    // running the cost up. Generous for legitimate interactive use.
    if !rate_limit_ok("submit:" + tenant, 20, 60) {
        return json_error(429, "rate limit exceeded — too many submits, slow down")
    }
    // JSON body: { "seed": "<>=10 char>", "rounds": <int> }
    // Form-encoded body is not used (stdlib parse_query splits naively on
    // every '=' — measured to truncate seeds containing '=' in P1b smoke).
    let body = request["body"]
    if body == nil { body = "" }
    if len(body) == 0 { return json_error(400, "JSON body required") }
    let m = json_parse(body)
    if m == nil { return json_error(400, "JSON body did not parse") }
    let seed_v = m["seed"]
    if seed_v == nil { return json_error(400, "seed (string) required in JSON body") }
    let seed = to_string(seed_v)
    if len(seed) < 10 {
        return json_error(400, "seed required (>=10 chars, substantive problem statement)")
    }
    let mut rounds = "1"
    let r_v = m["rounds"]
    if r_v != nil { rounds = to_string(r_v) }
    let cmd = jobctl_cmd()
        + " submit --tenant " + shquote(tenant)
        + " --token "        + shquote(token)
        + " --seed "         + shquote(seed)
        + " --rounds "       + shquote(rounds)
    let r = exec_with_status(cmd)
    let stdout = r[0]
    let rc = r[1]
    if rc == 4 { return json_error(401, "auth failed") }
    if rc != 0 { return json_error(500, "jobctl rc=" + to_string(rc) + " · stdout=" + stdout) }
    let out = #{}
    let job_id = stdout.trim()
    out["job_id"] = job_id
    // Decision 24: the job record is now durable (jobctl returned the
    // id); HTTP-push the {tenant,job_id} pointer to the CF Queue so the
    // worker pool consumes it. Best-effort + reported in the response —
    // when the queue is disabled (no PHANES_Q_*) the local detached
    // spawn jobctl already started is the path (degrade), so a missing
    // queue never fails a submit.
    let q = q_send(tenant, job_id)
    out["queued"] = q["ok"]
    if !q["ok"] && q_enabled() { out["queue_error"] = q["error"] }
    let resp = #{}
    resp["status"] = 201
    resp["content_type"] = "application/json"
    resp["body"] = json_stringify(out)
    return resp
}

fn handle_get_or_result(request) {
    let tenant = header_get(request, "x-phanes-tenant")
    let token  = bearer_token(request)
    if len(tenant) == 0 { return json_error(401, "X-Phanes-Tenant header required") }
    if len(token)  == 0 { return json_error(401, "Authorization: Bearer <token> required") }
    let path = request["path"]
    let prefix = "/v1/jobs/"
    if len(path) < len(prefix) { return json_error(404, "not found") }
    if path.substring(0, len(prefix)) != prefix { return json_error(404, "not found") }
    let tail = path.substring(len(prefix), len(path))
    let mut job_id = tail
    let mut sub = "get"
    let slash = tail.index_of("/")
    if slash >= 0 {
        job_id = tail.substring(0, slash)
        let rest = tail.substring(slash + 1, len(tail))
        if rest == "result" {
            sub = "result"
        } else {
            return json_error(404, "not found")
        }
    }
    if len(job_id) == 0 { return json_error(400, "job id required in path") }
    let cmd = jobctl_cmd() + " " + sub
        + " --tenant " + shquote(tenant)
        + " --token "  + shquote(token)
        + " --job "    + shquote(job_id)
    let r = exec_with_status(cmd)
    let stdout = r[0]
    let rc = r[1]
    if rc == 4 { return json_error(401, "auth failed") }
    if rc == 5 { return json_error(404, "job not found") }
    if rc != 0 { return json_error(500, "jobctl rc=" + to_string(rc)) }
    let resp = #{}
    resp["status"] = 200
    resp["content_type"] = "application/json"
    resp["body"] = stdout
    return resp
}

// ── url-decode helper (form-body has + → space, %XX → byte) ──────
// stdlib parse_query does not decode; we do here for the /dashboard
// form-encoded surface (the /v1/jobs JSON-body API is unaffected).

fn _hex1(c) {
    if c == "0" { return 0 } if c == "1" { return 1 } if c == "2" { return 2 }
    if c == "3" { return 3 } if c == "4" { return 4 } if c == "5" { return 5 }
    if c == "6" { return 6 } if c == "7" { return 7 } if c == "8" { return 8 }
    if c == "9" { return 9 }
    if c == "a" { return 10 } if c == "b" { return 11 } if c == "c" { return 12 }
    if c == "d" { return 13 } if c == "e" { return 14 } if c == "f" { return 15 }
    if c == "A" { return 10 } if c == "B" { return 11 } if c == "C" { return 12 }
    if c == "D" { return 13 } if c == "E" { return 14 } if c == "F" { return 15 }
    return 0 - 1
}

fn urldecode(s) {
    let mut out = ""
    let mut i = 0
    let n = len(s)
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "+" {
            out = out + " "
            i = i + 1
        } else if c == "%" && (i + 2) < n {
            let h = _hex1(s.substring(i + 1, i + 2))
            let l = _hex1(s.substring(i + 2, i + 3))
            if h >= 0 && l >= 0 {
                out = out + chr(h * 16 + l)
                i = i + 3
            } else {
                out = out + c
                i = i + 1
            }
        } else {
            out = out + c
            i = i + 1
        }
    }
    return out
}

fn html_escape(s) {
    return s.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")
        .replace("\"", "&quot;").replace("'", "&#39;")
}

// ── session + cookie helpers (P3 real-auth) ──────────────────────
// Server-side session store: filesystem-backed (.store/sessions/<sid>).
// sid is 32 hex chars from /dev/urandom. session file = two lines:
// tenant\ntoken\n. Lost on .store wipe; OK for v1.

fn _store_root() {
    let here = env("PHANES_HOME")
    if len(here) == 0 { here = "." }
    return here + "/service/.store"
}

// ── Rate limiting (fixed-window, file-backed) ────────────────────
// Caps the cost-bearing / brute-forceable surfaces: login (bearer-token
// guessing) and job submit (each submit spawns a kick job — real EC2
// compute). The counter lives under .store/ratelimit/ — same store
// model as sessions. The select-loop server is single-threaded, so the
// file read-modify-write inside one check is race-free. Fixed window:
// the count resets once window_sec has elapsed since the window opened.
fn _ratelimit_dir() {
    let d = _store_root() + "/ratelimit"
    mkdir(d)
    return d
}

fn _now_epoch() {
    let r = exec_with_status("date +%s")
    if r[1] != 0 { return 0 }
    return to_int(r[0].trim())
}

// ── R2 object store (Decision 21 — ALL Cloudflare R2) ────────────
// phanes' datastore is Cloudflare R2: S3-compatible object storage,
// AWS-SigV4-authenticated (service="s3", region="auto", host
// <account>.r2.cloudflarestorage.com). Replaces the AWS DynamoDB+S3
// design — the app makes zero AWS calls; the only credential is an R2
// API token. Signing reuses the upstream stdlib/aws/sigv4.hexa (B2
// step-1) unchanged. Credentials come from R2_ACCESS_KEY_ID /
// R2_SECRET_ACCESS_KEY / R2_ACCOUNT_ID, populated by
// service/run-phanes.sh from the `secret` CLI's r2.phanes.* keys.
fn _r2_host() {
    return env("R2_ACCOUNT_ID") + ".r2.cloudflarestorage.com"
}

// r2_sign — S3 requires `x-amz-content-sha256` to be a *signed* header
// whose value is the payload hash, but the stdlib signer computes that
// hash internally and does not auto-attach the header. So: sign once to
// learn the payload hash from the result, attach it as a header, sign
// again. Two signings (microseconds each) keep this pure — no shell
// hashing, only the upstream stdlib signer (@D g_stdlib_ownership).
fn r2_sign(method, path, query, body, ak, sk, amz_date) {
    let host = _r2_host()
    let probe = Sigv4Request {
        method:        method,
        host:          host,
        region:        "auto",
        service:       "s3",
        path:          path,
        query:         query,
        headers:       [ Sigv4Header { name: "host", value: host },
                         Sigv4Header { name: "x-amz-date", value: amz_date } ],
        payload:       body,
        access_key:    ak,
        secret_key:    sk,
        amz_date:      amz_date,
        session_token: ""
    }
    let s1 = sigv4_sign(probe)
    let phash = s1.x_amz_content_sha256
    let req = Sigv4Request {
        method:        method,
        host:          host,
        region:        "auto",
        service:       "s3",
        path:          path,
        query:         query,
        headers:       [ Sigv4Header { name: "host", value: host },
                         Sigv4Header { name: "x-amz-content-sha256", value: phash },
                         Sigv4Header { name: "x-amz-date", value: amz_date } ],
        payload:       body,
        access_key:    ak,
        secret_key:    sk,
        amz_date:      amz_date,
        session_token: ""
    }
    return sigv4_sign(req)
}

// r2_request(method, bucket, key, query, body) — one signed R2 call.
// Posts via curl (the same shell-out pattern stdlib/net/http_client
// uses for GET — a generic signed HTTP verb is a stdlib gap). Returns:
//   "ok"     : bool   — HTTP 2xx
//   "status" : int    — HTTP status (0 on curl failure)
//   "body"   : str    — response body (or error stdout)
//   "error"  : str    — non-empty when ok=false
fn r2_request(method, bucket, key, query, body) {
    let ak   = env("R2_ACCESS_KEY_ID")
    let sk   = env("R2_SECRET_ACCESS_KEY")
    let acct = env("R2_ACCOUNT_ID")
    let mut result = #{}
    result["ok"]     = false
    result["status"] = 0
    result["body"]   = ""
    result["error"]  = ""
    if len(ak) == 0 || len(sk) == 0 || len(acct) == 0 {
        result["error"] = "R2 credentials missing — `secret set r2.phanes.access_key_id|secret_access_key|account_id`, relaunch via service/run-phanes.sh"
        return result
    }
    let now_r = exec_with_status("date -u +%Y%m%dT%H%M%SZ")
    if now_r[1] != 0 { result["error"] = "date(1) failed"; return result }
    let amz_date = now_r[0].trim()
    let mut path = "/" + bucket
    if len(key) > 0 { path = path + "/" + key }
    // `sig` not `signed` — `signed` is a C reserved word.
    let sig = r2_sign(method, path, query, body, ak, sk, amz_date)
    let host = acct + ".r2.cloudflarestorage.com"
    let mut url = "https://" + host + path
    if len(query) > 0 { url = url + "?" + query }
    let mut cmd = "curl -sS -X " + method + " --max-time 20"
        + " -H " + shquote("Host: "                 + host)
        + " -H " + shquote("X-Amz-Date: "            + sig.x_amz_date)
        + " -H " + shquote("X-Amz-Content-Sha256: "  + sig.x_amz_content_sha256)
        + " -H " + shquote("Authorization: "         + sig.authorization)
    if method == "PUT" {
        cmd = cmd + " --data-binary " + shquote(body)
    }
    cmd = cmd + " -w " + shquote("\n%{http_code}") + " " + shquote(url)
    let r = exec_with_status(cmd)
    let out = r[0]
    let rc  = r[1]
    if rc != 0 {
        result["error"] = "curl rc=" + to_string(rc)
        result["body"] = out
        return result
    }
    let lines = out.split("\n")
    let n = len(lines)
    if n < 1 { result["body"] = out; return result }
    let status_str = lines[n - 1].trim()
    let mut body_buf = ""
    let mut i = 0
    while i < n - 1 {
        if i > 0 { body_buf = body_buf + "\n" }
        body_buf = body_buf + lines[i]
        i = i + 1
    }
    result["status"] = to_int(status_str)
    result["body"]   = body_buf
    let st = result["status"]
    if st >= 200 && st < 300 { result["ok"] = true }
    if !result["ok"] && len(result["error"]) == 0 {
        result["error"] = "R2 status " + status_str
    }
    return result
}

// Convenience object verbs — what the .store/ → R2 migration (B2
// step-3+) calls. bucket is the phanes R2 bucket name (env
// R2_BUCKET, default "phanes").
fn _r2_bucket() {
    let b = env("R2_BUCKET")
    if len(b) == 0 { return "phanes" }
    return b
}
fn r2_put(key, body)  { return r2_request("PUT",    _r2_bucket(), key, "", body) }
fn r2_get(key)        { return r2_request("GET",    _r2_bucket(), key, "", "") }
fn r2_delete(key)     { return r2_request("DELETE", _r2_bucket(), key, "", "") }
// r2_list — ListObjectsV2 under a key prefix. Caller sorts/limits the
// returned XML (newest-first via a reverse-timestamp key prefix).
fn r2_list(prefix)    { return r2_request("GET", _r2_bucket(), "", "list-type=2&prefix=" + prefix, "") }

// ── CF Queues dispatch producer (Decision 24 — REST API, F-D23 PASS) ──
// On submit the web tier HTTP-pushes a pointer {tenant,job_id} to the
// Cloudflare Queue; the worker pool is the pull+ack consumer. Endpoint
// measured-validated by F-D23. Pure curl-shell carrier (same model as
// r2_request) — no Worker sidecar (Decision 24). Creds from env
// (run-phanes.sh ← secret cloudflare.queues.*): PHANES_Q_ACCOUNT_ID,
// PHANES_Q_ID, PHANES_Q_TOKEN. Absent ⇒ q_enabled()=false ⇒ submit
// skips the push and the job still runs via the local detached spawn
// (degrade preserves today's behavior; the Queue is the 2-tier path).
fn q_enabled() {
    return len(env("PHANES_Q_ACCOUNT_ID")) > 0
        && len(env("PHANES_Q_ID")) > 0
        && len(env("PHANES_Q_TOKEN")) > 0
}

// q_send — POST {"body":{"tenant","job_id"}} to the queue. Returns a
// dict {ok:bool, status:int, error:str}. Best-effort: a failed push is
// reported, not fatal (the local detached spawn is the fallback path
// until the worker tier is the sole consumer).
fn q_send(tenant, job_id) {
    let mut result = #{}
    result["ok"]     = false
    result["status"] = 0
    result["error"]  = ""
    if !q_enabled() { result["error"] = "queue disabled (PHANES_Q_* unset)"; return result }
    let acct = env("PHANES_Q_ACCOUNT_ID")
    let qid  = env("PHANES_Q_ID")
    let tok  = env("PHANES_Q_TOKEN")
    let url  = "https://api.cloudflare.com/client/v4/accounts/" + acct
        + "/queues/" + qid + "/messages"
    // pointer-only payload (Decision 23) — far under the 128 KB CF cap.
    let payload = "{\"body\":{\"tenant\":" + json_stringify(tenant)
        + ",\"job_id\":" + json_stringify(job_id) + "}}"
    let cmd = "curl -sS -X POST --max-time 15"
        + " -H " + shquote("Authorization: Bearer " + tok)
        + " -H " + shquote("Content-Type: application/json")
        + " --data " + shquote(payload)
        + " -w " + shquote("\n%{http_code}")
        + " " + shquote(url)
    let rr = exec_with_status(cmd)
    let out = rr[0]
    if rr[1] != 0 { result["error"] = "curl failed rc=" + to_string(rr[1]); return result }
    let lines = out.split("\n")
    let n = len(lines)
    if n < 1 { result["error"] = "empty response"; return result }
    let status_str = lines[n - 1].trim()
    result["status"] = to_int(status_str)
    if result["status"] == 200 { result["ok"] = true }
    if !result["ok"] { result["error"] = "queue HTTP " + status_str }
    return result
}

// rate_limit_ok(key, max_hits, window_sec) — records this hit and
// returns true if the caller is within the limit, false if over it.
fn rate_limit_ok(key, max_hits, window_sec) {
    let safe = key.replace("/", "_").replace(":", "_").replace(" ", "_").replace(".", "_")
    let p = _ratelimit_dir() + "/" + safe
    let now = _now_epoch()
    let mut win_start = now
    let mut count = 0
    if file_exists(p) {
        let raw = read_file(p).trim()
        let parts = raw.split(" ")
        if len(parts) == 2 {
            let ws = to_int(parts[0])
            let c  = to_int(parts[1])
            if now < ws + window_sec {
                win_start = ws
                count = c
            }
            // else: window expired — fall through to a fresh window
        }
    }
    count = count + 1
    write_file(p, to_string(win_start) + " " + to_string(count))
    if count > max_hits { return false }
    return true
}

fn _new_session_id() {
    let r = exec_with_status("head -c 16 /dev/urandom | od -An -tx1 | tr -d ' \\n'")
    return r[0].trim()
}

// ── KV store seam (Decision 21 — R2 is the datastore) ────────────
// When R2 is configured the store is Cloudflare R2 objects (stateless
// EC2 host, horizontally restartable — the architectural intent of
// Decision 21). When R2 creds are absent it degrades to the .store/
// filesystem so local dev, the no-creds smoke, and the public-demo
// path keep working. The seam keeps the routing in one place; the
// session/tenant/job verbs call _kv_*, never the backend directly.
fn _r2_enabled() {
    return len(env("R2_ACCESS_KEY_ID")) > 0
        && len(env("R2_SECRET_ACCESS_KEY")) > 0
        && len(env("R2_ACCOUNT_ID")) > 0
}

fn _kv_put(key, body) {
    if _r2_enabled() {
        let r = r2_put(key, body)
        return r["ok"]
    }
    let p = _store_root() + "/" + key
    // hexa's mkdir(path) is POSIX single-level (codegen_c2 → mkdir(p,0755));
    // the key may nest (sessions/<sid>), and PHANES_HOME/service/.store
    // need not pre-exist — so create the full parent chain with mkdir -p
    // (deployment-glue shellout, same model as the ls -t / date calls).
    let slash = p.last_index_of("/")
    if slash > 0 {
        exec_with_status("mkdir -p " + shquote(p.substring(0, slash)))
    }
    write_file(p, body)
    return true
}

// _kv_get -> the stored string, or nil when the key is absent.
fn _kv_get(key) {
    if _r2_enabled() {
        let r = r2_get(key)
        if !r["ok"] { return nil }
        return r["body"]
    }
    let p = _store_root() + "/" + key
    if !file_exists(p) { return nil }
    return read_file(p)
}

fn _kv_del(key) {
    if _r2_enabled() {
        r2_delete(key)
        return
    }
    let p = _store_root() + "/" + key
    if file_exists(p) { delete_file(p) }
}

fn session_create(tenant, token) {
    let sid = _new_session_id()
    _kv_put("sessions/" + sid, tenant + "\n" + token + "\n")
    return sid
}

fn session_load(sid) {
    if len(sid) == 0 { return nil }
    let raw = _kv_get("sessions/" + sid)
    if raw == nil { return nil }
    let lines = raw.split("\n")
    if len(lines) < 2 { return nil }
    let r = #{}
    r["tenant"] = lines[0]
    r["token"]  = lines[1]
    return r
}

fn session_destroy(sid) {
    if len(sid) == 0 { return }
    _kv_del("sessions/" + sid)
}

fn cookie_get(request, name) {
    let cookie = header_get(request, "cookie")
    if len(cookie) == 0 { return "" }
    let pairs = cookie.split(";")
    let mut i = 0
    while i < len(pairs) {
        let p = pairs[i].trim()
        let eq = p.index_of("=")
        if eq > 0 {
            let k = p.substring(0, eq)
            if k == name {
                return p.substring(eq + 1, len(p))
            }
        }
        i = i + 1
    }
    return ""
}

fn cookie_set_str(name, value, max_age_s) {
    return name + "=" + value + "; HttpOnly; Path=/; SameSite=Lax; Max-Age=" + to_string(max_age_s)
}

fn cookie_clear_str(name) {
    return name + "=; HttpOnly; Path=/; Max-Age=0"
}

fn current_session(request) {
    return session_load(cookie_get(request, "phanes_session"))
}

fn redirect_resp(location) {
    let resp = #{}
    resp["status"] = 303
    resp["content_type"] = "text/html; charset=utf-8"
    let h = #{}
    h["Location"] = location
    resp["headers"] = h
    resp["body"] = "<a href=\"" + html_escape(location) + "\">→</a>"
    return resp
}

fn redirect_with_cookie(location, cookie_header) {
    let resp = #{}
    resp["status"] = 303
    resp["content_type"] = "text/html; charset=utf-8"
    let h = #{}
    h["Location"] = location
    h["Set-Cookie"] = cookie_header
    resp["headers"] = h
    resp["body"] = "<a href=\"" + html_escape(location) + "\">→</a>"
    return resp
}

// list tenant's jobs (newest first, capped). Returns array of job ids.
fn list_tenant_jobs(tenant, limit) {
    let dir = _store_root() + "/tenants/" + tenant + "/jobs"
    let cmd = "ls -t " + shquote(dir) + " 2>/dev/null | head -" + to_string(limit)
    let r = exec_with_status(cmd)
    if r[1] != 0 { return [] }
    let raw = r[0].trim()
    if len(raw) == 0 { return [] }
    return raw.split("\n")
}

// ── HTML fragment helpers ────────────────────────────────────────

fn _html_resp(status, content_type, body) {
    let resp = #{}
    resp["status"] = status
    resp["content_type"] = content_type
    // no-store kills both the regular cache and Chrome's bfcache, so a
    // history navigation (e.g. back to /?lang=ko after visiting the
    // dashboard) cannot serve a stale page with old HTMX polling triggers
    // that would loop on the landing.
    let h = #{}
    h["Cache-Control"] = "no-store, must-revalidate"
    resp["headers"] = h
    resp["body"] = body
    return resp
}

fn _html_ok(body)    { return _html_resp(200, "text/html; charset=utf-8", body) }
fn _html_400(body)   { return _html_resp(400, "text/html; charset=utf-8", body) }
fn _html_401(body)   { return _html_resp(401, "text/html; charset=utf-8", body) }
fn _html_429(body)   { return _html_resp(429, "text/html; charset=utf-8", body) }
fn _html_500(body)   { return _html_resp(500, "text/html; charset=utf-8", body) }

// Render one <li> job row. If status ∈ {done, failed} no hx-trigger
// (polling stops). Otherwise hx-trigger self-polls every 2s; auth comes
// from the session cookie so the URL stays clean.
fn render_job_row(job_id, status, wall_ms, rounds, total, verifier_rc) {
    let id_attr = "job-" + job_id
    let mut row = "<li id=\"" + id_attr + "\""
    if status == "queued" || status == "running" {
        row = row
            + " hx-get=\"/dashboard/jobs/" + job_id + "\""
            + " hx-trigger=\"load delay:2s\""
            + " hx-swap=\"outerHTML\""
    }
    row = row + ">"
    row = row + "<code>" + html_escape(job_id) + "</code> · "
    row = row + "status=<b>" + html_escape(status) + "</b> · "
    row = row + "wall_ms=" + wall_ms + " · "
    row = row + "rounds=" + rounds + " · "
    row = row + "total=" + total
    if verifier_rc != "" && verifier_rc != "null" {
        row = row + " · verifier_rc=" + verifier_rc
    }
    row = row + "</li>"
    return row
}

// Render a single existing job's <li> from its job.json (used on
// dashboard page-load to pre-populate the jobs list). Returns "" on
// any failure so a single bad job doesn't break the whole page.
fn render_existing_job_row(tenant, token, job_id) {
    let cmd = jobctl_cmd() + " get --tenant " + shquote(tenant)
        + " --token " + shquote(token) + " --job " + shquote(job_id)
    let r = exec_with_status(cmd)
    if r[1] != 0 { return "" }
    let m = json_parse(r[0])
    if m == nil { return "" }
    let mut status = "?"
    if m["status"] != nil { status = to_string(m["status"]) }
    let mut wall_ms = "-"
    if m["wall_ms"] != nil { wall_ms = to_string(m["wall_ms"]) }
    let mut rounds = "-"
    if m["rounds"] != nil { rounds = to_string(m["rounds"]) }
    let mut total = "-"
    let res = m["result"]
    if res != nil {
        if res["total"] != nil { total = to_string(res["total"]) }
    }
    let mut verifier_rc = ""
    if m["verifier_rc"] != nil { verifier_rc = to_string(m["verifier_rc"]) }
    return render_job_row(job_id, status, wall_ms, rounds, total, verifier_rc)
}

// ── i18n (5 langs: en · zh · ru · ja · ko) ───────────────────────
// Marketing pages only. Login/dashboard stay EN for v1.
// Query param ?lang=<code> selects. Default = en.

fn _valid_lang(code) {
    if code == "en" || code == "zh" || code == "ru" || code == "ja" || code == "ko" {
        return true
    }
    return false
}

fn _detect_lang(request) {
    // Priority: 1) explicit ?lang= query  2) phanes_lang cookie (user
    // selection sticks)  3) Accept-Language header (browser preference)
    // 4) default "en".
    let query = request["query"]
    if query != nil {
        if len(to_string(query)) > 0 {
            let q = parse_query(to_string(query))
            let l = q["lang"]
            if l != nil {
                let ls = to_string(l)
                if _valid_lang(ls) { return ls }
            }
        }
    }
    let c = cookie_get(request, "phanes_lang")
    if _valid_lang(c) { return c }
    // Accept-Language: "ko-KR,ko;q=0.9,en;q=0.8" — take first supported
    // primary tag (first 2 chars, lowercased).
    let al = header_get(request, "accept-language")
    if len(al) > 0 {
        let parts = al.split(",")
        let mut i = 0
        while i < len(parts) {
            let mut p = parts[i].trim()
            let semi = p.index_of(";")
            if semi > 0 { p = p.substring(0, semi) }
            if len(p) >= 2 {
                let head = p.substring(0, 2).to_lower()
                if _valid_lang(head) { return head }
            }
            i = i + 1
        }
    }
    return "en"
}

fn _t(key, lang) {
    // Brand names stay Latin (PHANES / DEMIURGE) in all langs — only
    // the phonetic transliteration as a small subtitle changes per
    // language. en = blank subtitle (the latin form IS english).
    // Per user directive 2026-05-19: "이름은 그대로 발음그대로", "번역말고"
    // — descriptions/roles NOT translated; only phonetic + UI strings.
    if key == "phanes_role" {
        if lang == "ko" { return "발견" }
        if lang == "ja" { return "発見" }
        if lang == "zh" { return "发现" }
        if lang == "ru" { return "открытие" }
        return "discovery"
    }
    if key == "demiurge_role" {
        if lang == "ko" { return "설계" }
        if lang == "ja" { return "設計" }
        if lang == "zh" { return "设计" }
        if lang == "ru" { return "проектирование" }
        return "design"
    }
    if key == "phanes_phonetic" {
        if lang == "ko" { return "파네스" }
        if lang == "ja" { return "ファネス" }
        if lang == "zh" { return "法尼斯" }
        if lang == "ru" { return "Фанес" }
        return ""
    }
    if key == "demiurge_phonetic" {
        if lang == "ko" { return "데미우르지" }
        if lang == "ja" { return "デミウルゴス" }
        if lang == "zh" { return "德米乌尔格" }
        if lang == "ru" { return "Демиург" }
        return ""
    }
    // CTAs
    if key == "enter" {
        if lang == "ko" { return "진입" }
        if lang == "ja" { return "進む" }
        if lang == "zh" { return "进入" }
        if lang == "ru" { return "войти" }
        return "enter"
    }
    if key == "read_more" {
        if lang == "ko" { return "더보기" }
        if lang == "ja" { return "詳細" }
        if lang == "zh" { return "了解更多" }
        if lang == "ru" { return "подробнее" }
        return "read more"
    }
    if key == "log_in" {
        if lang == "ko" { return "로그인" }
        if lang == "ja" { return "ログイン" }
        if lang == "zh" { return "登录" }
        if lang == "ru" { return "вход" }
        return "log in"
    }
    if key == "back" {
        if lang == "ko" { return "← 돌아가기" }
        if lang == "ja" { return "← 戻る" }
        if lang == "zh" { return "← 返回" }
        if lang == "ru" { return "← назад" }
        return "← back"
    }
    return key
}

fn _lang_path(current_path, lang) {
    return current_path + "?lang=" + lang
}

// Inline 5-language string picker. Marketing prose is translated; code
// identifiers and technical terms (OUROBOROS, hexa kick, falsifier,
// saturation, verifier, Phanes, Demiurge, Stripe, GitHub, …) stay in
// their original Latin form inside every translation.
fn _tr(lang, en, ko, ja, zh, ru) {
    if lang == "ko" { return ko }
    if lang == "ja" { return ja }
    if lang == "zh" { return zh }
    if lang == "ru" { return ru }
    return en
}

// ── Reusable CTA component ───────────────────────────────────────
// One funnel for every link/button-shaped action. `variant` selects
// the .btn modifier; href starting with "http" auto-gets external
// safety attrs. Specialized helper `render_github_cta(repo, label)`
// composes the github.com URL from a dancinlab/<repo> path.

fn render_cta(href, label, variant) {
    // Unified outline style site-wide: white border, transparent interior.
    // Filled `btn-cta` / `btn-primary` modifiers are intentionally retired —
    // every button on every page now resolves to the base `.btn` look, with
    // size as the only modifier. Variant names stay (legacy call sites) but
    // map to size only.
    let mut classes = "btn"
    if variant == "primary-lg" || variant == "outline-lg" || variant == "ghost-lg" {
        classes = classes + " btn-lg"
    } else if variant == "sm" {
        classes = classes + " btn-sm"
    }
    // ("primary" / "outline" / "ghost" / "" → base .btn, no size modifier)
    let mut ext = ""
    if len(href) >= 4 {
        if href.substring(0, 4) == "http" {
            ext = " target=\"_blank\" rel=\"noopener\""
        }
    }
    return "<a class=\"" + classes + "\" href=\"" + href + "\"" + ext + ">" + label + "</a>"
}

fn render_github_cta(repo_path, label) {
    // repo_path like "dancinlab/demiurge"
    return render_cta("https://github.com/" + repo_path, label, "outline-lg")
}

// Nav-scoped CTA (e.g. the LOG IN button on the top bar).
// Uses the .topnav .right .cta CSS (different size from page-level .btn).
fn render_nav_cta(label, href) {
    return "<div class=\"right\"><a class=\"cta\" href=\"" + href + "\">" + label + "</a></div>"
}

// Single-button language switcher (HTML <details> dropdown — no JS).
// Shows full lang name + all 5 in menu with ✓ on current.
fn render_lang_switcher(lang, current_path) {
    let mut cur_label = "English"
    if lang == "zh" { cur_label = "中文" }
    if lang == "ru" { cur_label = "Русский" }
    if lang == "ja" { cur_label = "日本語" }
    if lang == "ko" { cur_label = "한국어" }
    let mut s = "<details class=\"langsw\"><summary>" + cur_label + " ▾</summary>"
    s = s + "<div class=\"langmenu\">"
    let codes = ["en", "zh", "ru", "ja", "ko"]
    let names = ["English", "中文", "Русский", "日本語", "한국어"]
    let mut i = 0
    while i < len(codes) {
        let mut cl = ""
        if codes[i] == lang { cl = " class=\"current\"" }
        s = s + "<a href=\"/lang/" + codes[i] + "?from=" + current_path + "\"" + cl + ">"
        s = s + "<span>" + names[i] + "</span>"
        if codes[i] == lang { s = s + "<span class=\"chk\">✓</span>" }
        s = s + "</a>"
        i = i + 1
    }
    s = s + "</div></details>"
    return s
}

// ── Shared marketing chrome (Decision-IA 나: unified brand) ──────
// Used by the three public marketing pages: /, /phanes, /demiurge.
// Authenticated pages (/login, /dashboard) keep their own product
// chrome (standard marketing/product split, like Stripe).
fn render_nav(current, lang, current_path) {
    let mut cco = ""
    let mut cph = ""
    let mut cde = ""
    let mut chx = ""
    let mut can = ""
    let mut cdm = ""
    let mut cpr = ""
    let mut cct = ""
    if current == "cosmogony" { cco = " class=\"current\"" }
    if current == "phanes"    { cph = " class=\"current\"" }
    if current == "demiurge"  { cde = " class=\"current\"" }
    if current == "hexa-lang" { chx = " class=\"current\"" }
    if current == "anima"     { can = " class=\"current\"" }
    if current == "demo"      { cdm = " class=\"current\"" }
    if current == "pricing"   { cpr = " class=\"current\"" }
    if current == "contact"   { cct = " class=\"current\"" }
    let mut n = "<nav class=\"topnav\">"
    n = n + "<a class=\"brand\" href=\"/?lang=" + lang + "\"" + cco + ">dancinlab</a>"
    // Responsive nav via the checkbox hack (no JS): a hidden checkbox +
    // a ☰ <label> toggle + the plain .links div. Desktop CSS hides the
    // checkbox/label and shows .links inline; mobile CSS shows the ☰ and
    // reveals .links as a dropdown panel via `.nav-cb:checked ~ .links`.
    // (A <details> is the wrong tool here — modern browsers hide a
    // closed <details>'s content with content-visibility, which an
    // author display rule cannot override, so the links vanished on
    // desktop. The checkbox sibling-combinator is robust everywhere.)
    n = n + "<input type=\"checkbox\" id=\"nav-toggle\" class=\"nav-cb\">"
    n = n + "<label for=\"nav-toggle\" class=\"nav-burger\" aria-label=\"menu\">☰</label>"
    n = n + "<div class=\"links\">"
    n = n + "<a href=\"/phanes?lang=" + lang + "\"" + cph + ">Phanes</a>"
    n = n + "<a href=\"/demiurge?lang=" + lang + "\"" + cde + ">Demiurge</a>"
    n = n + "<a href=\"/hexa-lang?lang=" + lang + "\"" + chx + ">hexa-lang</a>"
    n = n + "<a href=\"/anima?lang=" + lang + "\"" + can + ">Anima</a>"
    n = n + "<a href=\"/demo?lang=" + lang + "\"" + cdm + ">" + _tr(lang, "Demo", "데모", "デモ", "演示", "Демо") + "</a>"
    n = n + "<a href=\"/pricing?lang=" + lang + "\"" + cpr + ">" + _tr(lang, "Pricing", "요금", "料金", "定价", "Цены") + "</a>"
    n = n + "<a href=\"/contact?lang=" + lang + "\"" + cct + ">" + _tr(lang, "Contact", "문의", "お問い合わせ", "联系", "Контакты") + "</a>"
    n = n + "</div>"
    // Reusable components: lang switcher + nav CTA
    n = n + render_lang_switcher(lang, current_path)
    n = n + render_nav_cta(_t("log_in", lang), "/login")
    n = n + "</nav>"
    return n
}

// ── Design tokens (single source of truth, no hardcoded values) ──
// All colors, type sizes, spacing, radii, transitions live in :root.
// Pages reference via `var(--<name>)`. Change a brand value in ONE
// place → propagates site-wide. Modeled after Palantir Titanium's
// own CSS-variable system (their bundle uses --body-100-size /
// --text-color / etc.).
fn _tokens_css() {
    let mut c = ":root{"
    // colors (Palantir Titanium palette)
    c = c + "--bg:#1e2124;"
    c = c + "--bg-elev:#2f3234;"
    c = c + "--bg-deep:#1c212b;"
    c = c + "--fg:#fff;"
    c = c + "--fg-muted:#b9b9b9;"
    c = c + "--fg-dim:#767676;"
    c = c + "--fg-faint:#494a4b;"
    c = c + "--line:rgba(255,255,255,0.07);"
    c = c + "--line-strong:rgba(255,255,255,0.2);"
    c = c + "--line-bold:rgba(255,255,255,0.85);"
    c = c + "--accent-red:#ff4136;"
    c = c + "--accent-green:#2b5945;"
    c = c + "--accent-blue:#4e8af7;"
    c = c + "--hover-bg:rgba(255,255,255,0.06);"
    c = c + "--hover-bg-soft:rgba(255,255,255,0.04);"
    // type stacks
    c = c + "--font-sans:\"Alliance No.1\",system-ui,-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,\"Helvetica Neue\",Helvetica,Arial,\"Apple SD Gothic Neo\",\"Noto Sans CJK\",sans-serif;"
    c = c + "--font-mono:\"JetBrains Mono\",\"IBM Plex Mono\",ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;"
    // sizes (body-100/300/400 + hero/label/tiny ladder)
    c = c + "--fs-tiny:10px;--fs-label:11px;--fs-200:12px;--fs-100:14px;--fs-300:16px;--fs-400:20px;--fs-500:24px;"
    c = c + "--fs-headline:clamp(36px,7vw,80px);--fs-hero:clamp(56px,13vw,176px);"
    // Palantir-aligned (body 16px, nav 15-20px, NOT 11-12px micro-text)
    c = c + "--fs-body:16px;--fs-nav-brand:24px;--fs-nav-link:17px;--fs-nav-cta:14px;"
    // weights (Palantir uses 400/500/600/700 ladder; 600 is CTA signature)
    c = c + "--fw-regular:400;--fw-medium:500;--fw-semibold:600;--fw-bold:700;"
    // letter-spacing — Palantir spec extracted (their submit btn uses 0.04em,
    // form-label 0.08em, tag 0.1em; bigger heads use negative -0.5px)
    c = c + "--ls-headline:-0.5px;--ls-tight:-0.04em;--ls-near:-0.015em;--ls-normal:0;"
    c = c + "--ls-btn:0.04em;--ls-label:0.08em;--ls-tag:0.1em;"
    c = c + "--ls-wide:0.12em;--ls-x:0.18em;--ls-xx:0.24em;--ls-xxx:0.32em;--ls-xxxx:0.4em;"
    // line-height
    c = c + "--lh-tight:1;--lh-snug:1.1;--lh-base:1.55;"
    // spacing scale
    c = c + "--sp-1:4px;--sp-2:8px;--sp-3:14px;--sp-4:24px;--sp-5:40px;--sp-6:60px;--sp-7:80px;"
    // radii (Palantir uses 0; 4px small; 10px cards)
    c = c + "--r-0:0;--r-1:4px;--r-2:10px;"
    // transitions — Palantir spec uses 0.25s ease-in-out on nav/menu;
    // page-level .btn explicitly overrides to `transition:none` for
    // instant feedback (per user direction).
    c = c + "--t-fast:opacity 0.25s ease-in-out;--t-base:0.25s ease-in-out;--t-menu:all 0.25s ease-in-out;"
    // layout (nav-h grows with bigger brand)
    c = c + "--nav-h:84px;--container:1240px;"
    c = c + "}"
    return c
}

fn _shared_css() {
    let mut c = _tokens_css()
    // ── base reset + body ────────────────────────────────────────
    c = c + "*{box-sizing:border-box;margin:0;padding:0}"
    c = c + "html,body{background:var(--bg);color:var(--fg);min-height:100%;font-family:var(--font-sans);font-weight:var(--fw-regular);font-size:var(--fs-body);line-height:var(--lh-base);-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}"
    c = c + "a{color:inherit;text-decoration:none}"
    c = c + "code,.mono{font-family:var(--font-mono)}"
    // ── topnav ───────────────────────────────────────────────────
    c = c + ".topnav{position:fixed;top:0;left:0;right:0;height:var(--nav-h);display:flex;align-items:center;padding:0 36px;background:rgba(30,33,36,0.95);backdrop-filter:saturate(140%) blur(8px);z-index:100}"
    c = c + ".topnav .brand{font-size:var(--fs-nav-brand);letter-spacing:0;font-weight:var(--fw-medium);opacity:0.95;line-height:var(--lh-tight);display:inline-flex;align-items:center}"
    c = c + ".topnav .brand.current{opacity:1}"
    // nav links — checkbox-hack responsive. Desktop: the checkbox and ☰
    // label are hidden, .links is a plain always-visible inline row.
    // Mobile rules in the _sections_css @media block reveal the ☰ and
    // turn .links into a `.nav-cb:checked ~ .links` dropdown panel.
    c = c + ".topnav .nav-cb{display:none}"
    c = c + ".topnav .nav-burger{display:none}"
    c = c + ".topnav .links{margin-left:56px;display:flex;align-items:center;gap:32px}"
    c = c + ".topnav .links a{font-size:var(--fs-nav-link);letter-spacing:0;font-weight:var(--fw-regular);opacity:0.65;transition:var(--t-fast);padding:2px 0;line-height:var(--lh-tight)}"
    c = c + ".topnav .links a:hover{opacity:1}"
    c = c + ".topnav .links a.current{opacity:1;text-decoration:underline;text-underline-offset:6px;text-decoration-color:var(--line-bold)}"
    // ── lang switcher (single button + <details> dropdown) ──────
    c = c + ".topnav .langsw{margin-left:auto;position:relative;margin-right:var(--sp-3)}"
    c = c + ".topnav .langsw summary{cursor:pointer;list-style:none;display:inline-flex;align-items:center;gap:8px;padding:13px 26px;border:1px solid var(--fg);font-size:var(--fs-nav-cta);letter-spacing:0;font-weight:var(--fw-medium);line-height:var(--lh-tight);transition:none;white-space:nowrap}"
    c = c + ".topnav .langsw summary::-webkit-details-marker{display:none}"
    c = c + ".topnav .langsw summary::marker{display:none}"
    c = c + ".topnav .langsw summary:hover{background:var(--fg);color:var(--bg)}"
    c = c + ".topnav .langsw[open] summary{background:var(--fg);color:var(--bg)}"
    c = c + ".topnav .langmenu{position:absolute;top:calc(100% - 1px);right:0;background:var(--bg);border:1px solid var(--fg);display:flex;flex-direction:column;min-width:220px;z-index:200}"
    c = c + ".topnav .langmenu a{display:flex;align-items:center;justify-content:space-between;padding:13px 26px;font-size:var(--fs-nav-cta);letter-spacing:0;border-bottom:1px solid var(--fg);font-weight:var(--fw-medium);opacity:0.85;transition:none}"
    c = c + ".topnav .langmenu a:last-child{border-bottom:0}"
    c = c + ".topnav .langmenu a:hover{background:var(--fg);color:var(--bg);opacity:1}"
    c = c + ".topnav .langmenu a.current{background:var(--fg);color:var(--bg);opacity:1}"
    c = c + ".topnav .langmenu a .chk{font-size:var(--fs-label);margin-left:12px}"
    // ── topnav CTA (right side LOG IN) — same shape as .btn-sm ──
    c = c + ".topnav .right{display:flex;align-items:center}"
    c = c + ".topnav .right .cta{display:inline-flex;align-items:center;line-height:var(--lh-tight);padding:13px 26px;border:1px solid var(--fg);font-size:var(--fs-nav-cta);letter-spacing:0;font-weight:var(--fw-medium);transition:none}"
    c = c + ".topnav .right .cta:hover{background:var(--fg);color:var(--bg);border-color:var(--fg)}"
    // ── Button system (Palantir Titanium exact spec, extracted) ─
    // Master spec (from `.clickwrapForm__submit` in their bundle):
    //   font:14px/600  letter-spacing:0.04em  padding:14px 40px
    //   text-transform:uppercase  border-radius:0
    //
    // .btn         = THE button — transparent fill, 1px white border, inverts on hover
    // .btn-sm      = compact (nav-form-label spec: 12px/600 0.08em)
    // .btn-lg      = hero CTA (slightly larger pad)
    // .btn-tag     = small uppercase chip (Alliance No.2 spec, not a button)
    // Filled-CTA / filled-primary variants intentionally retired —
    // render_cta() collapses every variant to this single outline look.
    c = c + ".btn{display:inline-flex;align-items:center;justify-content:center;padding:14px 40px;font-family:inherit;font-size:var(--fs-100);font-weight:var(--fw-semibold);letter-spacing:var(--ls-btn);text-transform:uppercase;line-height:var(--lh-tight);border:1px solid var(--fg);background:transparent;color:var(--fg);cursor:pointer;transition:none;text-decoration:none;border-radius:var(--r-0);white-space:nowrap}"
    c = c + ".btn:hover{background:var(--fg);color:var(--bg)}"
    c = c + ".btn-sm{padding:10px 22px;font-size:var(--fs-200);letter-spacing:var(--ls-label)}"
    c = c + ".btn-lg{padding:16px 48px;font-size:var(--fs-100);letter-spacing:var(--ls-btn)}"
    c = c + ".btn-tag{padding:7px 5px;font-size:var(--fs-100);font-weight:var(--fw-regular);letter-spacing:var(--ls-tag);text-transform:uppercase;border:0;background:transparent;color:var(--fg-muted);font-feature-settings:\"ss04\" on}"
    // ── Heading utilities (Palantir titleContainer spec) ────────
    c = c + ".h-display{font-size:var(--fs-hero);font-weight:200;letter-spacing:var(--ls-tight);line-height:var(--lh-tight)}"
    c = c + ".h-headline{font-size:var(--fs-headline);font-weight:300;letter-spacing:var(--ls-near);line-height:var(--lh-snug)}"
    c = c + ".h-title{font-size:22px;font-weight:var(--fw-medium);letter-spacing:var(--ls-headline);line-height:1.15}"
    c = c + ".h-label{font-size:var(--fs-200);font-weight:var(--fw-semibold);letter-spacing:var(--ls-label);text-transform:uppercase;color:var(--fg-muted)}"
    return c
}

// ── Marketing section CSS (Palantir Titanium 5-section parity) ───
// Cloned structure: hero / overview / key-features / connected-grid /
// verified-closer + a link-group footer. All values via :root tokens.
fn _sections_css() {
    let mut c = ""
    // hero — full-bleed typographic, no third-party imagery
    c = c + ".hero{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:var(--nav-h) 36px var(--sp-7);text-align:center;position:relative}"
    c = c + ".hero .mark{font-size:var(--fs-hero);font-weight:200;letter-spacing:var(--ls-tight);line-height:var(--lh-tight)}"
    c = c + ".hero .ph{margin-top:18px;font-size:clamp(14px,2.2vw,22px);opacity:0.5;letter-spacing:var(--ls-x);font-weight:var(--fw-regular)}"
    c = c + ".hero .sub{margin-top:40px;font-size:var(--fs-label);letter-spacing:var(--ls-xxxx);text-transform:uppercase;opacity:0.6;max-width:720px;line-height:2}"
    c = c + ".hero .cue{position:absolute;bottom:36px;left:50%;transform:translateX(-50%);font-size:var(--fs-tiny);letter-spacing:var(--ls-xx);text-transform:uppercase;opacity:0.4}"
    // hero eyebrow tag chip (above the giant mark)
    c = c + ".hero .tag{margin-bottom:var(--sp-4);font-size:var(--fs-200);font-weight:var(--fw-semibold);letter-spacing:var(--ls-tag);text-transform:uppercase;color:var(--fg-dim);border:1px solid var(--line-strong);padding:7px 16px}"
    // hero stat strip — numeric proof points (Palantir stat-band shape)
    c = c + ".hero .stats{margin-top:var(--sp-6);display:flex;gap:0;border:1px solid var(--line)}"
    c = c + ".hero .stat{padding:var(--sp-4) var(--sp-5);border-right:1px solid var(--line);min-width:150px}"
    c = c + ".hero .stat:last-child{border-right:0}"
    c = c + ".hero .stat .sv{font-size:var(--fs-500);font-weight:200;letter-spacing:var(--ls-near);line-height:1}"
    c = c + ".hero .stat .sl{margin-top:var(--sp-2);font-size:var(--fs-tiny);letter-spacing:var(--ls-xx);text-transform:uppercase;opacity:0.55}"
    // section frame
    c = c + ".sec{border-top:1px solid var(--line);padding:var(--sp-7) 0}"
    c = c + ".sec-in{max-width:var(--container);margin:0 auto;padding:0 36px}"
    c = c + ".eyebrow{font-size:var(--fs-200);font-weight:var(--fw-semibold);letter-spacing:var(--ls-label);text-transform:uppercase;color:var(--fg-dim);margin-bottom:var(--sp-5)}"
    c = c + ".lead{font-size:var(--fs-headline);font-weight:200;letter-spacing:var(--ls-near);line-height:1.22;max-width:1040px}"
    // overview supporting paragraph (richer-content second para)
    c = c + ".ov-p2{margin-top:var(--sp-5);font-size:var(--fs-400);font-weight:var(--fw-regular);line-height:1.7;color:var(--fg-muted);max-width:900px}"
    // how-it-works — numbered process steps
    c = c + ".steps{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line);border:1px solid var(--line)}"
    c = c + ".step{background:var(--bg);padding:var(--sp-5) var(--sp-4)}"
    c = c + ".step .sn{font-size:var(--fs-headline);font-weight:200;letter-spacing:var(--ls-tight);line-height:1;opacity:0.22}"
    c = c + ".step .st{margin-top:var(--sp-3);font-size:var(--fs-300);font-weight:var(--fw-medium);letter-spacing:var(--ls-near);line-height:1.3}"
    c = c + ".step .sb{margin-top:var(--sp-2);font-size:var(--fs-200);color:var(--fg-muted);line-height:1.6}"
    // key features — stacked ↳ bullets
    c = c + ".feats{display:flex;flex-direction:column;gap:var(--sp-5);max-width:960px}"
    c = c + ".feat{position:relative;padding-left:var(--sp-5);font-size:var(--fs-400);font-weight:var(--fw-regular);line-height:1.5;color:var(--fg-muted)}"
    c = c + ".feat .arr{position:absolute;left:0;color:var(--fg);opacity:0.65}"
    c = c + ".feat .fl{color:var(--fg);font-weight:var(--fw-medium)}"
    // connected — hairline 2×2 card grid
    c = c + ".cards{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--line);border:1px solid var(--line)}"
    c = c + ".card{background:var(--bg);padding:var(--sp-6) var(--sp-5)}"
    c = c + ".card .num{font-size:var(--fs-200);font-weight:var(--fw-semibold);letter-spacing:var(--ls-label);color:var(--fg-faint)}"
    c = c + ".card .ct{margin-top:var(--sp-4);font-size:var(--fs-500);font-weight:var(--fw-medium);letter-spacing:var(--ls-near);line-height:1.2}"
    c = c + ".card .cl{margin-top:var(--sp-3);font-size:var(--fs-300);color:var(--fg);line-height:1.55}"
    c = c + ".card .cb{margin-top:var(--sp-3);font-size:var(--fs-300);color:var(--fg-muted);line-height:1.62}"
    // verified closer
    c = c + ".vf .lead{font-size:var(--fs-400);font-weight:var(--fw-regular);line-height:1.7;color:var(--fg-muted);max-width:900px}"
    c = c + ".vf-cta{margin-top:var(--sp-6);display:flex;align-items:center;gap:var(--sp-4);flex-wrap:wrap}"
    c = c + ".vf-sister{font-size:var(--fs-tiny);letter-spacing:var(--ls-xx);text-transform:uppercase;opacity:0.45}"
    c = c + ".vf-sister a{text-decoration:underline;text-underline-offset:3px;text-decoration-color:var(--line-strong)}"
    // footer — link groups
    c = c + ".site-foot{border-top:1px solid var(--line);padding:var(--sp-7) 0 var(--sp-5);margin-top:0}"
    c = c + ".foot-grid{max-width:var(--container);margin:0 auto;padding:0 36px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:var(--sp-6)}"
    c = c + ".foot-brand{font-size:var(--fs-400);font-weight:var(--fw-medium);letter-spacing:0}"
    c = c + ".foot-brand .fb-sub{margin-top:var(--sp-2);font-size:var(--fs-tiny);letter-spacing:var(--ls-x);text-transform:uppercase;opacity:0.4;font-weight:var(--fw-regular)}"
    c = c + ".foot-col{display:flex;flex-direction:column;gap:var(--sp-2)}"
    c = c + ".foot-col h4{font-size:var(--fs-200);letter-spacing:var(--ls-label);text-transform:uppercase;color:var(--fg-dim);margin-bottom:var(--sp-2);font-weight:var(--fw-semibold)}"
    c = c + ".foot-col a{font-size:var(--fs-300);opacity:0.6;transition:var(--t-fast)}"
    c = c + ".foot-col a:hover{opacity:1}"
    c = c + ".foot-legal{max-width:var(--container);margin:var(--sp-6) auto 0;padding:var(--sp-4) 36px 0;border-top:1px solid var(--line);font-size:var(--fs-tiny);letter-spacing:var(--ls-x);text-transform:uppercase;opacity:0.35}"
    // responsive collapse
    c = c + "@media (max-width:760px){.cards{grid-template-columns:1fr}.steps{grid-template-columns:1fr}.hero .stats{flex-direction:column}.hero .stat{border-right:0;border-bottom:1px solid var(--line);width:100%}.hero .stat:last-child{border-bottom:0}.sec{padding:var(--sp-6) 0}.foot-grid{flex-direction:column;gap:var(--sp-5)}.sec-in{padding:0 var(--sp-4)}.hero{padding:var(--nav-h) var(--sp-4) var(--sp-7)}.foot-grid,.foot-legal{padding-left:var(--sp-4);padding-right:var(--sp-4)}"
    // topnav collapse — the 7-link row cannot fit a phone, so the links
    // fold behind a ☰ hamburger. The bar stays a single fixed-height row
    // (brand · ☰ · lang · login); ☰ drops the links as an absolute panel.
    c = c + ".topnav{padding:0 var(--sp-4)}"
    c = c + ".topnav .nav-burger{display:inline-flex;align-items:center;margin-left:auto;padding:10px 16px;border:1px solid var(--fg);font-size:var(--fs-nav-cta);font-weight:var(--fw-medium);line-height:var(--lh-tight);cursor:pointer}"
    c = c + ".topnav .nav-burger:hover{background:var(--fg);color:var(--bg)}"
    c = c + ".topnav .nav-cb:checked ~ .nav-burger{background:var(--fg);color:var(--bg)}"
    c = c + ".topnav .links{display:none}"
    c = c + ".topnav .nav-cb:checked ~ .links{display:flex;flex-direction:column;align-items:stretch;gap:0;margin-left:0;position:absolute;top:var(--nav-h);left:0;right:0;background:var(--bg);border-bottom:1px solid var(--fg)}"
    c = c + ".topnav .nav-cb:checked ~ .links a{padding:15px var(--sp-4);border-top:1px solid var(--line);opacity:0.85}"
    c = c + ".topnav .nav-cb:checked ~ .links a.current{text-decoration:none;background:var(--hover-bg-soft);opacity:1}"
    c = c + ".topnav .langsw{margin-left:var(--sp-3)}"
    c = c + ".topnav .right .cta{padding:10px 14px}"
    c = c + ".topnav .langsw summary{padding:10px 14px}}"
    return c
}

// ── Section render helpers ───────────────────────────────────────
// One ↳ feature bullet (Palantir Key-Features pattern).
fn render_feat_bullet(lead, body) {
    return "<div class=\"feat\"><span class=\"arr\">↳</span>"
         + "<span class=\"fl\">" + lead + "</span> " + body + "</div>"
}

// One numbered card (Palantir "A Connected Operating System" pattern).
fn render_feat_card(num, title, lead, body) {
    return "<article class=\"card\">"
         + "<div class=\"num\">" + num + "</div>"
         + "<h3 class=\"ct\">" + title + "</h3>"
         + "<p class=\"cl\">↳ " + lead + "</p>"
         + "<p class=\"cb\">" + body + "</p></article>"
}

// One hero stat block — a numeric proof point.
fn render_hero_stat(value, label) {
    return "<div class=\"stat\"><div class=\"sv\">" + value + "</div>"
         + "<div class=\"sl\">" + label + "</div></div>"
}

// One How-It-Works process step (numbered).
fn render_step(num, title, body) {
    return "<div class=\"step\"><div class=\"sn\">" + num + "</div>"
         + "<div class=\"st\">" + title + "</div>"
         + "<div class=\"sb\">" + body + "</div></div>"
}

// Shared site footer — link groups + legal line (Palantir footer shape).
fn render_site_footer(lang) {
    let mut f = "<footer class=\"site-foot\">"
    f = f + "<div class=\"foot-grid\">"
    f = f + "<div class=\"foot-brand\">dancinlab"
    f = f + "<div class=\"fb-sub\">" + _tr(lang, "discovery · design · substrate · consciousness", "발견 · 설계 · 기반 · 의식", "発見 · 設計 · 基盤 · 意識", "发现 · 设计 · 底层 · 意识", "открытие · проектирование · субстрат · сознание") + "</div></div>"
    // products
    f = f + "<div class=\"foot-col\"><h4>" + _tr(lang, "products", "제품", "製品", "产品", "Продукты") + "</h4>"
    f = f + "<a href=\"/phanes?lang=" + lang + "\">Phanes</a>"
    f = f + "<a href=\"/demiurge?lang=" + lang + "\">Demiurge</a>"
    f = f + "<a href=\"/hexa-lang?lang=" + lang + "\">hexa-lang</a>"
    f = f + "<a href=\"/anima?lang=" + lang + "\">Anima</a></div>"
    // source
    f = f + "<div class=\"foot-col\"><h4>" + _tr(lang, "source", "소스", "ソース", "源码", "Исходный код") + "</h4>"
    f = f + "<a href=\"https://github.com/dancinlab/phanes\" target=\"_blank\" rel=\"noopener\">GitHub · phanes</a>"
    f = f + "<a href=\"https://github.com/dancinlab/demiurge\" target=\"_blank\" rel=\"noopener\">GitHub · demiurge</a>"
    f = f + "<a href=\"https://github.com/dancinlab/hexa-lang\" target=\"_blank\" rel=\"noopener\">GitHub · hexa-lang</a>"
    f = f + "<a href=\"https://github.com/dancinlab/anima\" target=\"_blank\" rel=\"noopener\">GitHub · anima</a></div>"
    // platform
    f = f + "<div class=\"foot-col\"><h4>" + _tr(lang, "platform", "플랫폼", "プラットフォーム", "平台", "Платформа") + "</h4>"
    f = f + "<a href=\"/demo?lang=" + lang + "\">" + _tr(lang, "demo", "데모", "デモ", "演示", "демо") + "</a>"
    f = f + "<a href=\"/pricing?lang=" + lang + "\">" + _tr(lang, "pricing", "요금", "料金", "定价", "цены") + "</a>"
    f = f + "<a href=\"/contact?lang=" + lang + "\">" + _tr(lang, "contact", "문의", "お問い合わせ", "联系", "контакты") + "</a>"
    f = f + "<a href=\"/login\">" + _t("log_in", lang) + "</a>"
    f = f + "<a href=\"/dashboard\">" + _tr(lang, "dashboard", "대시보드", "ダッシュボード", "仪表板", "панель") + "</a></div>"
    f = f + "</div>"
    f = f + "<div class=\"foot-legal\">" + _tr(lang, "© 2026 dancinlab · all rights reserved · proprietary", "© 2026 dancinlab · 모든 권리 보유 · 독점 소프트웨어", "© 2026 dancinlab · 全著作権所有 · プロプライエタリ", "© 2026 dancinlab · 保留所有权利 · 专有软件", "© 2026 dancinlab · все права защищены · проприетарное ПО") + "</div>"
    f = f + "</footer>"
    return f
}

// ── Generic 6-section product overview page ──────────────────────
// Palantir Titanium parity, enriched: hero (eyebrow tag + stat strip) →
// overview (lead + supporting para) → key features → how it works
// (numbered steps) → a connected system → a verified solution → footer.
// Driven by a config dict so every product page is one builder call.
// Section copy stays English (user directive: only UI chrome + phonetic
// translate).
fn render_product_overview_page(lang, cfg) {
    let slug = cfg["slug"]
    let mark = cfg["mark"]
    let mut h = "<!doctype html>\n<html lang=\"" + lang + "\"><head>"
    h = h + "<meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">"
    h = h + "<title>" + mark + "</title>"
    h = h + "<style>" + _shared_css() + _sections_css() + "</style></head><body>"
    h = h + render_nav(slug, lang, "/" + slug)
    // ── section 1 — hero (eyebrow tag + mark + phonetic + sub + stats) ──
    h = h + "<section class=\"hero\">"
    h = h + "<div class=\"tag\">" + cfg["hero_tag"] + "</div>"
    h = h + "<h1 class=\"mark\">" + mark + "</h1>"
    if len(cfg["phonetic"]) > 0 { h = h + "<div class=\"ph\">" + cfg["phonetic"] + "</div>" }
    h = h + "<div class=\"sub\">" + cfg["hero_sub"] + "</div>"
    h = h + "<div class=\"stats\">"
    h = h + render_hero_stat(cfg["s1v"], cfg["s1l"])
    h = h + render_hero_stat(cfg["s2v"], cfg["s2l"])
    h = h + render_hero_stat(cfg["s3v"], cfg["s3l"])
    h = h + "</div>"
    h = h + "<div class=\"cue\">↓ scroll</div>"
    h = h + "</section>"
    // ── section 2 — overview (lead + supporting paragraph) ──
    h = h + "<section class=\"sec\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + cfg["ov_eyebrow"] + "</h2>"
    h = h + "<p class=\"lead\">" + cfg["ov_lead"] + "</p>"
    h = h + "<p class=\"ov-p2\">" + cfg["ov_p2"] + "</p>"
    h = h + "</div></section>"
    // ── section 3 — key features ──
    h = h + "<section class=\"sec\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + cfg["kf_eyebrow"] + "</h2>"
    h = h + "<div class=\"feats\">"
    h = h + render_feat_bullet(cfg["f1l"], cfg["f1b"])
    h = h + render_feat_bullet(cfg["f2l"], cfg["f2b"])
    h = h + render_feat_bullet(cfg["f3l"], cfg["f3b"])
    h = h + "</div></div></section>"
    // ── section 4 — how it works (numbered process steps) ──
    h = h + "<section class=\"sec\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + cfg["hw_eyebrow"] + "</h2>"
    h = h + "<div class=\"steps\">"
    h = h + render_step("01", cfg["w1t"], cfg["w1b"])
    h = h + render_step("02", cfg["w2t"], cfg["w2b"])
    h = h + render_step("03", cfg["w3t"], cfg["w3b"])
    h = h + render_step("04", cfg["w4t"], cfg["w4b"])
    h = h + "</div></div></section>"
    // ── section 5 — a connected system ──
    h = h + "<section class=\"sec\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + cfg["cn_eyebrow"] + "</h2>"
    h = h + "<div class=\"cards\">"
    h = h + render_feat_card("01", cfg["c1t"], cfg["c1l"], cfg["c1b"])
    h = h + render_feat_card("02", cfg["c2t"], cfg["c2l"], cfg["c2b"])
    h = h + render_feat_card("03", cfg["c3t"], cfg["c3l"], cfg["c3b"])
    h = h + render_feat_card("04", cfg["c4t"], cfg["c4l"], cfg["c4b"])
    h = h + "</div></div></section>"
    // ── section 6 — a verified solution ──
    h = h + "<section class=\"sec vf\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + cfg["vf_eyebrow"] + "</h2>"
    h = h + "<p class=\"lead\">" + cfg["vf_body"] + "</p>"
    h = h + "<div class=\"vf-cta\">" + cfg["cta_html"]
    if len(cfg["sister_label"]) > 0 {
        h = h + "<span class=\"vf-sister\">" + _tr(lang, "sibling — ", "자매 프로젝트 — ", "姉妹プロジェクト — ", "姊妹项目 — ", "родственный проект — ") + "<a href=\"" + cfg["sister_href"] + "\">" + cfg["sister_label"] + "</a></span>"
    }
    h = h + "</div></div></section>"
    h = h + render_site_footer(lang)
    h = h + "</body></html>"
    return h
}

// One clickable product card for the cosmogony directory grid.
fn render_cosmo_card(slug, mark, phonetic, role, tagline, cta_label, lang) {
    let href = "/" + slug + "?lang=" + lang
    let mut r = "<a class=\"dcard\" href=\"" + href + "\">"
    r = r + "<div class=\"dc-role\">" + role + "</div>"
    r = r + "<div class=\"dc-mark\">" + mark + "</div>"
    if len(phonetic) > 0 { r = r + "<div class=\"dc-ph\">" + phonetic + "</div>" }
    r = r + "<div class=\"dc-tag\">" + tagline + "</div>"
    r = r + "<div class=\"dc-cta\">" + cta_label + " →</div>"
    r = r + "</a>"
    return r
}

// ── Cosmogony landing (/) — 5-section Palantir-overview shape ─────
// hero → a continuous cosmology → product directory → the dependency
// stack → honest by construction + footer.
fn render_cosmogony_landing(lang) {
    let mut h = "<!doctype html>\n<html lang=\"" + lang + "\"><head>"
    h = h + "<meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">"
    h = h + "<title>DANCINLAB</title>"
    h = h + "<style>" + _shared_css() + _sections_css()
    // cosmogony-only: clickable product directory grid
    h = h + ".dir{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--line);border:1px solid var(--line)}"
    h = h + ".dcard{display:block;background:var(--bg);padding:var(--sp-6) var(--sp-5);transition:none}"
    h = h + ".dcard:hover{background:var(--hover-bg-soft)}"
    h = h + ".dc-role{font-size:var(--fs-200);font-weight:var(--fw-semibold);letter-spacing:var(--ls-label);text-transform:uppercase;color:var(--fg-faint)}"
    h = h + ".dc-mark{margin-top:var(--sp-3);font-size:clamp(34px,5vw,60px);font-weight:200;letter-spacing:var(--ls-tight);line-height:var(--lh-tight)}"
    h = h + ".dc-ph{margin-top:8px;font-size:var(--fs-300);opacity:0.5;letter-spacing:var(--ls-x)}"
    h = h + ".dc-tag{margin-top:var(--sp-4);font-size:var(--fs-label);letter-spacing:var(--ls-xx);text-transform:uppercase;opacity:0.6;line-height:1.8}"
    h = h + ".dc-cta{margin-top:var(--sp-4);font-size:var(--fs-200);font-weight:var(--fw-semibold);letter-spacing:var(--ls-label);text-transform:uppercase;opacity:0.85}"
    h = h + "@media (max-width:760px){.dir{grid-template-columns:1fr}}"
    h = h + "</style></head><body>"
