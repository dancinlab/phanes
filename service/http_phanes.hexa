fn render_hexa_lang_page(lang) {
    let c = #{}
    c["slug"] = "hexa-lang"
    c["mark"] = "HEXA-LANG"
    c["phonetic"] = ""
    c["hero_tag"] = "Native Compiler · Substrate"
    c["hero_sub"] = "A self-hosted native compiler with atlas-bound theorems"
    c["s1v"] = "8"
    c["s1l"] = "strict-lint stages"
    c["s2v"] = "38/44"
    c["s2l"] = "tier-1 corpus PASS"
    c["s3v"] = "0"
    c["s3l"] = "LLVM, by policy"
    c["ov_eyebrow"] = "A Compiler that Cites"
    c["ov_lead"] = "hexa-lang is a self-hosted native compiler. Every formula-bearing line cites an atlas theorem, every build passes eight strict-lint stages, and nothing leaves the toolchain that was not verified. It is the bottom of the dancinlab stack — wilson, echoes, anima and the hexa-* family all consume it; nothing imports back."
    c["ov_p2"] = "Most compilers trust the programmer. hexa-lang does not — it asks every formula where it came from. A line of mathematics that does not cite an atlas theorem is not a warning; it is a build failure. The compiler bootstraps itself to a bit-stable fixpoint, generates its own machine code with no LLVM in the loop, and treats provenance as a type-level invariant rather than a code-review courtesy."
    c["kf_eyebrow"] = "Key Features"
    c["f1l"] = "Atlas-Bound Theorems:"
    c["f1b"] = "Every formula must cite an atlas entry. Strict-lint stage four rejects the build if a formula line has no citation — provenance is a compile-time invariant, not a convention."
    c["f2l"] = "No LLVM, No C-Transpile:"
    c["f2b"] = "Fully self-hosted. C emission exists only as a portable artifact; the architecture is hexa-native, compiling to its own machine code."
    c["f3l"] = "n=6 Perfect-Number Primitives:"
    c["f3b"] = "The compiler is built on six primitives and six stages. The n=6 lattice is a tool used internally — never a constraint on what the language can express."
    c["hw_eyebrow"] = "How a Build Runs"
    c["w1t"] = "Parse"
    c["w1b"] = "Source enters the frontend — tokenized, parsed, and resolved into a typed syntax tree."
    c["w2t"] = "Strict-Lint"
    c["w2b"] = "Eight stages gate the build: atlas integrity, citation match, formula well-formedness, type soundness."
    c["w3t"] = "Lower"
    c["w3b"] = "The tree lowers through HIR, MIR and LIR — each level a smaller, more explicit form."
    c["w4t"] = "Native Codegen"
    c["w4b"] = "LIR emits native machine code directly. No LLVM, no transpile — the self-hosted path."
    c["cn_eyebrow"] = "A Connected Toolchain"
    c["c1t"] = "Self-Hosted Bootstrap"
    c["c1l"] = "The compiler compiles itself, bit-for-bit."
    c["c1b"] = "aprime_cc reaches a bit-stable self-host fixpoint — ap1f, ap2f, ap3f are byte-identical. The compiler reproduces its own output exactly, with no interpreter and no third-party backend in the loop."
    c["c2t"] = "Citation-Enforced Lint"
    c["c2l"] = "Eight strict-lint stages, every build."
    c["c2b"] = "Atlas integrity, citation match, formula well-formedness, type soundness — each is a gate. A build that skips a citation does not compile; honesty is enforced by the toolchain, not the reviewer."
    c["c3t"] = "HEXA-NATIVE-ONLY"
    c["c3l"] = "No LLVM, no GHC, no Rust runtime."
    c["c3b"] = "The language is responsible for its own code generation. The C path is a fallback for portability, never the architecture — the self-hosted native path is the canonical one."
    c["c4t"] = "A Downstream Ecosystem"
    c["c4l"] = "The whole stack compiles through it."
    c["c4b"] = "wilson the agent, echoes the discovery log, anima the consciousness model, and the hexa-* family — chip, bio, matter, arch — all sit downstream. hexa-lang is the substrate they share."
    c["vf_eyebrow"] = "A Verified Substrate"
    c["vf_body"] = "Tier-1 codegen-correctness is verified — 38 of 44 corpus checks pass, with the remaining six all outside the tier-1 path. The self-host fixpoint is bit-stable: ap1f, ap2f and ap3f are byte-identical. R7 phases one and two are closed; the legacy interpreter is deprecated and emits a user-facing warning. OUROBOROS cycle h36 is complete. Every claim here is measured, not asserted."
    c["cta_html"] = render_github_cta("dancinlab/hexa-lang", "GitHub")
    c["sister_label"] = ""
    c["sister_href"] = ""
    return render_product_overview_page(lang, c)
}

