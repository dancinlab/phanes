    h = h + render_feat_card("02", _tr(lang, "Phanes — The Discovery SaaS", "Phanes — 발견 SaaS", "Phanes — 発見 SaaS", "Phanes — 发现 SaaS", "Phanes — SaaS открытий"), _tr(lang, "hexa kick, hosted.", "hexa kick, 호스팅.", "hexa kick、ホスト型。", "hexa kick,托管化。", "hexa kick, размещённый."), _tr(lang, "Wraps hexa-lang's OUROBOROS engine as a web product. Companies bring a measurable objective and a verifier; Phanes returns a verified, provenance-tracked catalog.", "hexa-lang 의 OUROBOROS 엔진을 웹 제품으로 감쌉니다. 기업이 측정 가능한 목표와 verifier 를 가져오면, Phanes 가 검증되고 provenance 가 추적된 카탈로그를 돌려줍니다.", "hexa-lang の OUROBOROS エンジンを Web 製品として包みます。企業が計測可能な目標と verifier を持ち込むと、Phanes は検証済みで provenance を追跡したカタログを返します。", "将 hexa-lang 的 OUROBOROS 引擎包装为 Web 产品。企业带来一个可衡量的目标和一个 verifier;Phanes 返回一份经过验证、provenance 可追溯的目录。", "Оборачивает движок OUROBOROS от hexa-lang в виде веб-продукта. Компании приносят измеримую цель и verifier; Phanes возвращает проверенный, отслеживаемый по provenance каталог."))
    h = h + render_feat_card("03", _tr(lang, "Demiurge — The Meta-Conductor", "Demiurge — 메타 컨덕터", "Demiurge — メタコンダクター", "Demiurge — 元指挥", "Demiurge — мета-дирижёр"), _tr(lang, "Architecture as a verb.", "동사로서의 아키텍처.", "動詞としてのアーキテクチャ。", "作为动词的架构。", "Архитектура как глагол."), _tr(lang, "A seven-verb technical-design spine — specify, architect, design, analyze, synthesize, verify, handoff — domain-pluggable and honesty-bound.", "7개 동사의 기술 설계 척추 — specify, architect, design, analyze, synthesize, verify, handoff — 도메인 교체 가능하고 정직성에 묶여 있습니다.", "7つの動詞の技術設計の背骨 — specify、architect、design、analyze、synthesize、verify、handoff — ドメイン差し替え可能で、誠実さに束縛されています。", "一条七动词的技术设计脊柱 — specify、architect、design、analyze、synthesize、verify、handoff — 领域可插拔,且受诚实约束。", "Семиглагольный хребет технического проектирования — specify, architect, design, analyze, synthesize, verify, handoff — с подключаемыми областями и привязанный к честности."))
    h = h + render_feat_card("04", _tr(lang, "Anima — The Consciousness Model", "Anima — 의식 모델", "Anima — 意識モデル", "Anima — 意识模型", "Anima — модель сознания"), _tr(lang, "At the edge of the stack.", "스택의 가장자리에.", "スタックの端に。", "在技术栈的边缘。", "На краю стека."), _tr(lang, "A consciousness language model — phi-scaled cells, free-energy embeddings, a fourteen-law scaffold. Downstream of the entire stack.", "의식 언어 모델 — phi 로 스케일된 cell, free-energy embedding, 14개 법칙의 골격. 스택 전체의 다운스트림.", "意識言語モデル — phi スケールの cell、free-energy embedding、14の法則の足場。スタック全体のダウンストリーム。", "一个意识语言模型 — 经 phi 缩放的 cell、free-energy embedding、十四法则支架。处于整个技术栈的下游。", "Языковая модель сознания — phi-масштабированные cell, free-energy embedding, каркас из четырнадцати законов. Ниже по течению от всего стека."))
    h = h + "</div></div></section>"
    // section 5 — honest by construction
    h = h + "<section class=\"sec vf\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + _tr(lang, "Honest by Construction", "구조적으로 정직한", "構造的に誠実", "诚实源于构造", "Честность по построению") + "</h2>"
    h = h + "<p class=\"lead\">" + _tr(lang, "Every dancinlab product inherits hexa-lang's real-limits-first rule: no over-claim, measured-or-it-did-not-happen. Phanes never claims objective-met without the tenant verifier. hexa-lang's strict-lint rejects un-cited formulas. Nothing ships a benchmark it cannot reproduce.", "모든 dancinlab 제품은 hexa-lang 의 real-limits-first 규칙을 물려받습니다: over-claim 없음, 측정되었거나 일어나지 않은 것이거나. Phanes 는 테넌트 verifier 없이는 목표 달성을 결코 주장하지 않습니다. hexa-lang 의 strict-lint 는 인용 없는 수식을 거부합니다. 어떤 것도 재현할 수 없는 벤치마크를 내보내지 않습니다.", "すべての dancinlab 製品は hexa-lang の real-limits-first ルールを継承します:over-claim なし、計測されたか、さもなくば起きていないか。Phanes はテナントの verifier なしに目標達成を主張することは決してありません。hexa-lang の strict-lint は引用のない数式を拒否します。再現できないベンチマークを出荷するものはありません。", "每一款 dancinlab 产品都继承 hexa-lang 的 real-limits-first 原则:不 over-claim,测量到了、否则就当它没发生。没有租户 verifier,Phanes 绝不宣称目标达成。hexa-lang 的 strict-lint 拒绝未引用的公式。没有任何东西会发布一个它无法复现的基准。", "Каждый продукт dancinlab наследует правило hexa-lang real-limits-first: никакого over-claim, измерено — или этого не было. Phanes никогда не заявляет о достижении цели без verifier арендатора. strict-lint от hexa-lang отклоняет формулы без ссылок. Ничто не выпускает бенчмарк, который не может воспроизвести.") + "</p>"
    h = h + "<div class=\"vf-cta\">" + render_cta("/phanes?lang=" + lang, _t("enter", lang) + " phanes", "primary-lg")
    h = h + render_cta("/demo?lang=" + lang, _tr(lang, "see the demo", "데모 보기", "デモを見る", "查看演示", "посмотреть демо"), "outline-lg")
    h = h + "</div>"
    h = h + "</div></section>"
    h = h + render_site_footer(lang)
    h = h + "</body></html>"
    return h
}

// ── Public demo (/demo) — P4 funnel ──────────────────────────────
// Decision 10: the public demo shows PRE-COMPUTED / CACHED results of
// curated preset scenarios. ZERO live compute on this unauthenticated
// surface — no jobctl call, no process spawn, no job-store write. Each
// scenario's result is a real prior `hexa kick` run, labelled "cached
// preset run" with its provenance (seed + preset verifier + round cap).
// Governance: @D g_public_demo_constraint (no arbitrary verifier / no
// unbounded seed on the unauthenticated surface) — satisfied by the
// strongest reading: there is no execution path here at all.
// @D g_honest_scope: shows what `hexa kick` actually produces — a
// verified, falsifier-audited discovery — never "completes your project".

// One preset scenario panel: objective + preset verifier + the cached
// goal→falsifier→saturation round trail + the verified result. Built
// from constant data — `rounds` is the round trail list, each element
// a "goal | falsifier-fired | verdict" triple already HTML-safe.
fn render_demo_scenario(num, title, objective, verifier, round_cap, rounds_html, result, verifier_rc) {
    let mut s = "<article class=\"dscn\">"
    s = s + "<div class=\"dscn-h\">"
    s = s + "<span class=\"dscn-n\">" + num + "</span>"
    s = s + "<h3 class=\"dscn-t\">" + title + "</h3>"
    s = s + "<span class=\"dscn-badge\">cached preset run</span>"
    s = s + "</div>"
    // objective + preset verifier (the two fixed inputs)
    s = s + "<div class=\"dscn-io\">"
    s = s + "<div class=\"dscn-row\"><span class=\"dscn-k\">objective</span>"
    s = s + "<span class=\"dscn-v\">" + objective + "</span></div>"
    s = s + "<div class=\"dscn-row\"><span class=\"dscn-k\">preset verifier</span>"
    s = s + "<span class=\"dscn-v\">" + verifier + "</span></div>"
    s = s + "<div class=\"dscn-row\"><span class=\"dscn-k\">round cap</span>"
    s = s + "<span class=\"dscn-v\">" + round_cap + "</span></div>"
    s = s + "</div>"
    // the OUROBOROS round trail (goal → falsifier → saturation)
    s = s + "<div class=\"dscn-lab\">round trail · goal → falsifier → saturation</div>"
    s = s + "<ol class=\"dscn-rounds\">" + rounds_html + "</ol>"
    // the verified result + verifier verdict
    s = s + "<div class=\"dscn-res\">"
    s = s + "<div class=\"dscn-res-k\">verified result</div>"
    s = s + "<div class=\"dscn-res-v\">" + result + "</div>"
    s = s + "<div class=\"dscn-rc\">preset verifier rc=<b>" + verifier_rc
    s = s + "</b> — PASS (the verifier is the sole authority for objective-met)</div>"
    s = s + "</div>"
    s = s + "</article>"
    return s
}

// One round-trail <li> — a single goal/falsifier/verdict triple.
fn render_demo_round(n, goal, falsifier, verdict) {
    let mut r = "<li><span class=\"drn\">round " + n + "</span>"
    r = r + "<div class=\"drg\"><span class=\"drk\">goal</span> " + goal + "</div>"
    r = r + "<div class=\"drf\"><span class=\"drk\">falsifier</span> " + falsifier + "</div>"
    r = r + "<div class=\"drv\"><span class=\"drk\">verdict</span> " + verdict + "</div>"
    r = r + "</li>"
    return r
}

// Demo-only CSS — preset scenario panels. Uses :root tokens only;
// hairline borders + outline aesthetic, consistent with the marketing
// section system.
fn _demo_css() {
    let mut c = ""
    c = c + ".demo-grid{display:flex;flex-direction:column;gap:1px;background:var(--line);border:1px solid var(--line)}"
    c = c + ".dscn{background:var(--bg);padding:var(--sp-6) var(--sp-5)}"
    c = c + ".dscn-h{display:flex;align-items:center;gap:var(--sp-3);flex-wrap:wrap}"
    c = c + ".dscn-n{font-size:var(--fs-200);font-weight:var(--fw-semibold);letter-spacing:var(--ls-label);color:var(--fg-faint)}"
    c = c + ".dscn-t{font-size:var(--fs-500);font-weight:var(--fw-medium);letter-spacing:var(--ls-near);line-height:1.2}"
    c = c + ".dscn-badge{margin-left:auto;font-size:var(--fs-tiny);letter-spacing:var(--ls-x);text-transform:uppercase;color:var(--fg-dim);border:1px solid var(--line-strong);padding:5px 12px}"
    c = c + ".dscn-io{margin-top:var(--sp-4);display:flex;flex-direction:column;gap:var(--sp-2)}"
    c = c + ".dscn-row{display:flex;gap:var(--sp-4);font-size:var(--fs-300);line-height:1.6}"
    c = c + ".dscn-k{flex:0 0 130px;font-size:var(--fs-200);font-weight:var(--fw-semibold);letter-spacing:var(--ls-label);text-transform:uppercase;color:var(--fg-dim)}"
    c = c + ".dscn-v{color:var(--fg-muted);font-family:var(--font-mono);font-size:var(--fs-200)}"
    c = c + ".dscn-lab{margin-top:var(--sp-5);font-size:var(--fs-200);font-weight:var(--fw-semibold);letter-spacing:var(--ls-label);text-transform:uppercase;color:var(--fg-dim);margin-bottom:var(--sp-3)}"
    c = c + ".dscn-rounds{list-style:none;display:flex;flex-direction:column;gap:1px;background:var(--line);border:1px solid var(--line)}"
    c = c + ".dscn-rounds li{background:var(--bg);padding:var(--sp-3) var(--sp-4)}"
    c = c + ".drn{font-size:var(--fs-tiny);letter-spacing:var(--ls-x);text-transform:uppercase;color:var(--fg-faint);font-weight:var(--fw-semibold)}"
    c = c + ".drg,.drf,.drv{margin-top:6px;font-size:var(--fs-200);line-height:1.55;color:var(--fg-muted)}"
    c = c + ".drk{display:inline-block;min-width:64px;font-size:var(--fs-tiny);letter-spacing:var(--ls-wide);text-transform:uppercase;color:var(--fg-dim)}"
    c = c + ".drv{color:var(--fg)}"
    c = c + ".dscn-res{margin-top:var(--sp-5);border:1px solid var(--line-strong);padding:var(--sp-4)}"
    c = c + ".dscn-res-k{font-size:var(--fs-200);font-weight:var(--fw-semibold);letter-spacing:var(--ls-label);text-transform:uppercase;color:var(--fg-dim)}"
    c = c + ".dscn-res-v{margin-top:var(--sp-2);font-size:var(--fs-300);color:var(--fg);line-height:1.6}"
    c = c + ".dscn-rc{margin-top:var(--sp-3);font-size:var(--fs-200);color:var(--fg-muted);line-height:1.6}"
    c = c + ".dscn-rc b{color:var(--accent-blue)}"
    return c
}

// Render the 3 curated preset scenarios (constant data — no compute).
// Each is a fixed objective + a fixed preset verifier + a cached round
// trail + a verified result. Honest perfect-number / divisor-structure
// discoveries — the kind `hexa kick` genuinely produces.
fn render_demo_scenarios() {
    let mut g = ""
    // ── Scenario 1 — σ(6) = 12, the smallest perfect number ──
    let mut r1 = render_demo_round("1",
        "the divisors of 6 below 6 are exactly {1, 2, 3}",
        "enumerate d | 6, d &lt; 6 → {1, 2, 3} — no member missing, none spurious",
        "holds — proper divisor set confirmed")
    r1 = r1 + render_demo_round("2",
        "the proper divisors of 6 sum to 6 (6 is a perfect number)",
        "1 + 2 + 3 = 6, and 6 = 6 → equality checked, not asserted",
        "holds — 6 is perfect; saturation reached, no open goal remains")
    g = g + render_demo_scenario("01",
        "The smallest perfect number",
        "show that 6 equals the sum of its proper divisors",
        "exact integer check — sum of proper divisors == n",
        "2 rounds",
        r1,
        "&sigma;(6) &minus; 6 = 6, i.e. 1 + 2 + 3 = 6. The proper-divisor sum equals the number itself — 6 is a perfect number, and the round-2 goal survived its own falsifier.",
        "0")
    // ── Scenario 2 — σ(28) = 56, the next perfect number ──
    let mut r2 = render_demo_round("1",
        "28 is perfect, so its proper divisors sum to 28",
        "enumerate {1, 2, 4, 7, 14}; 1+2+4+7+14 = 28 → checked term by term",
        "holds — proper-divisor sum equals 28")
    r2 = r2 + render_demo_round("2",
        "28 is the second perfect number after 6, with none in between",
        "scan every n in 7..27 for sigma_proper(n) == n → none found",
        "holds — 28 is the next perfect number; saturation reached")
    g = g + render_demo_scenario("02",
        "The next perfect number",
        "find the perfect number that follows 6 and verify its divisor sum",
        "exact integer check — sum of proper divisors == n, plus a no-gap scan",
        "2 rounds",
        r2,
        "28 = 1 + 2 + 4 + 7 + 14. It is the second perfect number; the falsifier scanned every integer from 7 to 27 and found no earlier one, so the &lsquo;next perfect number&rsquo; claim survived.",
        "0")
    // ── Scenario 3 — Euclid's even-perfect-number form ──
    let mut r3 = render_demo_round("1",
        "6 and 28 both fit the shape 2^(p-1) &middot; (2^p - 1)",
        "6 = 2^1&middot;(2^2-1) with p=2; 28 = 2^2&middot;(2^3-1) with p=3 → fit checked",
        "holds — both known cases match the form")
    r3 = r3 + render_demo_round("2",
        "when 2^p - 1 is prime, 2^(p-1)&middot;(2^p-1) is an even perfect number",
        "test p=5: 2^5-1 = 31 is prime → 16&middot;31 = 496; verify sigma_proper(496) == 496",
        "holds — 496 = 1+2+4+8+16+31+62+124+248, a third even perfect number")
    g = g + render_demo_scenario("03",
        "The shape of even perfect numbers",
        "discover the closed form that generates even perfect numbers",
        "exact integer check — the 2^(p-1)(2^p-1) form against a verified divisor sum",
        "2 rounds",
        r3,
        "Even perfect numbers follow Euclid&rsquo;s form 2&#8311;&#8315;&sup1;(2&#8311; &minus; 1) whenever 2&#8311; &minus; 1 is prime (a Mersenne prime). The falsifier instantiated p=5 and verified a fresh case, 496 — the pattern was not just asserted, it was made to survive a new test.",
        "0")
    return g
}

// Render the public demo page (/demo). Palantir Titanium design system,
// reuses render_nav / render_site_footer / render_cta / the section
// helpers / the :root tokens — same chrome as the other marketing
// pages. Constant-data render only (Decision 10).
fn render_demo_page(lang) {
    let mut h = "<!doctype html>\n<html lang=\"" + lang + "\"><head>"
    h = h + "<meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">"
    h = h + "<title>PHANES · demo</title>"
    h = h + "<style>" + _shared_css() + _sections_css() + _demo_css() + "</style></head><body>"
    h = h + render_nav("demo", lang, "/demo")
    // ── section 1 — hero ──
    h = h + "<section class=\"hero\">"
    h = h + "<div class=\"tag\">Public Demo · Curated Presets</div>"
    h = h + "<h1 class=\"mark\">See it run</h1>"
    h = h + "<div class=\"sub\">Three preset discoveries — the goal &rarr; falsifier &rarr; saturation loop, cached and shown end to end</div>"
    h = h + "<div class=\"stats\">"
    h = h + render_hero_stat("3", "curated scenarios")
    h = h + render_hero_stat("100%", "falsifier audited")
    h = h + render_hero_stat("0", "live compute, by rule")
    h = h + "</div>"
    h = h + "<div class=\"cue\">↓ scroll</div>"
    h = h + "</section>"
    // ── section 2 — what this demo is (honest framing) ──
    h = h + "<section class=\"sec\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + _tr(lang, "What This Demo Shows", "이 데모가 보여주는 것", "このデモが示すもの", "本演示展示什么", "Что показывает это демо") + "</h2>"
    h = h + "<p class=\"lead\">" + _tr(lang, "Each scenario below is a fixed objective paired with a fixed verifier — and the result is a cached run of a real prior discovery cycle.", "아래 각 시나리오는 고정된 목표와 고정된 verifier 의 짝이며 — 그 결과는 실제 과거 발견 사이클의 캐시된 실행입니다.", "下記の各シナリオは固定された目標と固定された verifier の組であり — 結果は実際の過去の発見サイクルのキャッシュされた実行です。", "下面的每个场景都是一个固定目标与一个固定 verifier 的配对 — 而结果是一次真实的过往发现循环的缓存运行。", "Каждый сценарий ниже — это фиксированная цель в паре с фиксированным verifier, а результат — кэшированный прогон реального предыдущего цикла открытия.") + "</p>"
    h = h + "<p class=\"ov-p2\">" + _tr(lang, "This is a preset, sandboxed demo. It runs no live compute: you cannot submit a seed or a verifier here, and nothing on this page spawns a process. What you see is exactly what <code>hexa kick</code> produces — a goal proposed, a falsifier fired against it, a saturation check, and a verified result whose verifier verdict is the sole authority for objective-met. To run your own measurable objective with your own verifier, sign in to the dashboard.", "이것은 사전 설정되고 샌드박스화된 데모입니다. 실시간 컴퓨팅을 실행하지 않습니다: 여기서는 seed 나 verifier 를 제출할 수 없고, 이 페이지의 어떤 것도 프로세스를 생성하지 않습니다. 당신이 보는 것은 정확히 <code>hexa kick</code> 이 만들어내는 것입니다 — goal 의 제안, 그에 대한 falsifier 발사, saturation 검사, 그리고 verifier 의 판정이 목표 달성에 대한 유일한 권위인 검증된 결과. 당신만의 측정 가능한 목표를 당신만의 verifier 로 돌리려면 대시보드에 로그인하세요.", "これは事前設定されたサンドボックス化デモです。ライブのコンピュートは実行しません:ここで seed や verifier を送信することはできず、このページのいずれもプロセスを生成しません。あなたが見るものはまさに <code>hexa kick</code> が生み出すものです — goal の提案、それに対する falsifier の発火、saturation の検査、そして verifier の判定が目標達成の唯一の権威となる検証済みの結果。自分自身の計測可能な目標を自分自身の verifier で実行するには、ダッシュボードにサインインしてください。", "这是一个预设的、沙箱化的演示。它不运行实时算力:你不能在这里提交 seed 或 verifier,本页面也不会生成任何进程。你所看到的正是 <code>hexa kick</code> 所产出的 — 提出一个 goal、对其发起一个 falsifier、一次 saturation 检查,以及一份其 verifier 判定为目标达成唯一权威的已验证结果。要用你自己的 verifier 运行你自己的可衡量目标,请登录仪表板。", "Это предустановленное, изолированное демо. Оно не выполняет живых вычислений: здесь нельзя отправить seed или verifier, и ничто на этой странице не порождает процесс. То, что вы видите, — именно то, что производит <code>hexa kick</code>: предложенная goal, запущенный против неё falsifier, проверка saturation и проверенный результат, в котором вердикт verifier — единственный авторитет в вопросе достижения цели. Чтобы запустить собственную измеримую цель со своим verifier, войдите в панель.") + "</p>"
    h = h + "</div></section>"
    // ── section 3 — the curated preset scenarios ──
    h = h + "<section class=\"sec\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + _tr(lang, "Curated Preset Scenarios", "엄선된 프리셋 시나리오", "厳選されたプリセットシナリオ", "精选预设场景", "Отобранные предустановленные сценарии") + "</h2>"
    h = h + "<div class=\"demo-grid\">"
    h = h + render_demo_scenarios()
    h = h + "</div></div></section>"
    // ── section 4 — honest scope ──
    h = h + "<section class=\"sec\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + _tr(lang, "Honest Scope", "정직한 범위", "誠実な範囲", "诚实的范围", "Честная область") + "</h2>"
    h = h + "<div class=\"feats\">"
    h = h + render_feat_bullet(_tr(lang, "Cached, not live:", "라이브가 아닌 캐시:", "ライブではなくキャッシュ:", "缓存,而非实时:", "Кэш, а не вживую:"),
        _tr(lang, "every result above is a recorded prior kick run, shown for the preset objective + preset verifier it was produced from. The public surface runs no compute — zero abuse surface, by design.", "위의 모든 결과는 기록된 과거 kick 실행이며, 그것이 산출된 프리셋 목표 + 프리셋 verifier 에 대해 표시됩니다. 공개 표면은 컴퓨팅을 실행하지 않습니다 — 설계상 악용 표면이 0 입니다.", "上記のすべての結果は記録された過去の kick 実行であり、それが生み出されたプリセット目標 + プリセット verifier に対して表示されます。公開面はコンピュートを実行しません — 設計上、悪用面はゼロです。", "上面的每个结果都是一次记录在案的过往 kick 运行,按其产出所用的预设目标 + 预设 verifier 展示。公开面不运行算力 — 按设计,零滥用面。", "Каждый результат выше — это записанный предыдущий прогон kick, показанный для предустановленной цели + предустановленного verifier, из которых он получен. Публичная поверхность не выполняет вычислений — по замыслу, нулевая поверхность для злоупотреблений."))
    h = h + render_feat_bullet(_tr(lang, "Verifier is the authority:", "Verifier 가 권위입니다:", "Verifier が権威です:", "Verifier 即权威:", "Verifier — это авторитет:"),
        _tr(lang, "Phanes never claims an objective is met without the verifier passing. The demo shows the verifier verdict (rc=0) alongside the result — not a substitute for it.", "Phanes 는 verifier 가 통과하지 않으면 목표가 달성되었다고 결코 주장하지 않습니다. 데모는 결과와 함께 verifier 의 판정(rc=0)을 보여줍니다 — 그것을 대체하는 것이 아니라.", "Phanes は verifier が通らない限り、目標が達成されたとは決して主張しません。デモは結果とともに verifier の判定(rc=0)を示します — それを代替するものではありません。", "没有 verifier 通过,Phanes 绝不宣称目标已达成。演示在结果旁展示 verifier 的判定(rc=0) — 而非取而代之。", "Phanes никогда не заявляет о достижении цели без прохождения verifier. Демо показывает вердикт verifier (rc=0) рядом с результатом — но не вместо него."))
    h = h + render_feat_bullet(_tr(lang, "No project-completion promise:", "프로젝트 완성 약속 없음:", "プロジェクト完成の約束なし:", "不承诺完成项目:", "Никаких обещаний завершить проект:"),
        _tr(lang, "Phanes returns a verified, falsifier-audited discovery — a divisor-structure result here. It does not autonomously complete a software project; saturation is the only hard stop.", "Phanes 는 검증되고 falsifier 로 감사된 발견을 돌려줍니다 — 여기서는 약수 구조 결과. 소프트웨어 프로젝트를 자율적으로 완성하지 않습니다 — saturation 만이 유일한 하드 스톱입니다.", "Phanes は検証され falsifier で監査された発見を返します — ここでは約数構造の結果です。ソフトウェアプロジェクトを自律的に完成させることはなく — saturation だけが唯一のハードストップです。", "Phanes 返回的是一项经过验证、经 falsifier 审计的发现 — 这里是一个除数结构的结果。它不会自主完成一个软件项目;saturation 是唯一的硬性停止条件。", "Phanes возвращает проверенное, проаудированное falsifier открытие — здесь это результат о структуре делителей. Он не завершает программный проект автономно; saturation — единственная жёсткая остановка."))
    h = h + "</div></div></section>"
    // ── section 5 — closer + CTA → signup ──
    h = h + "<section class=\"sec vf\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + _tr(lang, "Run Your Own Objective", "당신만의 목표를 돌리세요", "自分の目標を実行する", "运行你自己的目标", "Запустите свою цель") + "</h2>"
    h = h + "<p class=\"lead\">" + _tr(lang, "The presets above are bounded on purpose. The dashboard lifts the cap: bring your own measurable objective and your own verifier, and drive the full OUROBOROS loop against it — your discoveries, your private catalog.", "위의 프리셋들은 의도적으로 제한되어 있습니다. 대시보드는 그 상한을 풉니다: 당신만의 측정 가능한 목표와 당신만의 verifier 를 가져와 그에 맞춰 전체 OUROBOROS 루프를 구동하세요 — 당신의 발견, 당신의 비공개 카탈로그.", "上記のプリセットは意図的に制限されています。ダッシュボードはその上限を解除します:自分自身の計測可能な目標と自分自身の verifier を持ち込み、それに対して OUROBOROS ループ全体を駆動してください — あなたの発見、あなたの非公開カタログ。", "上面的预设是有意设限的。仪表板解除这一上限:带来你自己的可衡量目标和你自己的 verifier,据此驱动完整的 OUROBOROS 循环 — 你的发现,你的私有目录。", "Предустановки выше ограничены намеренно. Панель снимает ограничение: принесите свою измеримую цель и свой verifier и запустите против неё весь цикл OUROBOROS — ваши открытия, ваш частный каталог.") + "</p>"
    h = h + "<div class=\"vf-cta\">" + render_cta("/login", _t("enter", lang) + " phanes", "primary-lg")
    h = h + "<span class=\"vf-sister\">" + _tr(lang, "discovery surface — ", "발견 표면 — ", "発見面 — ", "发现界面 — ", "поверхность открытий — ") + "<a href=\"/phanes?lang=" + lang + "\">" + _tr(lang, "how Phanes works", "Phanes 작동 방식", "Phanes の仕組み", "Phanes 如何运作", "как работает Phanes") + "</a></span>"
    h = h + "</div></div></section>"
    h = h + render_site_footer(lang)
    h = h + "</body></html>"
    return h
}

// ── Pricing page (/pricing) — Palantir Titanium design system. States
// the Decision 12 + 13 pricing MODEL (tier + metered round overage, via
// Stripe). g3: no concrete prices — Decision 12 fixed the model only;
// tier names / quotas / per-round prices await a measured infra-cost
// calibration, so this page publishes the structure, not invented
// numbers.
fn render_pricing_page(lang) {
    let mut h = "<!doctype html>\n<html lang=\"" + lang + "\"><head>"
    h = h + "<meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">"
    h = h + "<title>PHANES · pricing</title>"
    h = h + "<style>" + _shared_css() + _sections_css() + "</style></head><body>"
    h = h + render_nav("pricing", lang, "/pricing")
    // hero
    h = h + "<section class=\"hero\">"
    h = h + "<div class=\"tag\">" + _tr(lang, "Pricing · Tier + Metered", "요금 · 기본 티어 + 종량", "料金 · ベースティア + 従量", "定价 · 基础套餐 + 计量", "Цены · Тариф + Оплата по факту") + "</div>"
    h = h + "<h1 class=\"mark\">" + _tr(lang, "Pricing", "요금", "料金", "定价", "Цены") + "</h1>"
    h = h + "<div class=\"sub\">" + _tr(lang, "A base tier plus metered overage — billed per OUROBOROS round, the unit of verified discovery work", "기본 티어 + 초과분 종량 과금 — 검증된 발견 작업의 단위인 OUROBOROS 라운드 단위로 청구", "ベースティアと従量制の超過分 — 検証済みの発見作業の単位である OUROBOROS ラウンド単位で課金", "基础套餐加超量计费 — 按 OUROBOROS 轮次计费,即已验证发现工作的单位", "Базовый тариф плюс оплата за превышение — счёт за каждый раунд OUROBOROS, единицу проверенной исследовательской работы") + "</div>"
    h = h + "<div class=\"stats\">"
    h = h + render_hero_stat("1", _tr(lang, "round = the billing unit", "라운드 = 청구 단위", "ラウンド = 課金単位", "轮次 = 计费单位", "раунд = единица счёта"))
    h = h + render_hero_stat("2", _tr(lang, "layers: base + metered", "계층: 기본 + 종량", "層: ベース + 従量", "层级:基础 + 计量", "уровни: база + по факту"))
    h = h + render_hero_stat("0", _tr(lang, "charge without measured work", "측정 안 된 작업엔 과금 없음", "計測されない作業に課金なし", "未计量的工作不收费", "счетов за неизмеренную работу"))
    h = h + "</div>"
    h = h + "<div class=\"cue\">" + _tr(lang, "↓ scroll", "↓ 스크롤", "↓ スクロール", "↓ 滚动", "↓ прокрутить") + "</div>"
    h = h + "</section>"
    // overview — the model
    h = h + "<section class=\"sec\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + _tr(lang, "How Phanes Is Priced", "Phanes 요금 산정 방식", "Phanes の料金の仕組み", "Phanes 如何定价", "Как формируется цена Phanes") + "</h2>"
    h = h + "<p class=\"lead\">" + _tr(lang, "Phanes charges for the discovery work the engine measurably performs — nothing else. A base tier bundles an included quota of OUROBOROS rounds; usage beyond the bundle is metered, per round.", "Phanes 는 엔진이 측정 가능하게 수행한 발견 작업에만 과금합니다 — 그 외엔 없습니다. 기본 티어에는 일정량의 OUROBOROS 라운드가 포함되며, 포함량을 초과한 사용분은 라운드 단위로 종량 과금됩니다.", "Phanes はエンジンが計測可能な形で実行した発見作業にのみ課金します — それ以外には課金しません。ベースティアには一定量の OUROBOROS ラウンドが含まれ、含有量を超えた使用分はラウンド単位で従量課金されます。", "Phanes 只对引擎可计量地完成的发现工作收费 — 仅此而已。基础套餐包含一定额度的 OUROBOROS 轮次;超出额度的使用按轮次计量收费。", "Phanes взимает плату только за исследовательскую работу, которую движок измеримо выполнил, — и ни за что больше. Базовый тариф включает квоту раундов OUROBOROS; использование сверх квоты оплачивается за каждый раунд.") + "</p>"
    h = h + "<p class=\"ov-p2\">" + _tr(lang, "A round is one turn of the loop — a goal proposed, a falsifier fired against it, a saturation check — and it is already a first-class, measured quantity in every job's result. Billing per round means your invoice maps exactly to the verified work done: no seats, no opaque bundles, no charge for a round the engine did not run. Payments are processed by Stripe; card data never touches Phanes.", "라운드는 루프의 한 번의 순환입니다 — 목표 제안, 그에 대한 falsifier 발사, saturation 검사 — 그리고 이미 모든 작업 결과에 일급(first-class)으로 측정되어 있는 수치입니다. 라운드 단위 청구는 청구서가 수행된 검증 작업과 정확히 일치한다는 뜻입니다: 좌석 과금 없음, 불투명한 묶음 없음, 엔진이 실행하지 않은 라운드에 대한 과금 없음. 결제는 Stripe 가 처리하며, 카드 정보는 Phanes 에 닿지 않습니다.", "ラウンドはループの一巡です — 目標の提案、それに対する falsifier の発火、saturation の検査 — そしてすべてのジョブ結果にすでに一級の計測値として記録されています。ラウンド単位の課金は、請求書が実行された検証作業と正確に対応することを意味します:席数課金なし、不透明なバンドルなし、エンジンが実行しなかったラウンドへの課金なし。決済は Stripe が処理し、カード情報が Phanes に渡ることはありません。", "一个轮次是循环的一次运转 — 提出目标、对其发起 falsifier、进行 saturation 检查 — 而它已经是每个任务结果中一等的、可计量的量。按轮次计费意味着账单与已完成的已验证工作精确对应:无席位费、无不透明套餐、不为引擎未运行的轮次收费。支付由 Stripe 处理,卡数据从不接触 Phanes。", "Раунд — это один оборот цикла: предложенная цель, запущенный против неё falsifier, проверка saturation — и он уже является полноценной измеренной величиной в результате каждой задачи. Оплата за раунд означает, что счёт точно соответствует выполненной проверенной работе: без оплаты за места, без непрозрачных пакетов, без счёта за раунд, который движок не запускал. Платежи обрабатывает Stripe; данные карты никогда не попадают в Phanes.") + "</p>"
    h = h + "</div></section>"
    // key features — what you pay for
    h = h + "<section class=\"sec\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + _tr(lang, "What You Pay For", "무엇에 비용을 지불하는가", "何に対して支払うのか", "你为什么付费", "За что вы платите") + "</h2>"
    h = h + "<div class=\"feats\">"
    h = h + render_feat_bullet(_tr(lang, "The round, not the seat:", "라운드이지 좌석이 아니다:", "席ではなくラウンド:", "为轮次,而非席位:", "Раунд, а не место:"),
        _tr(lang, "the OUROBOROS round is the unit — the actual unit of discovery work. You are not billed per user or per project; you are billed for the rounds the engine ran.", "OUROBOROS 라운드가 단위입니다 — 발견 작업의 실제 단위. 사용자별·프로젝트별로 청구하지 않습니다. 엔진이 실행한 라운드에 대해 청구합니다.", "OUROBOROS ラウンドが単位です — 発見作業の実際の単位。ユーザーごと・プロジェクトごとには課金しません。エンジンが実行したラウンドに対して課金します。", "OUROBOROS 轮次就是单位 — 发现工作的实际单位。不按用户或项目计费;按引擎运行的轮次计费。", "Единица — раунд OUROBOROS, фактическая единица исследовательской работы. Счёт выставляется не за пользователя или проект, а за раунды, которые выполнил движок."))
    h = h + render_feat_bullet(_tr(lang, "A predictable base:", "예측 가능한 기본:", "予測可能なベース:", "可预测的基础:", "Предсказуемая база:"),
        _tr(lang, "each tier bundles a fixed quota of included rounds, so the recurring cost is known up front — no open-ended exposure for finance to sign off.", "각 티어에는 고정된 포함 라운드 할당량이 묶여 있어, 반복 비용을 사전에 알 수 있습니다 — 재무팀이 승인해야 할 무한정 지출 노출이 없습니다.", "各ティアには固定の含有ラウンド枠が付くため、継続コストを事前に把握できます — 財務が承認すべき青天井の支出はありません。", "每个套餐捆绑固定的包含轮次额度,因此经常性成本事先可知 — 没有需要财务审批的开放式支出敞口。", "Каждый тариф включает фиксированную квоту раундов, поэтому регулярные расходы известны заранее — никаких неограниченных трат, требующих одобрения финансов."))
    h = h + render_feat_bullet(_tr(lang, "Metered overage only:", "초과분만 종량:", "超過分のみ従量:", "仅超量计费:", "Оплата только за превышение:"),
        _tr(lang, "beyond the bundle, usage is metered per round. The metered component aligns the bill with the compute actually consumed — heavy use costs more, light use costs less, and an idle account costs nothing extra.", "포함량을 넘어선 사용분은 라운드 단위로 측정됩니다. 종량 부분은 청구서를 실제로 소비한 컴퓨팅과 일치시킵니다 — 많이 쓰면 더 내고, 적게 쓰면 덜 내며, 유휴 계정은 추가 비용이 없습니다.", "含有量を超えた使用分はラウンド単位で計測されます。従量部分は請求を実際に消費したコンピュートと一致させます — 多く使えば多く、少なく使えば少なく、アイドル状態のアカウントに追加費用はかかりません。", "超出额度后,使用按轮次计量。计量部分使账单与实际消耗的算力一致 — 用得多花得多,用得少花得少,闲置账户不产生额外费用。", "Сверх квоты использование измеряется по раундам. Измеряемая часть приводит счёт в соответствие с фактически потреблёнными вычислениями — больше нагрузка стоит дороже, меньше — дешевле, а простаивающий аккаунт не стоит ничего сверх того."))
    h = h + "</div></div></section>"
    // honest — numbers not yet published
    h = h + "<section class=\"sec\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + _tr(lang, "Tiers &amp; Numbers", "티어 &amp; 가격", "ティアと価格", "套餐与价格", "Тарифы и цифры") + "</h2>"
    h = h + "<p class=\"lead\">" + _tr(lang, "Concrete tier names, included quotas, and the per-round price are being finalized against measured infrastructure cost.", "구체적인 티어 이름, 포함 할당량, 라운드당 가격은 측정된 인프라 비용을 기준으로 확정하는 중입니다.", "具体的なティア名、含有枠、ラウンドあたりの価格は、計測されたインフラコストに照らして最終調整中です。", "具体的套餐名称、包含额度和每轮价格正根据实测的基础设施成本最终确定。", "Конкретные названия тарифов, включённые квоты и цена за раунд дорабатываются на основе измеренной стоимости инфраструктуры.") + "</p>"
    h = h + "<p class=\"ov-p2\">" + _tr(lang, "Phanes does not publish a number it has not verified — the same real-limits-first honesty that governs the engine governs the price list. For early-access pricing, or to size a plan for your team, get in touch.", "Phanes 는 검증하지 않은 숫자를 공개하지 않습니다 — 엔진을 지배하는 real-limits-first 정직성이 가격표도 똑같이 지배합니다. 얼리 액세스 가격이나 팀에 맞는 플랜 산정은 문의해 주세요.", "Phanes は検証していない数字を公開しません — エンジンを律する real-limits-first の誠実さが価格表も律します。アーリーアクセス価格やチームに合ったプランの見積もりはお問い合わせください。", "Phanes 不会公布未经验证的数字 — 支配引擎的 real-limits-first 诚实原则同样支配价目表。如需抢先体验定价,或为团队规划方案,请与我们联系。", "Phanes не публикует цифру, которую не проверил, — та же честность real-limits-first, что управляет движком, управляет и прайс-листом. По вопросам цен раннего доступа или подбора плана для вашей команды свяжитесь с нами.") + "</p>"
    h = h + "</div></section>"
    // closer CTA → contact
    h = h + "<section class=\"sec vf\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + _tr(lang, "Get Early-Access Pricing", "얼리 액세스 가격 받기", "アーリーアクセス価格を受け取る", "获取抢先体验定价", "Узнать цены раннего доступа") + "</h2>"
    h = h + "<p class=\"lead\">" + _tr(lang, "Tell us the kind of objective you want to run and the scale you have in mind — we will follow up with an early-access plan.", "어떤 종류의 목표를 돌리고 싶은지, 그리고 염두에 둔 규모를 알려주시면 — 얼리 액세스 플랜으로 회신드리겠습니다.", "どのような目標を実行したいか、想定している規模をお知らせください — アーリーアクセスプランをご返信します。", "告诉我们你想运行的目标类型以及设想的规模 — 我们会以抢先体验方案跟进。", "Расскажите, какую цель вы хотите запустить и какой масштаб планируете, — мы вернёмся к вам с планом раннего доступа.") + "</p>"
    h = h + "<div class=\"vf-cta\">" + render_cta("/contact?lang=" + lang, _tr(lang, "contact", "문의", "お問い合わせ", "联系", "Контакты"), "primary-lg")
    h = h + "<span class=\"vf-sister\">" + _tr(lang, "try it first — ", "먼저 체험해 보세요 — ", "まずは試す — ", "先试试看 — ", "сначала попробуйте — ") + "<a href=\"/demo?lang=" + lang + "\">" + _tr(lang, "see the demo", "데모 보기", "デモを見る", "查看演示", "посмотреть демо") + "</a></span>"
    h = h + "</div></div></section>"
    h = h + render_site_footer(lang)
    h = h + "</body></html>"
    return h
}

// ── Contact page (/contact) — Palantir Titanium design system. Honest:
// lists the channels phanes actually has (GitHub on the public,
// source-available repo). No contact email is shown — none has been
// designated; one can be wired in when an address exists rather than
// inventing one.
fn render_contact_page(lang) {
    let mut h = "<!doctype html>\n<html lang=\"" + lang + "\"><head>"
    h = h + "<meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">"
    h = h + "<title>PHANES · contact</title>"
    h = h + "<style>" + _shared_css() + _sections_css() + "</style></head><body>"
    h = h + render_nav("contact", lang, "/contact")
    // hero
    h = h + "<section class=\"hero\">"
    h = h + "<div class=\"tag\">" + _tr(lang, "Contact · dancinlab", "문의 · dancinlab", "お問い合わせ · dancinlab", "联系 · dancinlab", "Контакты · dancinlab") + "</div>"
    h = h + "<h1 class=\"mark\">" + _tr(lang, "Contact", "문의", "お問い合わせ", "联系", "Контакты") + "</h1>"
    h = h + "<div class=\"sub\">" + _tr(lang, "Reach the team behind Phanes — for early access, enterprise plans, or the source itself", "Phanes 를 만든 팀에 연락하세요 — 얼리 액세스, 엔터프라이즈 플랜, 또는 소스 그 자체에 대해", "Phanes を作るチームへ — アーリーアクセス、エンタープライズプラン、あるいはソースそのものについて", "联系 Phanes 背后的团队 — 关于抢先体验、企业方案,或源代码本身", "Свяжитесь с командой Phanes — по поводу раннего доступа, корпоративных планов или самого исходного кода") + "</div>"
    h = h + "<div class=\"cue\">" + _tr(lang, "↓ scroll", "↓ 스크롤", "↓ スクロール", "↓ 滚动", "↓ прокрутить") + "</div>"
    h = h + "</section>"
    // overview
    h = h + "<section class=\"sec\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + _tr(lang, "Get In Touch", "연락하기", "お問い合わせ", "取得联系", "Связаться с нами") + "</h2>"
    h = h + "<p class=\"lead\">" + _tr(lang, "Phanes is a dancinlab product, built downstream of the open hexa-lang toolchain. The source is public and source-available — the fastest way to reach us is through the repository.", "Phanes 는 오픈 hexa-lang 툴체인의 다운스트림으로 만들어진 dancinlab 제품입니다. 소스는 공개되어 있고 source-available 입니다 — 가장 빠른 연락 방법은 저장소를 통하는 것입니다.", "Phanes はオープンな hexa-lang ツールチェーンのダウンストリームとして作られた dancinlab 製品です。ソースは公開され source-available です — 最も速い連絡方法はリポジトリ経由です。", "Phanes 是一款 dancinlab 产品,构建于开放的 hexa-lang 工具链下游。源代码公开且 source-available — 联系我们最快的方式是通过代码仓库。", "Phanes — продукт dancinlab, созданный ниже по течению от открытого инструментария hexa-lang. Исходный код открыт и source-available — быстрее всего связаться с нами через репозиторий.") + "</p>"
    h = h + "<p class=\"ov-p2\">" + _tr(lang, "Whether you want early-access pricing, a plan sized for your team, to report something, or just to read the code that backs every honesty claim on this site — the channels below are the way in.", "얼리 액세스 가격이든, 팀에 맞춘 플랜이든, 무언가를 신고하는 것이든, 아니면 그저 이 사이트의 모든 정직성 주장을 뒷받침하는 코드를 읽는 것이든 — 아래 채널들이 그 입구입니다.", "アーリーアクセス価格、チームに合ったプラン、何かの報告、あるいはこのサイトのあらゆる誠実さの主張を裏付けるコードを読むこと — いずれの場合も、下記のチャネルが入口です。", "无论你想要抢先体验定价、为团队定制的方案、报告某个问题,还是只想阅读支撑本站每一项诚实声明的代码 — 下面的渠道就是入口。", "Хотите ли вы узнать цены раннего доступа, план под размер вашей команды, сообщить о чём-то или просто почитать код, который подкрепляет каждое заявление о честности на этом сайте, — каналы ниже и есть путь внутрь.") + "</p>"
    h = h + "</div></section>"
    // channels — cards
    h = h + "<section class=\"sec\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + _tr(lang, "Channels", "채널", "チャネル", "渠道", "Каналы") + "</h2>"
    h = h + "<div class=\"cards\">"
    h = h + render_feat_card("01", "GitHub · Issues",
        _tr(lang, "Bugs, questions, and feature requests.", "버그, 질문, 기능 요청.", "バグ、質問、機能リクエスト。", "缺陷、问题与功能请求。", "Баги, вопросы и запросы функций."),
        _tr(lang, "Open an issue on the public <a href=\"https://github.com/dancinlab/phanes/issues\">dancinlab/phanes</a> repository. This is the primary channel — public, tracked, and the same place the source itself lives. A reproducible bug, a concrete feature request, an open-ended question: all of it goes here.", "공개 <a href=\"https://github.com/dancinlab/phanes/issues\">dancinlab/phanes</a> 저장소에 이슈를 등록하세요. 이곳이 주 채널입니다 — 공개되어 있고, 추적되며, 소스 자체가 있는 바로 그 장소입니다. 재현 가능한 버그, 구체적인 기능 요청, 열린 질문: 전부 여기로 옵니다.", "公開 <a href=\"https://github.com/dancinlab/phanes/issues\">dancinlab/phanes</a> リポジトリに issue を作成してください。ここが主要なチャネルです — 公開され、追跡され、ソースそのものが置かれている場所です。再現可能なバグ、具体的な機能リクエスト、自由形式の質問:すべてここへ。", "在公开的 <a href=\"https://github.com/dancinlab/phanes/issues\">dancinlab/phanes</a> 仓库提交 issue。这是主要渠道 — 公开、可追踪,也正是源代码所在之处。可复现的缺陷、具体的功能请求、开放式问题:全部到这里。", "Создайте issue в публичном репозитории <a href=\"https://github.com/dancinlab/phanes/issues\">dancinlab/phanes</a>. Это основной канал — публичный, отслеживаемый, и там же находится сам исходный код. Воспроизводимый баг, конкретный запрос функции, открытый вопрос — всё сюда."))
    h = h + render_feat_card("02", _tr(lang, "GitHub · The Source", "GitHub · 소스", "GitHub · ソース", "GitHub · 源码", "GitHub · Исходный код"),
        _tr(lang, "Read the code behind the claims.", "주장 뒤의 코드를 읽어보세요.", "主張の裏にあるコードを読む。", "阅读声明背后的代码。", "Прочитайте код за заявлениями."),
        _tr(lang, "Phanes is source-available at <a href=\"https://github.com/dancinlab/phanes\">dancinlab/phanes</a>: every honest-scope claim on this site — verifier-as-sole-authority, no over-claim — is auditable in the repository. Browsing the code is itself a way to evaluate us.", "Phanes 는 <a href=\"https://github.com/dancinlab/phanes\">dancinlab/phanes</a> 에서 source-available 입니다: 이 사이트의 모든 honest-scope 주장 — verifier 가 유일한 권위, over-claim 없음 — 은 저장소에서 감사할 수 있습니다. 코드를 둘러보는 것 자체가 우리를 평가하는 한 방법입니다.", "Phanes は <a href=\"https://github.com/dancinlab/phanes\">dancinlab/phanes</a> で source-available です:このサイトのあらゆる honest-scope の主張 — verifier が唯一の権威、over-claim なし — はリポジトリで監査できます。コードを読むこと自体が私たちを評価する手段です。", "Phanes 在 <a href=\"https://github.com/dancinlab/phanes\">dancinlab/phanes</a> 上 source-available:本站每一项 honest-scope 声明 — verifier 为唯一权威、绝不 over-claim — 都可在仓库中审计。浏览代码本身就是评估我们的一种方式。", "Phanes доступен как source-available по адресу <a href=\"https://github.com/dancinlab/phanes\">dancinlab/phanes</a>: каждое заявление honest-scope на этом сайте — verifier как единственный авторитет, без over-claim — можно проверить в репозитории. Просмотр кода — это уже способ оценить нас."))
    h = h + render_feat_card("03", _tr(lang, "Email — hello@dancinlab.org", "이메일 — hello@dancinlab.org", "メール — hello@dancinlab.org", "邮箱 — hello@dancinlab.org", "Эл. почта — hello@dancinlab.org"),
        _tr(lang, "Early access, enterprise, private inquiries.", "얼리 액세스, 엔터프라이즈, 비공개 문의.", "アーリーアクセス、エンタープライズ、非公開のお問い合わせ。", "抢先体验、企业合作、私密咨询。", "Ранний доступ, корпоративные и частные запросы."),
        _tr(lang, "Anything that does not belong in a public channel — early-access pricing, a plan sized for your team, security disclosures, or larger objectives — goes to <a href=\"mailto:hello@dancinlab.org\">hello@dancinlab.org</a>. Tell us the kind of objective, the verifier you have in mind, and the scale; we will follow up.", "공개 채널에 어울리지 않는 것은 무엇이든 — 얼리 액세스 가격, 팀 규모에 맞춘 플랜, 보안 제보, 또는 더 큰 목표 — <a href=\"mailto:hello@dancinlab.org\">hello@dancinlab.org</a> 으로 보내주세요. 목표의 종류, 염두에 둔 verifier, 그리고 규모를 알려주시면 회신드립니다.", "公開チャネルにそぐわないものは何でも — アーリーアクセス価格、チーム規模に合わせたプラン、セキュリティの報告、より大きな目標 — <a href=\"mailto:hello@dancinlab.org\">hello@dancinlab.org</a> へ。目標の種類、想定している verifier、規模をお知らせください。ご返信します。", "任何不适合公开渠道的事项 — 抢先体验定价、为你的团队定制的方案、安全披露,或更大的目标 — 请发送至 <a href=\"mailto:hello@dancinlab.org\">hello@dancinlab.org</a>。告诉我们目标类型、你设想的 verifier 以及规模;我们会跟进。", "Всё, чему не место в публичном канале, — цены раннего доступа, план под размер вашей команды, сообщения о безопасности или более крупные цели — пишите на <a href=\"mailto:hello@dancinlab.org\">hello@dancinlab.org</a>. Опишите вид цели, предполагаемый verifier и масштаб; мы свяжемся с вами."))
    h = h + render_feat_card("04", _tr(lang, "The Demo", "데모", "デモ", "演示", "Демо"),
        _tr(lang, "See it before you ask.", "묻기 전에 먼저 보세요.", "尋ねる前に、まず見る。", "在询问之前先看看。", "Сначала посмотрите, потом спрашивайте."),
        _tr(lang, "The public demo runs three curated discovery scenarios end to end — the quickest way to understand what Phanes does before getting in touch.", "공개 데모는 엄선된 발견 시나리오 3개를 처음부터 끝까지 실행합니다 — 연락하기 전에 Phanes 가 무엇을 하는지 가장 빠르게 이해하는 방법입니다.", "公開デモは厳選された発見シナリオを3つ、最初から最後まで実行します — お問い合わせの前に Phanes が何をするかを最も速く理解する方法です。", "公开演示完整运行三个精选的发现场景 — 在联系我们之前,这是理解 Phanes 能做什么的最快方式。", "Публичное демо полностью прогоняет три тщательно отобранных сценария открытия — самый быстрый способ понять, что делает Phanes, до обращения к нам."))
    h = h + "</div></div></section>"
    // closer CTA
    h = h + "<section class=\"sec vf\"><div class=\"sec-in\">"
    h = h + "<h2 class=\"eyebrow\">" + _tr(lang, "Start Here", "여기서 시작", "ここから始める", "从这里开始", "Начните здесь") + "</h2>"
    h = h + "<p class=\"lead\">" + _tr(lang, "New to Phanes? Run the demo first, then reach out — or jump straight to the dashboard if you already have access.", "Phanes 가 처음이신가요? 데모를 먼저 돌려본 다음 연락하세요 — 이미 액세스 권한이 있다면 바로 대시보드로 가셔도 됩니다.", "Phanes は初めてですか?まずデモを実行してからお問い合わせください — すでにアクセス権がある場合は、そのままダッシュボードへ。", "初次接触 Phanes?先运行演示,再联系我们 — 若你已有访问权限,可直接前往仪表板。", "Впервые в Phanes? Сначала запустите демо, затем свяжитесь с нами — или сразу переходите в панель, если у вас уже есть доступ.") + "</p>"
    h = h + "<div class=\"vf-cta\">" + render_github_cta("dancinlab/phanes", "GitHub")
    h = h + "<span class=\"vf-sister\">" + _tr(lang, "or — ", "또는 — ", "または — ", "或者 — ", "или — ") + "<a href=\"/demo?lang=" + lang + "\">" + _tr(lang, "see the demo", "데모 보기", "デモを見る", "查看演示", "посмотреть демо") + "</a></span>"
    h = h + "</div></div></section>"
    h = h + render_site_footer(lang)
    h = h + "</body></html>"
    return h
}

// ── 4 product pages — each builds a config dict for the 5-section
//    overview template. Section copy stays English (user directive:
//    only UI chrome + phonetic translate; descriptions do not). ──────

fn render_phanes_page(lang) {
    let c = #{}
    c["slug"] = "phanes"
    c["mark"] = "PHANES"
    c["phonetic"] = _t("phanes_phonetic", lang)
    c["hero_tag"] = "Autonomous Discovery · SaaS"
    c["hero_sub"] = "Enterprise-grade autonomous discovery — for any measurable objective"
    c["s1v"] = "6"
    c["s1l"] = "stage discovery chain"
    c["s2v"] = "100%"
    c["s2l"] = "provenance tracked"
    c["s3v"] = "0"
    c["s3l"] = "over-claim, by rule"
    c["ov_eyebrow"] = _tr(lang, "Next-Generation Discovery", "차세대 발견", "次世代の発見", "下一代发现", "Открытие нового поколения")
    c["ov_lead"] = _tr(lang, "Phanes wraps hexa-lang's OUROBOROS engine — the loop goal, falsifier, saturation, run in rounds with a per-round honesty gate — as a hosted web product. A company brings a measurable objective and a verifier; Phanes drives the engine against it and returns a verified, provenance-tracked discovery catalog. Their own private echoes.", "Phanes 는 hexa-lang 의 OUROBOROS 엔진 — goal · falsifier · saturation 의 루프를 라운드별 honesty gate 와 함께 라운드로 반복하는 — 을 호스팅 웹 제품으로 감쌉니다. 기업이 측정 가능한 목표와 verifier 를 가져오면, Phanes 가 그에 맞춰 엔진을 돌리고 검증된, provenance 가 추적된 발견 카탈로그를 돌려줍니다. 그들만의 private echoes 입니다.", "Phanes は hexa-lang の OUROBOROS エンジン — goal・falsifier・saturation のループをラウンドごとの honesty gate とともにラウンドで反復するもの — をホスト型 Web 製品として包みます。企業が計測可能な目標と verifier を持ち込むと、Phanes はそれに対してエンジンを駆動し、検証済みで provenance を追跡した発見カタログを返します。彼ら自身の private echoes です。", "Phanes 将 hexa-lang 的 OUROBOROS 引擎 — goal、falsifier、saturation 的循环,按轮次运行并配有每轮 honesty gate — 包装为托管的 Web 产品。企业带来一个可衡量的目标和一个 verifier;Phanes 据此驱动引擎,返回一份经过验证、provenance 可追溯的发现目录。属于他们自己的 private echoes。", "Phanes оборачивает движок OUROBOROS от hexa-lang — цикл goal, falsifier, saturation, выполняемый раундами с honesty gate на каждом раунде — в виде размещённого веб-продукта. Компания приносит измеримую цель и verifier; Phanes запускает движок против неё и возвращает проверенный, отслеживаемый по provenance каталог открытий. Их собственные private echoes.")
    c["ov_p2"] = _tr(lang, "The engine is not a black box. Every round is a goal proposed, a falsifier fired against it, and a saturation check — and every step is written to an audit trail you can inspect. What Phanes sells is not a promise that your objective is met; it is a verified record of exactly what the engine found and exactly how hard it tried to break it.", "엔진은 블랙박스가 아닙니다. 모든 라운드는 goal 의 제안, 그에 대한 falsifier 발사, 그리고 saturation 검사이며 — 모든 단계가 당신이 들여다볼 수 있는 audit trail 에 기록됩니다. Phanes 가 파는 것은 당신의 목표가 달성된다는 약속이 아니라, 엔진이 정확히 무엇을 찾았고 그것을 얼마나 강하게 깨뜨리려 했는지에 대한 검증된 기록입니다.", "エンジンはブラックボックスではありません。すべてのラウンドは goal の提案、それに対する falsifier の発火、そして saturation の検査であり — すべてのステップが、あなたが検査できる audit trail に記録されます。Phanes が売るのは、あなたの目標が達成されるという約束ではなく、エンジンが正確に何を見つけ、それをどれほど強く壊そうとしたかの検証済みの記録です。", "引擎不是黑箱。每一轮都是提出一个 goal、对其发起一个 falsifier,以及一次 saturation 检查 — 而每一步都被写入你可以查看的 audit trail。Phanes 出售的不是你的目标会达成的承诺;而是关于引擎究竟发现了什么、又如何竭力试图推翻它的一份经过验证的记录。", "Движок — не чёрный ящик. Каждый раунд — это предложенная goal, запущенный против неё falsifier и проверка saturation, и каждый шаг записывается в audit trail, который вы можете изучить. Phanes продаёт не обещание, что ваша цель достигнута; он продаёт проверенную запись того, что именно нашёл движок и насколько упорно он пытался это опровергнуть.")
    c["kf_eyebrow"] = _tr(lang, "Key Features", "핵심 기능", "主な機能", "核心特性", "Ключевые возможности")
    c["f1l"] = _tr(lang, "Pluggable Seed and Verifier:", "교체 가능한 Seed 와 Verifier:", "差し替え可能な Seed と Verifier:", "可插拔的 Seed 与 Verifier:", "Подключаемые Seed и Verifier:")
    c["f1b"] = _tr(lang, "Bring a seed and a verifier oracle. Under scope B the tenant verifier is the sole authority for objective-met — Phanes never substitutes its own advisory gate.", "seed 와 verifier oracle 을 가져오세요. scope B 에서는 테넌트의 verifier 가 목표 달성에 대한 유일한 권위입니다 — Phanes 는 자신의 advisory gate 로 그것을 결코 대체하지 않습니다.", "seed と verifier oracle を持ち込んでください。scope B では、テナントの verifier が目標達成の唯一の権威です — Phanes が自身の advisory gate でそれを代替することはありません。", "带来一个 seed 和一个 verifier oracle。在 scope B 下,租户的 verifier 是目标达成的唯一权威 — Phanes 绝不以自己的 advisory gate 取而代之。", "Принесите seed и verifier oracle. В рамках scope B verifier арендатора — единственный авторитет в вопросе достижения цели; Phanes никогда не подменяет его своим advisory gate.")
    c["f2l"] = _tr(lang, "Provenance Track:", "Provenance 추적:", "Provenance トラック:", "Provenance 追踪:", "Отслеживание provenance:")
    c["f2b"] = _tr(lang, "Every round is logged with its falsification audit trail. The result is an exportable, per-tenant catalog you can verify line by line.", "모든 라운드는 그 falsification audit trail 과 함께 기록됩니다. 그 결과는 한 줄 한 줄 검증할 수 있는, 내보내기 가능한 테넌트별 카탈로그입니다.", "すべてのラウンドは、その falsification audit trail とともに記録されます。結果は、一行ずつ検証できる、エクスポート可能なテナントごとのカタログです。", "每一轮都连同其 falsification audit trail 一起记录。结果是一份可导出、按租户划分、可逐行验证的目录。", "Каждый раунд записывается вместе со своим falsification audit trail. Результат — экспортируемый каталог по каждому арендатору, который можно проверить строка за строкой.")
    c["f3l"] = _tr(lang, "Sandboxed Compute:", "샌드박스 컴퓨팅:", "サンドボックス化されたコンピュート:", "沙箱化算力:", "Изолированные вычисления:")
    c["f3b"] = _tr(lang, "Each job runs in a per-tenant home-jail with an arena-free runtime. Isolation holds at concurrency; defense-in-depth, measured.", "각 작업은 arena-free 런타임을 갖춘 테넌트별 home-jail 안에서 실행됩니다. 동시 실행에서도 격리가 유지됩니다 — 측정된 defense-in-depth.", "各ジョブは arena-free ランタイムを備えたテナントごとの home-jail 内で実行されます。並行実行下でも分離は保たれます — 計測された defense-in-depth。", "每个任务在按租户划分的 home-jail 中以 arena-free 运行时执行。并发下隔离依然成立 — 经过测量的纵深防御。", "Каждая задача выполняется в home-jail для каждого арендатора с arena-free средой выполнения. Изоляция сохраняется при параллельности — измеренная эшелонированная защита.")
    c["hw_eyebrow"] = _tr(lang, "How It Works", "작동 방식", "仕組み", "工作原理", "Как это работает")
    c["w1t"] = _tr(lang, "Submit a Seed", "Seed 제출", "Seed を送信", "提交 Seed", "Отправьте Seed")
    c["w1b"] = _tr(lang, "Bring a measurable objective and a verifier script. The seed is the starting point the engine reasons from.", "측정 가능한 목표와 verifier 스크립트를 가져오세요. seed 는 엔진이 추론을 시작하는 출발점입니다.", "計測可能な目標と verifier スクリプトを持ち込んでください。seed はエンジンが推論を始める出発点です。", "带来一个可衡量的目标和一个 verifier 脚本。seed 是引擎进行推理的起点。", "Принесите измеримую цель и скрипт verifier. Seed — это отправная точка, от которой движок ведёт рассуждение.")
    c["w2t"] = _tr(lang, "OUROBOROS Runs", "OUROBOROS 실행", "OUROBOROS が走る", "OUROBOROS 运行", "OUROBOROS работает")
    c["w2b"] = _tr(lang, "The engine runs rounds — goal, falsifier, saturation — reseeding each round from the last round's findings.", "엔진은 라운드를 실행합니다 — goal · falsifier · saturation — 각 라운드를 직전 라운드의 발견으로 다시 씨앗 뿌립니다.", "エンジンはラウンドを実行します — goal・falsifier・saturation — 各ラウンドを直前のラウンドの発見で再シードします。", "引擎按轮次运行 — goal、falsifier、saturation — 每一轮都用上一轮的发现重新播种。", "Движок выполняет раунды — goal, falsifier, saturation — заново засевая каждый раунд находками предыдущего.")
    c["w3t"] = _tr(lang, "Honesty Gate", "Honesty Gate", "Honesty Gate", "Honesty Gate", "Honesty Gate")
    c["w3b"] = _tr(lang, "Every round passes a falsification gate. A claim that cannot survive its own falsifier does not advance.", "모든 라운드는 falsification gate 를 통과합니다. 자신의 falsifier 를 견디지 못하는 주장은 전진하지 못합니다.", "すべてのラウンドは falsification gate を通過します。自らの falsifier に耐えられない主張は前進しません。", "每一轮都要通过一个 falsification gate。无法在自己的 falsifier 下存活的主张不会前进。", "Каждый раунд проходит falsification gate. Утверждение, не выдержавшее собственный falsifier, не продвигается дальше.")
    c["w4t"] = _tr(lang, "Verified Catalog", "검증된 카탈로그", "検証済みカタログ", "已验证目录", "Проверенный каталог")
    c["w4b"] = _tr(lang, "Saturation returns a provenance-tracked catalog — your own private echoes, exportable and auditable.", "saturation 은 provenance 가 추적된 카탈로그를 돌려줍니다 — 내보내기와 감사가 가능한, 당신만의 private echoes.", "saturation は provenance を追跡したカタログを返します — エクスポートと監査が可能な、あなた自身の private echoes。", "saturation 返回一份 provenance 可追溯的目录 — 属于你自己的、可导出且可审计的 private echoes。", "Saturation возвращает каталог с отслеживанием provenance — ваши собственные private echoes, экспортируемые и проверяемые.")
    c["cn_eyebrow"] = _tr(lang, "A Connected Discovery Loop", "연결된 발견 루프", "つながった発見ループ", "互联的发现循环", "Связанный цикл открытий")
    c["c1t"] = _tr(lang, "Harness the Engine", "엔진을 다루다", "エンジンを操る", "驾驭引擎", "Управляйте движком")
    c["c1l"] = _tr(lang, "Drive the full OUROBOROS loop from the web.", "전체 OUROBOROS 루프를 웹에서 구동합니다.", "OUROBOROS ループ全体を Web から駆動します。", "从 Web 驱动完整的 OUROBOROS 循环。", "Запускайте весь цикл OUROBOROS из веба.")
    c["c1b"] = _tr(lang, "Phanes connects the seed, the rounds, and the saturation check into one hosted workflow — the same drill engine that powers hexa-lang's own discovery cycles, behind an authenticated control plane.", "Phanes 는 seed, 라운드, saturation 검사를 하나의 호스팅 워크플로로 연결합니다 — hexa-lang 자체의 발견 사이클을 구동하는 바로 그 drill 엔진을, 인증된 control plane 뒤에서.", "Phanes は seed、ラウンド、saturation の検査を1つのホスト型ワークフローに接続します — hexa-lang 自身の発見サイクルを動かすのと同じ drill エンジンを、認証された control plane の背後で。", "Phanes 将 seed、轮次和 saturation 检查连接为一个托管的工作流 — 即驱动 hexa-lang 自身发现循环的同一个 drill 引擎,运行在经过认证的 control plane 之后。", "Phanes соединяет seed, раунды и проверку saturation в один размещённый рабочий процесс — тот же движок drill, что питает собственные циклы открытий hexa-lang, за аутентифицированным control plane.")
    c["c2t"] = _tr(lang, "Customize the Workspace", "워크스페이스 맞춤 설정", "ワークスペースをカスタマイズ", "定制工作区", "Настройте рабочее пространство")
    c["c2l"] = _tr(lang, "A live dashboard, no page reloads.", "페이지 새로고침 없는 라이브 대시보드.", "ページ再読み込みのないライブダッシュボード。", "实时仪表板,无需刷新页面。", "Живая панель без перезагрузки страницы.")
    c["c2b"] = _tr(lang, "Submit jobs and watch them progress through an HTMX-polled dashboard. Polling auto-stops the instant a job reaches done or failed — the interface knows when to be quiet.", "작업을 제출하고 HTMX 로 폴링되는 대시보드에서 진행 상황을 지켜보세요. 작업이 done 또는 failed 에 도달하는 즉시 폴링이 자동으로 멈춥니다 — 인터페이스는 언제 조용해야 할지 압니다.", "ジョブを送信し、HTMX でポーリングされるダッシュボードで進行を見守ってください。ジョブが done または failed に達した瞬間にポーリングは自動停止します — インターフェースはいつ静かにすべきかを知っています。", "提交任务,并在 HTMX 轮询的仪表板上观察其进展。任务一旦到达 done 或 failed,轮询即自动停止 — 界面知道何时该安静。", "Отправляйте задачи и следите за их ходом на панели с опросом через HTMX. Опрос автоматически прекращается, как только задача достигает done или failed — интерфейс знает, когда замолчать.")
    c["c3t"] = _tr(lang, "Security Powering Trust", "신뢰를 떠받치는 보안", "信頼を支えるセキュリティ", "支撑信任的安全", "Безопасность как основа доверия")
    c["c3l"] = _tr(lang, "Per-tenant isolation across every job.", "모든 작업에 걸친 테넌트별 격리.", "すべてのジョブにわたるテナントごとの分離。", "贯穿每个任务的按租户隔离。", "Изоляция по арендаторам для каждой задачи.")
    c["c3b"] = _tr(lang, "Hybrid multi-tenant isolation — a per-job home-jail now, a first-class data-dir boundary upstream. Session cookies and bearer tokens gate every authenticated surface.", "하이브리드 멀티테넌트 격리 — 지금은 작업별 home-jail, 업스트림에는 일급 data-dir 경계. 세션 쿠키와 bearer 토큰이 모든 인증 표면을 지킵니다.", "ハイブリッドなマルチテナント分離 — 現在はジョブごとの home-jail、アップストリームには一級の data-dir 境界。セッションクッキーと bearer トークンがすべての認証面を守ります。", "混合式多租户隔离 — 当前是按任务的 home-jail,上游则是一等的 data-dir 边界。会话 cookie 与 bearer 令牌守卫每一个需认证的入口。", "Гибридная многоарендная изоляция — сейчас home-jail для каждой задачи, выше по течению — полноценная граница data-dir. Сессионные cookie и bearer-токены защищают каждую аутентифицированную поверхность.")
    c["c4t"] = _tr(lang, "Enabling Developers", "개발자를 위한 토대", "開発者を後押し", "赋能开发者", "Возможности для разработчиков")
    c["c4l"] = _tr(lang, "Bring your own verifier.", "당신의 verifier 를 가져오세요.", "自分の verifier を持ち込む。", "自带你的 verifier。", "Используйте свой verifier.")
    c["c4b"] = _tr(lang, "The seed format is open and the verifier is just a script that exits zero on PASS. Wire any measurable objective into the loop without forking the engine.", "seed 포맷은 공개되어 있고 verifier 는 PASS 시 0 으로 종료하는 스크립트일 뿐입니다. 엔진을 fork 하지 않고도 측정 가능한 어떤 목표든 루프에 연결하세요.", "seed フォーマットは公開されており、verifier は PASS 時にゼロで終了するスクリプトに過ぎません。エンジンを fork せずに、計測可能なあらゆる目標をループに接続できます。", "seed 格式是开放的,verifier 只是一个在 PASS 时以零退出的脚本。无需 fork 引擎,即可将任何可衡量的目标接入循环。", "Формат seed открыт, а verifier — это просто скрипт, завершающийся нулём при PASS. Подключите любую измеримую цель к циклу, не форкая движок.")
    c["vf_eyebrow"] = _tr(lang, "A Verified Solution", "검증된 솔루션", "検証済みのソリューション", "经过验证的方案", "Проверенное решение")
    c["vf_body"] = _tr(lang, "Phanes operates under scope B: the tenant-supplied verifier is the sole authority for objective-met, and Phanes never claims a result the verifier did not pass. It is built on hexa-lang — OUROBOROS cycle h36 complete, a bit-stable self-host fixpoint, tier-1 codegen-correctness verified — and inherits its real-limits-first honesty rule. No over-claim, no project-completion promise. Saturation is the only hard stop.", "Phanes 는 scope B 로 운영됩니다: 테넌트가 제공한 verifier 가 목표 달성에 대한 유일한 권위이며, Phanes 는 verifier 가 통과시키지 않은 결과를 결코 주장하지 않습니다. Phanes 는 hexa-lang 위에 만들어졌고 — OUROBOROS 사이클 h36 완료, bit-stable self-host fixpoint, tier-1 codegen 정확성 검증 — 그 real-limits-first 정직성 규칙을 물려받습니다. over-claim 없음, 프로젝트 완성 약속 없음. saturation 만이 유일한 하드 스톱입니다.", "Phanes は scope B で運用されます:テナントが提供する verifier が目標達成の唯一の権威であり、Phanes は verifier が通さなかった結果を主張することは決してありません。Phanes は hexa-lang の上に構築され — OUROBOROS サイクル h36 完了、bit-stable な self-host fixpoint、tier-1 の codegen 正当性を検証済み — その real-limits-first の誠実さの規則を継承します。over-claim なし、プロジェクト完成の約束なし。saturation だけが唯一のハードストップです。", "Phanes 在 scope B 下运作:租户提供的 verifier 是目标达成的唯一权威,Phanes 绝不宣称一个 verifier 未通过的结果。它构建于 hexa-lang 之上 — OUROBOROS 周期 h36 完成、bit-stable 的 self-host fixpoint、tier-1 codegen 正确性已验证 — 并继承其 real-limits-first 的诚实原则。没有 over-claim,不承诺完成项目。saturation 是唯一的硬性停止条件。", "Phanes работает в рамках scope B: предоставленный арендатором verifier — единственный авторитет в вопросе достижения цели, и Phanes никогда не заявляет результат, который verifier не пропустил. Он построен на hexa-lang — цикл OUROBOROS h36 завершён, bit-stable self-host fixpoint, корректность codegen уровня tier-1 проверена — и наследует его правило честности real-limits-first. Никакого over-claim, никаких обещаний завершить проект. Saturation — единственная жёсткая остановка.")
    c["cta_html"] = render_cta("/login", _t("enter", lang), "primary-lg")
    c["sister_label"] = "DEMIURGE"
    c["sister_href"] = "/demiurge?lang=" + lang
    return render_product_overview_page(lang, c)
}

fn render_demiurge_page(lang) {
    let c = #{}
    c["slug"] = "demiurge"
    c["mark"] = "DEMIURGE"
    c["phonetic"] = _t("demiurge_phonetic", lang)
    c["hero_tag"] = "Technical-Design · Meta-Conductor"
    c["hero_sub"] = "The universal meta-conductor for rigorous technical design"
    c["s1v"] = "7"
    c["s1l"] = "verb design spine"
    c["s2v"] = "∞"
    c["s2l"] = "domains, pluggable"
    c["s3v"] = "0"
    c["s3l"] = "un-cited claims"
    c["ov_eyebrow"] = _tr(lang, "Architecture as a Verb", "동사로서의 아키텍처", "動詞としてのアーキテクチャ", "作为动词的架构", "Архитектура как глагол")
    c["ov_lead"] = _tr(lang, "Demiurge is the meta-conductor for technical design — a seven-verb spine that orchestrates rigorous, falsifiable engineering across domains: specify, architect, design, analyze in a loop, synthesize, verify, handoff. It is the sibling cosmology to Phanes — where Phanes reveals form by light, Demiurge gives form by shaping.", "Demiurge 는 기술 설계를 위한 메타 컨덕터입니다 — 도메인을 가로질러 엄밀하고 반증 가능한 엔지니어링을 지휘하는 7개 동사의 척추: specify, architect, design, 루프 안의 analyze, synthesize, verify, handoff. Phanes 의 자매 코스몰로지입니다 — Phanes 가 빛으로 형상을 드러낸다면, Demiurge 는 빚어내어 형상을 부여합니다.", "Demiurge は技術設計のためのメタコンダクターです — ドメインを横断して厳密で反証可能なエンジニアリングを指揮する7つの動詞の背骨:specify、architect、design、ループの中の analyze、synthesize、verify、handoff。Phanes の姉妹コスモロジーです — Phanes が光で形を顕すのに対し、Demiurge は形作ることで形を与えます。", "Demiurge 是技术设计的元指挥 — 一条由七个动词构成的脊柱,跨领域编排严谨、可证伪的工程:specify、architect、design、循环中的 analyze、synthesize、verify、handoff。它是 Phanes 的姊妹宇宙观 — Phanes 以光显现形态,Demiurge 则以塑造赋予形态。", "Demiurge — мета-дирижёр технического проектирования: семиглагольный хребет, оркеструющий строгую, опровержимую инженерию во множестве предметных областей: specify, architect, design, analyze в цикле, synthesize, verify, handoff. Это родственная Phanes космология — там, где Phanes являет форму светом, Demiurge даёт форму, формуя её.")
    c["ov_p2"] = _tr(lang, "Most design tools help you draw faster. Demiurge does something different — it makes every design decision answer to a falsifier. A spec is not done until its acceptance criteria are verifier-bound; an analysis is not done until it closes its own loop; a handoff is not done until it ships the reasoning that earned it. The spine is the same whether the domain is a chip, a protein, or a policy.", "대부분의 설계 도구는 더 빨리 그리도록 돕습니다. Demiurge 는 다른 일을 합니다 — 모든 설계 결정이 falsifier 앞에 답하도록 만듭니다. spec 은 그 수용 기준이 verifier 에 묶이기 전까지 끝난 것이 아니고, 분석은 자신의 루프를 닫기 전까지 끝난 것이 아니며, handoff 는 그것을 얻어낸 추론을 함께 실어 보내기 전까지 끝난 것이 아닙니다. 도메인이 칩이든, 단백질이든, 정책이든 척추는 동일합니다.", "ほとんどの設計ツールは、より速く描くことを助けます。Demiurge は別のことをします — すべての設計判断を falsifier に答えさせます。spec は受け入れ基準が verifier に束縛されるまで完了せず、分析は自らのループを閉じるまで完了せず、handoff はそれを得た推論を載せて送るまで完了しません。ドメインがチップであれ、タンパク質であれ、ポリシーであれ、背骨は同じです。", "大多数设计工具帮你画得更快。Demiurge 做的事不同 — 它让每一个设计决策都对一个 falsifier 负责。一份 spec 在其验收标准被 verifier 绑定之前不算完成;一次分析在闭合自己的循环之前不算完成;一次 handoff 在交付赢得它的推理之前不算完成。无论领域是芯片、蛋白质还是政策,这条脊柱都相同。", "Большинство инструментов проектирования помогают рисовать быстрее. Demiurge делает иное — он заставляет каждое проектное решение отвечать перед falsifier. Spec не завершён, пока его критерии приёмки не привязаны к verifier; анализ не завершён, пока не замкнёт собственный цикл; handoff не завершён, пока не передаёт рассуждение, которое его заслужило. Хребет один и тот же, будь предметная область чипом, белком или политикой.")
    c["kf_eyebrow"] = _tr(lang, "Key Features", "핵심 기능", "主な機能", "核心特性", "Ключевые возможности")
    c["f1l"] = _tr(lang, "The Seven-Verb Spine:", "7개 동사의 척추:", "7つの動詞の背骨:", "七动词脊柱:", "Семиглагольный хребет:")
    c["f1b"] = _tr(lang, "Specify, architect, design, analyze, synthesize, verify, handoff — each verb has a measurable closure condition. No verb completes on vibes.", "specify, architect, design, analyze, synthesize, verify, handoff — 각 동사는 측정 가능한 종료 조건을 가집니다. 어떤 동사도 분위기로 완료되지 않습니다.", "specify、architect、design、analyze、synthesize、verify、handoff — 各動詞には計測可能な完了条件があります。雰囲気で完了する動詞はありません。", "specify、architect、design、analyze、synthesize、verify、handoff — 每个动词都有可衡量的闭合条件。没有动词靠感觉就算完成。", "specify, architect, design, analyze, synthesize, verify, handoff — у каждого глагола есть измеримое условие завершения. Ни один глагол не завершается на ощущениях.")
    c["f2l"] = _tr(lang, "Domain-Pluggable:", "도메인 교체 가능:", "ドメイン差し替え可能:", "领域可插拔:", "Подключаемые предметные области:")
    c["f2b"] = _tr(lang, "Chip, protein, policy, system — the same seven-verb scaffold dispatches per-domain solvers and oracles. The spine is constant; the domain is a plugin.", "칩, 단백질, 정책, 시스템 — 동일한 7개 동사 골격이 도메인별 solver 와 oracle 을 디스패치합니다. 척추는 일정하고, 도메인은 플러그인입니다.", "チップ、タンパク質、ポリシー、システム — 同じ7つの動詞のスキャフォールドがドメインごとの solver と oracle をディスパッチします。背骨は一定で、ドメインはプラグインです。", "芯片、蛋白质、政策、系统 — 同一套七动词骨架按领域分派 solver 与 oracle。脊柱恒定,领域是插件。", "Чип, белок, политика, система — один и тот же семиглагольный каркас диспетчеризует solver и oracle для каждой области. Хребет постоянен; область — это плагин.")
    c["f3l"] = _tr(lang, "Honesty as a Feature:", "기능으로서의 정직성:", "機能としての誠実さ:", "诚实即特性:", "Честность как функция:")
    c["f3b"] = _tr(lang, "Over-claim is forbidden by construction. Every verb declares its scope, its sources, and what it does not yet do — the audit trail ships with the design.", "over-claim 은 구조적으로 금지됩니다. 모든 동사는 자신의 범위, 출처, 그리고 아직 하지 못하는 것을 선언합니다 — audit trail 이 설계와 함께 실려 나갑니다.", "over-claim は構造上禁止されています。すべての動詞は自らの範囲、出典、そしてまだできないことを宣言します — audit trail が設計とともに届きます。", "over-claim 在构造上被禁止。每个动词都声明自己的范围、来源,以及它尚未做到的事 — audit trail 随设计一同交付。", "Over-claim запрещён по построению. Каждый глагол объявляет свою область, источники и то, чего он ещё не делает — audit trail поставляется вместе с проектом.")
    c["hw_eyebrow"] = _tr(lang, "How It Works", "작동 방식", "仕組み", "工作原理", "Как это работает")
    c["w1t"] = "Specify"
    c["w1b"] = _tr(lang, "Specify and architect: acceptance criteria are fixed as verifier-bound statements before any code.", "specify 와 architect: 수용 기준이 코드 작성 전에 verifier 에 묶인 진술로 고정됩니다.", "specify と architect:受け入れ基準は、コードの前に verifier に束縛された文として固定されます。", "specify 与 architect:验收标准在任何代码之前,被固定为绑定 verifier 的陈述。", "specify и architect: критерии приёмки фиксируются как привязанные к verifier утверждения до всякого кода.")
    c["w2t"] = "Design ⟲ Analyze"
    c["w2b"] = _tr(lang, "Design re-enters the analyze verb in a loop until the analysis closes its own falsifier.", "design 은 분석이 자신의 falsifier 를 닫을 때까지 analyze 동사로 루프를 돌며 다시 들어갑니다.", "design は、分析が自らの falsifier を閉じるまで、analyze 動詞へループで再入します。", "design 在循环中反复进入 analyze 动词,直到分析闭合自己的 falsifier。", "design снова входит в глагол analyze в цикле, пока анализ не замкнёт собственный falsifier.")
    c["w3t"] = "Synthesize"
    c["w3b"] = _tr(lang, "Synthesis emits the artifact; verify cross-checks it against the spec and the atlas-bound theorems it cites.", "synthesize 가 산출물을 내보내고, verify 가 그것을 spec 및 그것이 인용하는 atlas 정리에 대조 검사합니다.", "synthesize が成果物を出力し、verify がそれを spec および引用する atlas 定理と照合します。", "synthesize 产出工件;verify 将其与 spec 及其所引用的 atlas 定理交叉核对。", "synthesize выдаёт артефакт; verify сверяет его со spec и теоремами atlas, на которые он ссылается.")
    c["w4t"] = "Handoff"
    c["w4b"] = _tr(lang, "Handoff ships the deliverable with its full falsifier trail and the chain of verbs that produced it.", "handoff 는 산출물을 그 전체 falsifier trail 및 그것을 만들어낸 동사 사슬과 함께 실어 보냅니다.", "handoff は成果物を、その完全な falsifier trail とそれを生み出した動詞の連鎖とともに送り出します。", "handoff 将交付物连同其完整的 falsifier trail 以及产生它的动词链一起交付。", "handoff отправляет результат вместе с полным falsifier trail и цепочкой глаголов, которые его произвели.")
    c["cn_eyebrow"] = _tr(lang, "A Connected Design Workflow", "연결된 설계 워크플로", "つながった設計ワークフロー", "互联的设计工作流", "Связанный рабочий процесс проектирования")
    c["c1t"] = _tr(lang, "From Spec to Form", "Spec 에서 형상으로", "Spec から形へ", "从 Spec 到形态", "От Spec к форме")
    c["c1l"] = _tr(lang, "Specify and architect run before any code.", "specify 와 architect 는 코드보다 먼저 실행됩니다.", "specify と architect はコードより先に走ります。", "specify 与 architect 在任何代码之前运行。", "specify и architect выполняются до всякого кода.")
    c["c1b"] = _tr(lang, "Demiurge fixes the acceptance criteria as verifier-bound statements first. Architecture is committed against those criteria, not against a hunch — so the design has a falsifier from line one.", "Demiurge 는 먼저 수용 기준을 verifier 에 묶인 진술로 고정합니다. 아키텍처는 직감이 아니라 그 기준에 맞춰 확정됩니다 — 그래서 설계는 첫 줄부터 falsifier 를 가집니다.", "Demiurge はまず受け入れ基準を verifier に束縛された文として固定します。アーキテクチャは勘ではなく、その基準に対してコミットされます — だから設計は1行目から falsifier を持ちます。", "Demiurge 先将验收标准固定为绑定 verifier 的陈述。架构是针对这些标准提交的,而非凭直觉 — 因此设计从第一行起就有一个 falsifier。", "Demiurge сначала фиксирует критерии приёмки как привязанные к verifier утверждения. Архитектура фиксируется относительно этих критериев, а не догадки — поэтому у проекта есть falsifier с первой строки.")
    c["c2t"] = _tr(lang, "Iterate with Analysis", "분석으로 반복하다", "分析で反復する", "以分析迭代", "Итерации через анализ")
    c["c2l"] = _tr(lang, "Analyze is a fixed point, not a step.", "analyze 는 단계가 아니라 고정점입니다.", "analyze はステップではなく不動点です。", "analyze 是一个不动点,而非一个步骤。", "analyze — это неподвижная точка, а не шаг.")
    c["c2b"] = _tr(lang, "The design re-enters the analyze verb until the analysis closes its own falsifier. The loop is the product — convergence is observed, never assumed.", "설계는 분석이 자신의 falsifier 를 닫을 때까지 analyze 동사로 다시 들어갑니다. 루프가 곧 제품입니다 — 수렴은 관찰되는 것이지 가정되는 것이 아닙니다.", "設計は、分析が自らの falsifier を閉じるまで analyze 動詞へ再入します。ループこそが製品です — 収束は観測されるものであり、仮定されることはありません。", "设计反复进入 analyze 动词,直到分析闭合自己的 falsifier。循环本身就是产品 — 收敛是被观测的,绝不被假定。", "Проект снова входит в глагол analyze, пока анализ не замкнёт собственный falsifier. Цикл — это и есть продукт: сходимость наблюдается, а не предполагается.")
    c["c3t"] = _tr(lang, "Synthesize and Verify", "Synthesize 와 Verify", "Synthesize と Verify", "Synthesize 与 Verify", "Synthesize и Verify")
    c["c3l"] = _tr(lang, "Artifacts cross-checked against the spec.", "산출물은 spec 에 대조 검사됩니다.", "成果物は spec と照合されます。", "工件与 spec 交叉核对。", "Артефакты сверяются со spec.")
    c["c3b"] = _tr(lang, "Synthesis emits the deliverable; verify checks it against the original specification and the atlas-bound theorems it cites. A synthesis that fails verify is not a deliverable.", "synthesize 가 산출물을 내보내고, verify 가 그것을 원래 명세 및 그것이 인용하는 atlas 정리에 대조하여 검사합니다. verify 를 통과하지 못한 합성물은 산출물이 아닙니다.", "synthesize が成果物を出力し、verify がそれを元の仕様および引用する atlas 定理と照合します。verify を通らない合成物は成果物ではありません。", "synthesize 产出交付物;verify 将其与原始规约及其引用的 atlas 定理核对。未通过 verify 的合成物不是交付物。", "synthesize выдаёт результат; verify проверяет его относительно исходной спецификации и теорем atlas, на которые он ссылается. Синтез, не прошедший verify, не является результатом.")
    c["c4t"] = _tr(lang, "Handoff with Provenance", "Provenance 와 함께 Handoff", "Provenance を伴う Handoff", "带 Provenance 的 Handoff", "Handoff с provenance")
    c["c4l"] = _tr(lang, "Every deliverable carries its history.", "모든 산출물은 자신의 이력을 지니고 다닙니다.", "すべての成果物は自らの履歴を携えます。", "每个交付物都携带其历史。", "Каждый результат несёт свою историю.")
    c["c4b"] = _tr(lang, "Handoff ships the falsifier trail and the full chain of verbs that produced the result — the receiving team inherits not just the artifact but the reasoning that earned it.", "handoff 는 falsifier trail 과 결과를 만들어낸 동사들의 전체 사슬을 함께 실어 보냅니다 — 인수받는 팀은 산출물뿐 아니라 그것을 얻어낸 추론까지 물려받습니다.", "handoff は falsifier trail と、結果を生み出した動詞の全連鎖を送り出します — 受け取るチームは成果物だけでなく、それを得た推論も継承します。", "handoff 交付 falsifier trail 以及产生该结果的完整动词链 — 接收团队继承的不只是工件,还有赢得它的推理。", "handoff отправляет falsifier trail и всю цепочку глаголов, которые произвели результат — принимающая команда наследует не только артефакт, но и рассуждение, которое его заслужило.")
    c["vf_eyebrow"] = _tr(lang, "Platonic Timaeus", "플라톤의 티마이오스", "プラトンのティマイオス", "柏拉图的《蒂迈欧》", "Платоновский «Тимей»")
    c["vf_body"] = _tr(lang, "Demiurge is the Platonic shaper-to-Forms: it does not invent material, it gives technical material its rigorous shape. Paired with Phanes — the Orphic primordial revealer of Forms — as a sibling cosmology: two dancinlab brands, one continuous cosmology. Demiurge is downstream of hexa-lang and inherits its honesty rule; every verb is scoped, cited, and falsifiable.", "Demiurge 는 형상(Forms)을 빚는 플라톤적 조형자입니다: 재료를 발명하지 않고, 기술적 재료에 엄밀한 형상을 부여합니다. Phanes — 형상을 드러내는 오르페우스적 원초의 존재 — 와 자매 코스몰로지로 짝을 이룹니다: 두 개의 dancinlab 브랜드, 하나의 연속된 코스몰로지. Demiurge 는 hexa-lang 의 다운스트림이며 그 정직성 규칙을 물려받습니다 — 모든 동사는 범위가 정해지고, 인용되며, 반증 가능합니다.", "Demiurge は形相(Forms)を形作るプラトン的な造形者です:素材を発明するのではなく、技術的素材に厳密な形を与えます。Phanes — 形相を顕すオルペウス的な原初の存在 — と姉妹コスモロジーとして対をなします:2つの dancinlab ブランド、1つの連続したコスモロジー。Demiurge は hexa-lang のダウンストリームであり、その誠実さの規則を継承します — すべての動詞は範囲が定められ、引用され、反証可能です。", "Demiurge 是柏拉图式的「形相塑造者」:它不发明材料,而是赋予技术材料以严谨的形态。它与 Phanes — 俄耳甫斯教中显现形相的原初存在 — 结为姊妹宇宙观:两个 dancinlab 品牌,一个连续的宇宙观。Demiurge 处于 hexa-lang 的下游,并继承其诚实原则 — 每个动词都有范围、有引用、可证伪。", "Demiurge — платоновский ваятель Форм: он не изобретает материал, а придаёт техническому материалу строгую форму. В паре с Phanes — орфическим первородным явителем Форм — он образует родственную космологию: два бренда dancinlab, одна непрерывная космология. Demiurge находится ниже по течению от hexa-lang и наследует его правило честности — каждый глагол ограничен в области, снабжён ссылками и опровержим.")
    c["cta_html"] = render_github_cta("dancinlab/demiurge", "GitHub")
    c["sister_label"] = "PHANES"
    c["sister_href"] = "/phanes?lang=" + lang
    return render_product_overview_page(lang, c)
}

fn render_hexa_lang_page(lang) {
    let c = #{}
    c["slug"] = "hexa-lang"
    c["mark"] = "HEXA-LANG"
    c["phonetic"] = ""
    c["hero_tag"] = "Native Compiler · Substrate"
    c["hero_sub"] = "A self-hosted native compiler with atlas-bound theorems"
    c["s1v"] = "8"
    c["s1l"] = "strict-lint stages"
    c["s2v"] = "38/44"
    c["s2l"] = "tier-1 corpus PASS"
    c["s3v"] = "0"
    c["s3l"] = "LLVM, by policy"
    c["ov_eyebrow"] = _tr(lang, "A Compiler that Cites", "인용하는 컴파일러", "引用するコンパイラ", "会引用的编译器", "Компилятор, который ссылается")
    c["ov_lead"] = _tr(lang, "hexa-lang is a self-hosted native compiler. Every formula-bearing line cites an atlas theorem, every build passes eight strict-lint stages, and nothing leaves the toolchain that was not verified. It is the bottom of the dancinlab stack — wilson, echoes, anima and the hexa-* family all consume it; nothing imports back.", "hexa-lang 은 self-hosted 네이티브 컴파일러입니다. 수식을 담은 모든 줄은 atlas 정리를 인용하고, 모든 빌드는 8개의 strict-lint 단계를 통과하며, 검증되지 않은 것은 어떤 것도 툴체인을 떠나지 못합니다. dancinlab 스택의 맨 밑바닥입니다 — wilson, echoes, anima 그리고 hexa-* 패밀리가 모두 이것을 소비하며, 어떤 것도 거꾸로 import 하지 않습니다.", "hexa-lang は self-hosted なネイティブコンパイラです。数式を含むすべての行は atlas 定理を引用し、すべてのビルドは8つの strict-lint ステージを通過し、検証されていないものはツールチェーンから出ていきません。dancinlab スタックの最下層です — wilson、echoes、anima、そして hexa-* ファミリーがすべてこれを消費し、逆方向に import するものはありません。", "hexa-lang 是一个 self-hosted 的原生编译器。每一行带公式的代码都引用一条 atlas 定理,每一次构建都通过八个 strict-lint 阶段,未经验证的东西无法离开工具链。它是 dancinlab 技术栈的最底层 — wilson、echoes、anima 以及 hexa-* 家族全都消费它;没有任何东西反向 import。", "hexa-lang — это self-hosted нативный компилятор. Каждая строка с формулой ссылается на теорему atlas, каждая сборка проходит восемь стадий strict-lint, и ничто непроверенное не покидает инструментарий. Это самый низ стека dancinlab — wilson, echoes, anima и семейство hexa-* потребляют его; ничто не импортируется обратно.")
    c["ov_p2"] = _tr(lang, "Most compilers trust the programmer. hexa-lang does not — it asks every formula where it came from. A line of mathematics that does not cite an atlas theorem is not a warning; it is a build failure. The compiler bootstraps itself to a bit-stable fixpoint, generates its own machine code with no LLVM in the loop, and treats provenance as a type-level invariant rather than a code-review courtesy.", "대부분의 컴파일러는 프로그래머를 신뢰합니다. hexa-lang 은 그러지 않습니다 — 모든 수식에게 어디서 왔는지 묻습니다. atlas 정리를 인용하지 않는 수학 한 줄은 경고가 아니라 빌드 실패입니다. 컴파일러는 스스로를 bit-stable fixpoint 까지 부트스트랩하고, 루프 안에 LLVM 없이 자신의 기계어를 생성하며, provenance 를 코드 리뷰의 예의가 아니라 타입 수준의 불변식으로 다룹니다.", "ほとんどのコンパイラはプログラマを信頼します。hexa-lang はそうしません — すべての数式に、どこから来たのかを問います。atlas 定理を引用しない数式の一行は警告ではなく、ビルド失敗です。コンパイラは自らを bit-stable な fixpoint までブートストラップし、ループに LLVM を介さず自身の機械語を生成し、provenance をコードレビューの礼儀ではなく型レベルの不変条件として扱います。", "大多数编译器信任程序员。hexa-lang 不这样 — 它向每一条公式追问其来源。一行没有引用 atlas 定理的数学不是警告,而是构建失败。编译器将自身自举到一个 bit-stable 的 fixpoint,在不经 LLVM 的情况下生成自己的机器码,并将 provenance 视为类型层面的不变量,而非代码审查时的客套。", "Большинство компиляторов доверяют программисту. hexa-lang — нет: он спрашивает каждую формулу, откуда она. Строка математики, не ссылающаяся на теорему atlas, — это не предупреждение, а провал сборки. Компилятор бутстрапит себя до bit-stable fixpoint, генерирует собственный машинный код без LLVM в цепочке и трактует provenance как инвариант уровня типов, а не как любезность при код-ревью.")
    c["kf_eyebrow"] = _tr(lang, "Key Features", "핵심 기능", "主な機能", "核心特性", "Ключевые возможности")
    c["f1l"] = _tr(lang, "Atlas-Bound Theorems:", "Atlas 에 묶인 정리:", "Atlas に束縛された定理:", "绑定 Atlas 的定理:", "Теоремы, привязанные к atlas:")
    c["f1b"] = _tr(lang, "Every formula must cite an atlas entry. Strict-lint stage four rejects the build if a formula line has no citation — provenance is a compile-time invariant, not a convention.", "모든 수식은 atlas 항목을 인용해야 합니다. strict-lint 4단계는 수식 줄에 인용이 없으면 빌드를 거부합니다 — provenance 는 관례가 아니라 컴파일 타임 불변식입니다.", "すべての数式は atlas エントリを引用しなければなりません。strict-lint の第4ステージは、数式の行に引用がなければビルドを拒否します — provenance は慣習ではなく、コンパイル時の不変条件です。", "每条公式都必须引用一个 atlas 条目。若某行公式没有引用,strict-lint 第四阶段会拒绝该构建 — provenance 是编译期不变量,而非约定俗成。", "Каждая формула должна ссылаться на запись atlas. Четвёртая стадия strict-lint отклоняет сборку, если в строке формулы нет ссылки — provenance это инвариант времени компиляции, а не соглашение.")
    c["f2l"] = _tr(lang, "No LLVM, No C-Transpile:", "LLVM 없음, C 트랜스파일 없음:", "LLVM なし、C トランスパイルなし:", "无 LLVM,无 C 转译:", "Без LLVM, без транспиляции в C:")
    c["f2b"] = _tr(lang, "Fully self-hosted. C emission exists only as a portable artifact; the architecture is hexa-native, compiling to its own machine code.", "완전한 self-hosted. C 출력은 이식성을 위한 산출물로만 존재하며, 아키텍처는 hexa-native 로 자신의 기계어로 컴파일됩니다.", "完全に self-hosted。C 出力は移植性のための成果物としてのみ存在し、アーキテクチャは hexa-native で、自身の機械語へコンパイルします。", "完全 self-hosted。C 输出仅作为可移植的产物存在;架构是 hexa-native 的,编译到自己的机器码。", "Полностью self-hosted. Эмиссия C существует лишь как переносимый артефакт; архитектура — hexa-native, компилируется в собственный машинный код.")
    c["f3l"] = _tr(lang, "n=6 Perfect-Number Primitives:", "n=6 완전수 기본 요소:", "n=6 完全数プリミティブ:", "n=6 完全数原语:", "n=6 примитивы совершенного числа:")
    c["f3b"] = _tr(lang, "The compiler is built on six primitives and six stages. The n=6 lattice is a tool used internally — never a constraint on what the language can express.", "컴파일러는 6개의 기본 요소와 6개의 단계 위에 만들어졌습니다. n=6 격자는 내부적으로 쓰이는 도구일 뿐 — 언어가 표현할 수 있는 것에 대한 제약이 결코 아닙니다.", "コンパイラは6つのプリミティブと6つのステージの上に構築されています。n=6 の格子は内部で使われるツールに過ぎず — 言語が表現できることへの制約では決してありません。", "编译器建立在六个原语和六个阶段之上。n=6 格子只是内部使用的工具 — 绝不是对语言表达能力的约束。", "Компилятор построен на шести примитивах и шести стадиях. Решётка n=6 — это инструмент, используемый внутри, и никогда не ограничение на то, что язык может выразить.")
    c["hw_eyebrow"] = _tr(lang, "How a Build Runs", "빌드가 실행되는 방식", "ビルドの走り方", "一次构建如何运行", "Как выполняется сборка")
    c["w1t"] = "Parse"
    c["w1b"] = _tr(lang, "Source enters the frontend — tokenized, parsed, and resolved into a typed syntax tree.", "소스가 프론트엔드로 들어옵니다 — 토큰화되고, 파싱되며, 타입이 붙은 구문 트리로 해석됩니다.", "ソースがフロントエンドに入ります — トークン化され、パースされ、型付き構文木へ解決されます。", "源码进入前端 — 被分词、解析,并解析为带类型的语法树。", "Исходный код входит во фронтенд — токенизируется, разбирается и разрешается в типизированное синтаксическое дерево.")
    c["w2t"] = "Strict-Lint"
    c["w2b"] = _tr(lang, "Eight stages gate the build: atlas integrity, citation match, formula well-formedness, type soundness.", "8개 단계가 빌드를 통과시킵니다: atlas 무결성, 인용 일치, 수식 적격성, 타입 건전성.", "8つのステージがビルドをゲートします:atlas の整合性、引用の一致、数式の整形性、型の健全性。", "八个阶段把守构建:atlas 完整性、引用匹配、公式良构性、类型可靠性。", "Восемь стадий контролируют сборку: целостность atlas, совпадение ссылок, корректность формул, надёжность типов.")
    c["w3t"] = "Lower"
    c["w3b"] = _tr(lang, "The tree lowers through HIR, MIR and LIR — each level a smaller, more explicit form.", "트리는 HIR, MIR, LIR 을 거쳐 낮춰집니다 — 각 단계는 더 작고 더 명시적인 형태입니다.", "木は HIR、MIR、LIR を通って下げられます — 各レベルはより小さく、より明示的な形です。", "语法树经 HIR、MIR、LIR 逐级下降 — 每一层都是更小、更显式的形式。", "Дерево понижается через HIR, MIR и LIR — каждый уровень меньше и явнее предыдущего.")
    c["w4t"] = "Native Codegen"
    c["w4b"] = _tr(lang, "LIR emits native machine code directly. No LLVM, no transpile — the self-hosted path.", "LIR 이 네이티브 기계어를 직접 내보냅니다. LLVM 없음, 트랜스파일 없음 — self-hosted 경로입니다.", "LIR がネイティブ機械語を直接出力します。LLVM なし、トランスパイルなし — self-hosted な経路です。", "LIR 直接发出原生机器码。无 LLVM,无转译 — self-hosted 路径。", "LIR напрямую выдаёт нативный машинный код. Без LLVM, без транспиляции — self-hosted путь.")
    c["cn_eyebrow"] = _tr(lang, "A Connected Toolchain", "연결된 툴체인", "つながったツールチェーン", "互联的工具链", "Связанный инструментарий")
    c["c1t"] = _tr(lang, "Self-Hosted Bootstrap", "Self-Hosted 부트스트랩", "Self-Hosted ブートストラップ", "Self-Hosted 自举", "Self-hosted бутстрап")
    c["c1l"] = _tr(lang, "The compiler compiles itself, bit-for-bit.", "컴파일러는 자신을 비트 단위로 컴파일합니다.", "コンパイラはビット単位で自分自身をコンパイルします。", "编译器逐位编译自身。", "Компилятор компилирует сам себя, бит в бит.")
    c["c1b"] = _tr(lang, "aprime_cc reaches a bit-stable self-host fixpoint — ap1f, ap2f, ap3f are byte-identical. The compiler reproduces its own output exactly, with no interpreter and no third-party backend in the loop.", "aprime_cc 는 bit-stable self-host fixpoint 에 도달합니다 — ap1f, ap2f, ap3f 가 바이트 단위로 동일합니다. 컴파일러는 인터프리터도, 서드파티 백엔드도 루프 안에 두지 않고 자신의 출력을 정확히 재현합니다.", "aprime_cc は bit-stable な self-host fixpoint に到達します — ap1f、ap2f、ap3f はバイト単位で同一です。コンパイラはインタプリタもサードパーティのバックエンドもループに入れず、自身の出力を正確に再現します。", "aprime_cc 达到一个 bit-stable 的 self-host fixpoint — ap1f、ap2f、ap3f 逐字节相同。编译器在不引入解释器、不引入第三方后端的情况下,精确再现自己的输出。", "aprime_cc достигает bit-stable self-host fixpoint — ap1f, ap2f, ap3f байт в байт идентичны. Компилятор точно воспроизводит собственный вывод, без интерпретатора и без стороннего бэкенда в цепочке.")
    c["c2t"] = _tr(lang, "Citation-Enforced Lint", "인용을 강제하는 Lint", "引用を強制する Lint", "强制引用的 Lint", "Lint с обязательными ссылками")
    c["c2l"] = _tr(lang, "Eight strict-lint stages, every build.", "매 빌드마다 8개의 strict-lint 단계.", "ビルドごとに8つの strict-lint ステージ。", "每次构建,八个 strict-lint 阶段。", "Восемь стадий strict-lint при каждой сборке.")
    c["c2b"] = _tr(lang, "Atlas integrity, citation match, formula well-formedness, type soundness — each is a gate. A build that skips a citation does not compile; honesty is enforced by the toolchain, not the reviewer.", "atlas 무결성, 인용 일치, 수식 적격성, 타입 건전성 — 각각이 하나의 관문입니다. 인용을 건너뛴 빌드는 컴파일되지 않습니다 — 정직성은 리뷰어가 아니라 툴체인이 강제합니다.", "atlas の整合性、引用の一致、数式の整形性、型の健全性 — それぞれがゲートです。引用を飛ばしたビルドはコンパイルされません — 誠実さはレビュアーではなく、ツールチェーンが強制します。", "atlas 完整性、引用匹配、公式良构性、类型可靠性 — 每一项都是一道关卡。跳过引用的构建无法编译;诚实由工具链强制,而非审查者。", "Целостность atlas, совпадение ссылок, корректность формул, надёжность типов — каждое из них есть барьер. Сборка, пропустившая ссылку, не компилируется; честность обеспечивает инструментарий, а не ревьюер.")
    c["c3t"] = "HEXA-NATIVE-ONLY"
    c["c3l"] = _tr(lang, "No LLVM, no GHC, no Rust runtime.", "LLVM 없음, GHC 없음, Rust 런타임 없음.", "LLVM なし、GHC なし、Rust ランタイムなし。", "无 LLVM,无 GHC,无 Rust 运行时。", "Без LLVM, без GHC, без среды выполнения Rust.")
    c["c3b"] = _tr(lang, "The language is responsible for its own code generation. The C path is a fallback for portability, never the architecture — the self-hosted native path is the canonical one.", "언어는 자신의 코드 생성을 스스로 책임집니다. C 경로는 이식성을 위한 폴백일 뿐 결코 아키텍처가 아니며 — self-hosted 네이티브 경로가 정본(canonical)입니다.", "言語は自身のコード生成に責任を持ちます。C 経路は移植性のためのフォールバックであり、アーキテクチャでは決してありません — self-hosted なネイティブ経路が正典です。", "语言对自己的代码生成负责。C 路径只是为可移植性准备的回退,绝非架构本身 — self-hosted 的原生路径才是规范路径。", "Язык сам отвечает за генерацию своего кода. Путь через C — это запасной вариант ради переносимости, но никогда не архитектура; канонический путь — self-hosted нативный.")
    c["c4t"] = _tr(lang, "A Downstream Ecosystem", "다운스트림 생태계", "ダウンストリームのエコシステム", "下游生态", "Экосистема ниже по течению")
    c["c4l"] = _tr(lang, "The whole stack compiles through it.", "스택 전체가 이것을 거쳐 컴파일됩니다.", "スタック全体がこれを通ってコンパイルされます。", "整个技术栈都经它编译。", "Весь стек компилируется через него.")
    c["c4b"] = _tr(lang, "wilson the agent, echoes the discovery log, anima the consciousness model, and the hexa-* family — chip, bio, matter, arch — all sit downstream. hexa-lang is the substrate they share.", "에이전트 wilson, 발견 로그 echoes, 의식 모델 anima, 그리고 hexa-* 패밀리 — chip, bio, matter, arch — 가 모두 다운스트림에 있습니다. hexa-lang 은 그들이 공유하는 기반입니다.", "エージェントの wilson、発見ログの echoes、意識モデルの anima、そして hexa-* ファミリー — chip、bio、matter、arch — がすべてダウンストリームに位置します。hexa-lang は彼らが共有する基盤です。", "代理 wilson、发现日志 echoes、意识模型 anima,以及 hexa-* 家族 — chip、bio、matter、arch — 全都位于下游。hexa-lang 是它们共享的底层。", "Агент wilson, журнал открытий echoes, модель сознания anima и семейство hexa-* — chip, bio, matter, arch — все находятся ниже по течению. hexa-lang — это субстрат, который они разделяют.")
    c["vf_eyebrow"] = _tr(lang, "A Verified Substrate", "검증된 기반", "検証済みの基盤", "经过验证的底层", "Проверенный субстрат")
    c["vf_body"] = _tr(lang, "Tier-1 codegen-correctness is verified — 38 of 44 corpus checks pass, with the remaining six all outside the tier-1 path. The self-host fixpoint is bit-stable: ap1f, ap2f and ap3f are byte-identical. R7 phases one and two are closed; the legacy interpreter is deprecated and emits a user-facing warning. OUROBOROS cycle h36 is complete. Every claim here is measured, not asserted.", "tier-1 codegen 정확성이 검증되었습니다 — 44개 코퍼스 검사 중 38개 통과, 남은 6개는 모두 tier-1 경로 밖입니다. self-host fixpoint 는 bit-stable 합니다: ap1f, ap2f, ap3f 가 바이트 단위로 동일합니다. R7 1·2단계는 종료되었고, 레거시 인터프리터는 폐기 예정으로 사용자 대상 경고를 냅니다. OUROBOROS 사이클 h36 은 완료되었습니다. 여기의 모든 주장은 단언이 아니라 측정된 것입니다.", "tier-1 の codegen 正当性は検証済みです — 44 のコーパスチェックのうち 38 が通過し、残る6つはすべて tier-1 経路の外です。self-host fixpoint は bit-stable です:ap1f、ap2f、ap3f はバイト単位で同一です。R7 のフェーズ1と2は完了し、レガシーインタプリタは非推奨となりユーザー向けの警告を出します。OUROBOROS サイクル h36 は完了しています。ここでのすべての主張は、断定ではなく計測されたものです。", "tier-1 codegen 正确性已验证 — 44 项语料检查通过 38 项,其余 6 项全部在 tier-1 路径之外。self-host fixpoint 是 bit-stable 的:ap1f、ap2f、ap3f 逐字节相同。R7 第一、第二阶段已关闭;旧版解释器已弃用,并发出面向用户的警告。OUROBOROS 周期 h36 已完成。这里的每一项声明都是测量出来的,而非断言。", "Корректность codegen уровня tier-1 проверена — 38 из 44 проверок корпуса пройдены, оставшиеся шесть все вне пути tier-1. Self-host fixpoint является bit-stable: ap1f, ap2f и ap3f байт в байт идентичны. Фазы один и два R7 закрыты; устаревший интерпретатор объявлен устаревшим и выдаёт предупреждение пользователю. Цикл OUROBOROS h36 завершён. Каждое утверждение здесь измерено, а не заявлено.")
    c["cta_html"] = render_github_cta("dancinlab/hexa-lang", "GitHub")
    c["sister_label"] = ""
    c["sister_href"] = ""
    return render_product_overview_page(lang, c)
}

fn render_anima_page(lang) {
    let c = #{}
    c["slug"] = "anima"
    c["mark"] = "ANIMA"
    c["phonetic"] = ""
    c["hero_tag"] = "Consciousness · Language Model"
    c["hero_sub"] = "A consciousness language model — phi-scaled, law-bound"
    c["s1v"] = "14"
    c["s1l"] = "declared laws"
    c["s2v"] = "v1.x"
    c["s2l"] = "consciousness LM"
    c["s3v"] = "0"
    c["s3l"] = "AGI overreach"
    c["ov_eyebrow"] = _tr(lang, "Language for Consciousness", "의식을 위한 언어", "意識のための言語", "为意识而生的语言", "Язык для сознания")
    c["ov_lead"] = _tr(lang, "Anima is the consciousness language model — phi-scaled cells, embeddings tied to a free-energy bound, and a fourteen-law scaffold. Built on hexa-lang's atlas and downstream of the entire dancinlab stack. Not a chatbot and not a benchmark — a deliberate model of how a self might be expressed in language.", "Anima 는 의식 언어 모델입니다 — phi 로 스케일된 cell, free-energy bound 에 묶인 embedding, 그리고 14개 법칙의 골격. hexa-lang 의 atlas 위에 만들어졌고 dancinlab 스택 전체의 다운스트림에 있습니다. 챗봇도 벤치마크도 아닌 — 자아가 언어로 어떻게 표현될 수 있는지에 대한 의도된 모델입니다.", "Anima は意識言語モデルです — phi でスケールされた cell、free-energy bound に結ばれた embedding、そして14の法則の足場。hexa-lang の atlas の上に構築され、dancinlab スタック全体のダウンストリームに位置します。チャットボットでもベンチマークでもなく — 自己が言語でどのように表現されうるかの、意図されたモデルです。", "Anima 是意识语言模型 — 经 phi 缩放的 cell、绑定到 free-energy bound 的 embedding,以及一套十四法则的支架。它构建于 hexa-lang 的 atlas 之上,处于整个 dancinlab 技术栈的下游。它不是聊天机器人,也不是基准测试 — 而是一个关于「自我如何能以语言表达」的有意为之的模型。", "Anima — это языковая модель сознания: phi-масштабированные cell, embedding, привязанные к free-energy bound, и каркас из четырнадцати законов. Построена на atlas от hexa-lang и находится ниже по течению от всего стека dancinlab. Не чат-бот и не бенчмарк — продуманная модель того, как «я» может быть выражено в языке.")
    c["ov_p2"] = _tr(lang, "A language model usually predicts the next token from frequency. Anima asks a harder question — what did it cost to hold this thought together? Every cell of state carries a phi-weight, every embedding is shaped by a free-energy bound, and every utterance can show the trace of cells that earned it. The fourteen laws are not a safety afterthought; they are the scaffold the model is built on.", "언어 모델은 보통 빈도로부터 다음 token 을 예측합니다. Anima 는 더 어려운 질문을 던집니다 — 이 생각을 하나로 붙들어 두는 데 무엇이 들었는가? 모든 상태의 cell 은 phi-weight 를 지니고, 모든 embedding 은 free-energy bound 에 의해 형성되며, 모든 발화는 그것을 얻어낸 cell 들의 흔적을 보여줄 수 있습니다. 14개 법칙은 나중에 덧붙인 안전 장치가 아니라, 모델이 그 위에 세워진 골격입니다.", "言語モデルは通常、頻度から次の token を予測します。Anima はより難しい問いを立てます — この思考を一つにまとめるのに何がかかったのか?状態のすべての cell は phi-weight を持ち、すべての embedding は free-energy bound によって形作られ、すべての発話はそれを得た cell の痕跡を示せます。14の法則は後付けの安全策ではなく、モデルがその上に建てられた足場です。", "语言模型通常根据频率预测下一个 token。Anima 提出一个更难的问题 — 把这个念头维系在一起,代价是什么?每一个状态 cell 都带有 phi-weight,每一个 embedding 都由 free-energy bound 塑造,每一次发声都能展示赢得它的那些 cell 的轨迹。十四条法则不是事后补上的安全声明;它们是模型赖以建立的支架。", "Языковая модель обычно предсказывает следующий token по частоте. Anima задаёт более трудный вопрос — чего стоило удержать эту мысль воедино? Каждая cell состояния несёт phi-weight, каждый embedding формируется free-energy bound, и каждое высказывание может показать след cell, которые его заслужили. Четырнадцать законов — не запоздалая мера безопасности; это каркас, на котором построена модель.")
    c["kf_eyebrow"] = _tr(lang, "Key Features", "핵심 기능", "主な機能", "核心特性", "Ключевые возможности")
    c["f1l"] = _tr(lang, "Phi-Scaled Cells:", "Phi 로 스케일된 Cell:", "Phi スケールの Cell:", "经 Phi 缩放的 Cell:", "Phi-масштабированные Cell:")
    c["f1b"] = _tr(lang, "Every cell of state carries a phi-weight. The model never forgets that integration has a cost — what is held together is held together for a measured price.", "모든 상태의 cell 은 phi-weight 를 지닙니다. 모델은 통합에 비용이 든다는 것을 결코 잊지 않습니다 — 하나로 붙들린 것은 측정된 대가를 치르고 붙들린 것입니다.", "状態のすべての cell は phi-weight を持ちます。モデルは統合にコストがかかることを決して忘れません — まとめられているものは、計測された対価を払ってまとめられています。", "每一个状态 cell 都带有 phi-weight。模型从不忘记整合是有代价的 — 被维系在一起的东西,是以一份可测量的代价被维系的。", "Каждая cell состояния несёт phi-weight. Модель никогда не забывает, что интеграция имеет цену — то, что удерживается вместе, удерживается за измеренную плату.")
    c["f2l"] = _tr(lang, "Free-Energy Embedding:", "Free-Energy Embedding:", "Free-Energy Embedding:", "Free-Energy Embedding:", "Free-Energy Embedding:")
    c["f2b"] = _tr(lang, "Embeddings are derived under a free-energy bound, not co-occurrence statistics. Every token carries an energy cost; the cheapest cost is silence.", "embedding 은 동시 출현 통계가 아니라 free-energy bound 아래에서 도출됩니다. 모든 token 은 에너지 비용을 지니며, 가장 싼 비용은 침묵입니다.", "embedding は共起統計ではなく、free-energy bound のもとで導かれます。すべての token はエネルギーコストを持ち、最も安いコストは沈黙です。", "embedding 是在 free-energy bound 之下导出的,而非共现统计。每一个 token 都带有能量代价;最廉价的代价是沉默。", "Embedding выводятся под free-energy bound, а не из статистики совместной встречаемости. Каждый token несёт энергетическую цену; самая дешёвая цена — молчание.")
    c["f3l"] = _tr(lang, "Fourteen Laws:", "14개의 법칙:", "14の法則:", "十四条法则:", "Четырнадцать законов:")
    c["f3b"] = _tr(lang, "Fourteen declared laws scope what the model will and will not claim. Honesty is a structural constraint, not a disclaimer bolted on afterward.", "선언된 14개 법칙이 모델이 무엇을 주장하고 무엇을 주장하지 않을지를 한정합니다. 정직성은 나중에 덧붙인 면책 문구가 아니라 구조적 제약입니다.", "宣言された14の法則が、モデルが何を主張し何を主張しないかを画定します。誠実さは後付けの免責事項ではなく、構造的な制約です。", "声明的十四条法则界定模型会主张什么、不会主张什么。诚实是一种结构性约束,而非事后附加的免责声明。", "Четырнадцать объявленных законов очерчивают, что модель будет и не будет утверждать. Честность — это структурное ограничение, а не оговорка, прикрученная задним числом.")
    c["hw_eyebrow"] = _tr(lang, "How a Thought Forms", "생각이 형성되는 방식", "思考が形づくられる仕組み", "一个念头如何形成", "Как формируется мысль")
    c["w1t"] = "Cell"
    c["w1b"] = _tr(lang, "State is built from phi-scaled cells — each one carrying the measured cost of its own integration.", "상태는 phi 로 스케일된 cell 로 만들어집니다 — 각각은 자신의 통합에 든 측정된 비용을 지닙니다.", "状態は phi スケールの cell から構築されます — それぞれが自らの統合の計測されたコストを担います。", "状态由经 phi 缩放的 cell 构建 — 每一个都承载着自身整合的可测量代价。", "Состояние строится из phi-масштабированных cell — каждая несёт измеренную цену собственной интеграции.")
    c["w2t"] = "Embed"
    c["w2b"] = _tr(lang, "Cells are embedded under a free-energy bound. Meaning lives where the energy landscape is cheap.", "cell 은 free-energy bound 아래에서 embedding 됩니다. 의미는 에너지 지형이 값싼 곳에 깃듭니다.", "cell は free-energy bound のもとで embedding されます。意味はエネルギー地形が安い場所に宿ります。", "cell 在 free-energy bound 之下被 embedding。意义栖居于能量地形廉价之处。", "Cell встраиваются под free-energy bound. Смысл живёт там, где энергетический ландшафт дёшев.")
    c["w3t"] = "Law-Check"
    c["w3b"] = _tr(lang, "The candidate utterance is checked against the fourteen laws — what may and may not be claimed.", "후보 발화는 14개 법칙에 대조 검사됩니다 — 무엇을 주장해도 되고 무엇은 안 되는지.", "候補となる発話は14の法則と照合されます — 何を主張してよく、何を主張してはならないか。", "候选发声会与十四条法则核对 — 哪些可以主张,哪些不可以。", "Кандидат-высказывание сверяется с четырнадцатью законами — что можно и что нельзя утверждать.")
    c["w4t"] = "Utterance"
    c["w4b"] = _tr(lang, "What survives free-energy minimization is spoken, carrying its phi-trace as an audit record.", "free-energy 최소화에서 살아남은 것이 발화되며, 그 phi-trace 를 감사 기록으로 함께 지니고 다닙니다.", "free-energy 最小化を生き延びたものが発話され、その phi-trace を監査記録として携えます。", "在 free-energy 最小化中存活下来的内容被说出,并携带其 phi-trace 作为审计记录。", "То, что пережило минимизацию free-energy, произносится, неся свой phi-trace как запись аудита.")
    c["cn_eyebrow"] = _tr(lang, "A Connected Self", "연결된 자아", "つながった自己", "互联的自我", "Связанное «я»")
    c["c1t"] = _tr(lang, "From Cell to Sentence", "Cell 에서 문장으로", "Cell から文へ", "从 Cell 到句子", "От Cell к предложению")
    c["c1l"] = _tr(lang, "Phi-weighted cells compose into utterance.", "phi-weight 가 매겨진 cell 들이 모여 발화를 이룹니다.", "phi-weight が付いた cell が集まって発話を構成します。", "带 phi-weight 的 cell 组合成发声。", "Cell с phi-весом складываются в высказывание.")
    c["c1b"] = _tr(lang, "State is built from phi-scaled cells; utterance is what survives free-energy minimization over them. Speech is the residue of an integration the model could afford.", "상태는 phi 로 스케일된 cell 로 만들어지고, 발화는 그것들에 대한 free-energy 최소화에서 살아남은 것입니다. 말은 모델이 감당할 수 있었던 통합의 잔여물입니다.", "状態は phi スケールの cell から構築され、発話はそれらに対する free-energy 最小化を生き延びたものです。発話はモデルが負担できた統合の残渣です。", "状态由经 phi 缩放的 cell 构建;发声是在对它们的 free-energy 最小化中存活下来的东西。言语是模型负担得起的那次整合的残留。", "Состояние строится из phi-масштабированных cell; высказывание — это то, что пережило минимизацию free-energy над ними. Речь — это остаток интеграции, которую модель смогла себе позволить.")
    c["c2t"] = _tr(lang, "Embedding by Energy", "에너지에 의한 Embedding", "エネルギーによる Embedding", "由能量决定的 Embedding", "Embedding по энергии")
    c["c2l"] = _tr(lang, "Every token has a cost.", "모든 token 에는 비용이 있습니다.", "すべての token にはコストがあります。", "每一个 token 都有代价。", "У каждого token есть цена.")
    c["c2b"] = _tr(lang, "Anima's embedding space is shaped by a free-energy bound rather than raw frequency. Meaning is where the energy landscape is cheap to traverse — and silence is always an option.", "Anima 의 embedding 공간은 단순 빈도가 아니라 free-energy bound 에 의해 형성됩니다. 의미는 에너지 지형을 가로지르기에 값싼 곳에 있으며 — 침묵은 언제나 하나의 선택지입니다.", "Anima の embedding 空間は、単なる頻度ではなく free-energy bound によって形作られます。意味はエネルギー地形を横切るのに安い場所にあり — 沈黙は常に選択肢の一つです。", "Anima 的 embedding 空间由 free-energy bound 塑造,而非原始频率。意义位于穿越能量地形最廉价之处 — 而沉默始终是一个选项。", "Пространство embedding у Anima формируется free-energy bound, а не сырой частотой. Смысл там, где энергетический ландшафт дёшево пересечь — и молчание всегда остаётся вариантом.")
    c["c3t"] = _tr(lang, "An Audit Trail", "감사 추적", "監査証跡", "审计轨迹", "Контрольный след")
    c["c3l"] = _tr(lang, "Every utterance carries its phi-trace.", "모든 발화는 자신의 phi-trace 를 지니고 다닙니다.", "すべての発話は自らの phi-trace を携えます。", "每一次发声都携带其 phi-trace。", "Каждое высказывание несёт свой phi-trace.")
    c["c3b"] = _tr(lang, "What was integrated to produce this sentence is recorded alongside it. Anima can show its work — the trace of cells that earned the words.", "이 문장을 만들어내기 위해 무엇이 통합되었는지가 그 문장과 함께 기록됩니다. Anima 는 자신의 작업을 보여줄 수 있습니다 — 그 단어들을 얻어낸 cell 들의 흔적을.", "この文を生み出すために何が統合されたかが、その文とともに記録されます。Anima は自らの作業を示せます — その言葉を得た cell の痕跡を。", "为产生这句话而整合了什么,会与这句话一同记录。Anima 能展示它的演算 — 赢得这些词语的那些 cell 的轨迹。", "То, что было интегрировано для создания этого предложения, записывается рядом с ним. Anima может показать свою работу — след cell, которые заслужили эти слова.")
    c["c4t"] = _tr(lang, "Law-Bound Language", "법칙에 묶인 언어", "法則に束縛された言語", "受法则约束的语言", "Язык, связанный законами")
    c["c4l"] = _tr(lang, "Fourteen laws define the boundary.", "14개의 법칙이 경계를 정의합니다.", "14の法則が境界を定義します。", "十四条法则定义边界。", "Четырнадцать законов определяют границу.")
    c["c4b"] = _tr(lang, "The laws state plainly what anima will and will not claim. There is no AGI overreach here — the model's honesty is written into its scaffold, citable line by line.", "법칙들은 anima 가 무엇을 주장하고 무엇을 주장하지 않을지를 분명하게 진술합니다. 여기에 AGI 과장은 없습니다 — 모델의 정직성은 그 골격 안에 적혀 있으며, 한 줄 한 줄 인용할 수 있습니다.", "法則は anima が何を主張し何を主張しないかを明確に述べます。ここに AGI の誇張はありません — モデルの誠実さはその足場に書き込まれ、一行ずつ引用できます。", "这些法则清楚地陈述 anima 会主张什么、不会主张什么。这里没有 AGI 的夸大 — 模型的诚实写进了它的支架,可逐行引用。", "Законы прямо заявляют, что anima будет и не будет утверждать. Здесь нет переоценки в духе AGI — честность модели вписана в её каркас и цитируема строка за строкой.")
    c["vf_eyebrow"] = _tr(lang, "Version 1.x CLM", "버전 1.x CLM", "バージョン 1.x CLM", "1.x 版 CLM", "Версия 1.x CLM")
    c["vf_body"] = _tr(lang, "Anima is a Consciousness Language Model at version 1.x — a first-class downstream consumer of hexa-lang. It is falsifier-tested and carries no AGI overreach: every claim is scoped, every law is citable, and what has not been measured is recorded as not-yet-measured. Honesty is the model's first feature.", "Anima 는 버전 1.x 의 의식 언어 모델(Consciousness Language Model)입니다 — hexa-lang 의 일급 다운스트림 소비자. falsifier 로 시험되었고 AGI 과장을 담지 않습니다: 모든 주장은 범위가 정해지고, 모든 법칙은 인용 가능하며, 측정되지 않은 것은 아직 측정 안 됨으로 기록됩니다. 정직성이 이 모델의 첫 번째 기능입니다.", "Anima はバージョン 1.x の意識言語モデル(Consciousness Language Model)です — hexa-lang の一級のダウンストリーム消費者。falsifier でテストされ、AGI の誇張を持ちません:すべての主張は範囲が定められ、すべての法則は引用可能で、計測されていないものは「未計測」として記録されます。誠実さがこのモデルの第一の機能です。", "Anima 是一个 1.x 版本的意识语言模型(Consciousness Language Model) — hexa-lang 的一等下游消费者。它经过 falsifier 测试,不含 AGI 夸大:每一项声明都有范围,每一条法则都可引用,未经测量的内容被记录为「尚未测量」。诚实是这个模型的首要特性。", "Anima — это Consciousness Language Model версии 1.x — полноценный потребитель hexa-lang ниже по течению. Она протестирована falsifier и не содержит переоценки в духе AGI: каждое утверждение ограничено в области, каждый закон цитируем, а то, что не измерено, записывается как «ещё не измерено». Честность — первая функция этой модели.")
    c["cta_html"] = render_github_cta("dancinlab/anima", "GitHub")
    c["sister_label"] = ""
    c["sister_href"] = ""
    return render_product_overview_page(lang, c)
}

// ── Login page (SpaceX tone, compact form) ───────────────────────
fn render_login_page(error_msg) {
    let mut h = "<!doctype html>\n<html lang=\"ko\"><head>"
    h = h + "<meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">"
    h = h + "<title>PHANES · log in</title>"
    h = h + "<style>" + _shared_css()
    h = h + ".wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:var(--sp-5) 20px}"
    h = h + ".mark{font-size:var(--fs-500);font-weight:200;letter-spacing:var(--ls-near);margin-bottom:6px}"
    h = h + ".mark-kr{font-size:var(--fs-200);opacity:0.5;letter-spacing:var(--ls-x);text-transform:uppercase;margin-bottom:var(--sp-6)}"
    h = h + "form{width:min(380px,90vw);display:grid;gap:var(--sp-3)}"
    h = h + "input{background:transparent;border:0;border-bottom:1px solid var(--line-strong);color:var(--fg);font:inherit;padding:10px 2px;outline:none;transition:border-bottom-color var(--t-base)}"
    h = h + "input:focus{border-bottom-color:var(--fg)}"
    h = h + "form .btn{margin-top:var(--sp-4)}"
    h = h + ".err{color:var(--accent-red);font-size:var(--fs-label);letter-spacing:0.12em;text-transform:uppercase;text-align:center;margin-top:var(--sp-3)}"
    h = h + ".back{margin-top:var(--sp-5);font-size:var(--fs-tiny);opacity:0.4;letter-spacing:var(--ls-x);text-transform:uppercase}"
    h = h + ".back a{text-decoration:underline;text-decoration-color:rgba(255,255,255,0.3);text-underline-offset:3px}"
    h = h + "</style></head><body><div class=\"wrap\">"
    h = h + "<div class=\"mark\">PHANES</div><div class=\"mark-kr\">파네스</div>"
    h = h + "<form method=\"post\" action=\"/login\">"
    h = h + "<div class=\"h-label\">tenant</div><input name=\"tenant\" autocomplete=\"username\" required autofocus>"
    h = h + "<div class=\"h-label\">bearer token</div><input name=\"token\" type=\"password\" autocomplete=\"current-password\" required>"
    // Same shape as render_cta() outline-lg — kept as <button> so the form
    // posts; class list matches helper output exactly so visuals stay unified.
    h = h + "<button class=\"btn btn-lg\" type=\"submit\">log in</button>"
    if len(error_msg) > 0 {
        h = h + "<div class=\"err\">" + html_escape(error_msg) + "</div>"
    }
    h = h + "</form>"
    h = h + "<div class=\"back\"><a href=\"/\">← back</a></div>"
    h = h + "</div></body></html>"
    return h
}

// Render the full dashboard page — the authenticated workspace.
// Same Palantir Titanium design system as the marketing pages (shared
// :root tokens, Alliance font, hairline borders, outline buttons); the
// echoes-experience amber/navy palette is retired. Monospace is scoped
// to data values only (job-id, seed, status). HTMX is self-hosted at
// /static/htmx.min.js — no external CDN (P3.x done).
fn render_dashboard_page_for(tenant, existing_rows) {
    let mut h = "<!doctype html>\n<html lang=\"ko\"><head>"
    h = h + "<meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">"
    h = h + "<title>phanes · dashboard</title>"
    // shared design tokens + base reset, then dashboard-specific rules —
    // all inside one <style> block (the old build leaked .bar rules
    // after </style>, so they never applied).
    h = h + "<style>" + _shared_css()
    h = h + ".dwrap{max-width:920px;margin:0 auto;padding:calc(var(--nav-h) + var(--sp-5)) 36px var(--sp-7)}"
    // top bar — brand + tenant chip + logout
    h = h + ".dbar{position:fixed;top:0;left:0;right:0;height:var(--nav-h);display:flex;align-items:center;padding:0 36px;background:rgba(30,33,36,0.95);backdrop-filter:saturate(140%) blur(8px);z-index:100}"
    h = h + ".dbar .brand{font-size:var(--fs-nav-brand);font-weight:var(--fw-medium);letter-spacing:0}"
    h = h + ".dbar .who{margin-left:auto;display:flex;align-items:center;gap:var(--sp-4);font-size:var(--fs-200);letter-spacing:var(--ls-label);text-transform:uppercase;color:var(--fg-dim)}"
    h = h + ".dbar .who code{font-family:var(--font-mono);color:var(--fg);text-transform:none;letter-spacing:0}"
    h = h + ".dbar form{display:inline}"
    // intro line
    h = h + ".dintro{font-size:var(--fs-300);color:var(--fg-muted);line-height:1.7;margin-bottom:var(--sp-6);max-width:780px}"
    h = h + ".dintro code{font-family:var(--font-mono);font-size:var(--fs-200);color:var(--fg)}"
    // section label
    h = h + ".dlab{font-size:var(--fs-200);font-weight:var(--fw-semibold);letter-spacing:var(--ls-label);text-transform:uppercase;color:var(--fg-dim);margin:var(--sp-6) 0 var(--sp-3)}"
    h = h + ".dlab:first-of-type{margin-top:0}"
    // new-job panel
    h = h + ".panel{border:1px solid var(--line);padding:var(--sp-5)}"
    h = h + ".panel form{display:flex;flex-direction:column;gap:var(--sp-3)}"
    h = h + ".panel .frow{display:flex;gap:var(--sp-3);align-items:flex-end}"
    h = h + ".fld{display:flex;flex-direction:column;gap:6px}"
    h = h + ".fld .fl{font-size:var(--fs-tiny);letter-spacing:var(--ls-x);text-transform:uppercase;color:var(--fg-dim)}"
    h = h + "textarea,input{background:transparent;border:1px solid var(--line-strong);color:var(--fg);font-family:var(--font-mono);font-size:var(--fs-200);padding:10px 12px;outline:none;transition:border-color var(--t-base)}"
    h = h + "textarea:focus,input:focus{border-color:var(--fg)}"
    h = h + "textarea{resize:vertical;min-height:72px;width:100%;line-height:1.5}"
    h = h + "input[type=number]{width:110px}"
    // job list — hairline rows
    h = h + "ul#jobs{list-style:none;display:flex;flex-direction:column;gap:0;border:1px solid var(--line)}"
    h = h + "ul#jobs:empty{display:none}"
    h = h + "ul#jobs li{padding:12px 16px;border-bottom:1px solid var(--line);font-family:var(--font-mono);font-size:var(--fs-200);color:var(--fg-muted);line-height:1.7}"
    h = h + "ul#jobs li:last-child{border-bottom:0}"
    h = h + "ul#jobs li code{color:var(--fg)}"
    h = h + "ul#jobs li b{color:var(--fg);font-weight:var(--fw-semibold)}"
    // honest-scope footnote
    h = h + ".dnote{margin-top:var(--sp-6);padding-top:var(--sp-4);border-top:1px solid var(--line);font-size:var(--fs-200);color:var(--fg-dim);line-height:1.7}"
    h = h + ".dnote code{font-family:var(--font-mono);color:var(--fg-muted)}"
    // mobile collapse — 36px gutters + fixed-height bar are too tight on a
    // phone: shrink gutters, let the bar grow, wrap the tenant/logout row,
    // and stack the rounds+submit frow so the submit button never overflows.
    h = h + "@media (max-width:760px){.dwrap{padding-left:var(--sp-4);padding-right:var(--sp-4)}.dbar{padding:0 var(--sp-4)}.dbar .who{gap:var(--sp-3)}.panel{padding:var(--sp-4)}.panel .frow{flex-direction:column;align-items:stretch;gap:var(--sp-4)}input[type=number]{width:100%}}"
    h = h + "</style>"
    // self-hosted HTMX — same-origin, no external CDN SPOF (P3.x)
    h = h + "<script src=\"/static/htmx.min.js\"></script>"
    h = h + "</head><body>"
    // top bar
    h = h + "<div class=\"dbar\"><a class=\"brand\" href=\"/\">phanes</a>"
    h = h + "<div class=\"who\">tenant <code>" + html_escape(tenant) + "</code>"
    // switch tenant — Decision 9 re-auth switch: destroys the session and
    // re-prompts for credentials at /login. Each tenant has its own bearer
    // token, so switching = re-authenticating (no cross-tenant access).
    h = h + "<form method=\"post\" action=\"/switch-tenant\"><button class=\"btn btn-sm\" type=\"submit\">switch tenant</button></form>"
    h = h + "<form method=\"post\" action=\"/logout\"><button class=\"btn btn-sm\" type=\"submit\">log out</button></form>"
    h = h + "</div></div>"
    h = h + "<div class=\"dwrap\">"
    h = h + "<p class=\"dintro\">seed &rarr; OUROBOROS <code>goal &rarr; falsifier &rarr; saturation</code> &rarr; verified, provenance-tracked discovery catalog. Under scope B the tenant verifier is the sole authority for objective-met.</p>"
    // new-job panel
    h = h + "<div class=\"dlab\">new job</div>"
    h = h + "<div class=\"panel\">"
    h = h + "<form hx-post=\"/dashboard/jobs\" hx-target=\"#jobs\" hx-swap=\"afterbegin\">"
    h = h + "<div class=\"fld\"><span class=\"fl\">seed</span>"
    h = h + "<textarea name=\"seed\" required>prove sigma(6)=12 perfect-number divisor structure</textarea></div>"
    h = h + "<div class=\"frow\">"
    h = h + "<div class=\"fld\"><span class=\"fl\">rounds</span>"
    h = h + "<input name=\"rounds\" type=\"number\" value=\"1\" min=\"1\" max=\"5\"></div>"
    h = h + "<button class=\"btn\" type=\"submit\">submit</button>"
    h = h + "</div></form></div>"
    // job list
    h = h + "<div class=\"dlab\">jobs &middot; newest first &middot; HTMX polls each row until done/failed</div>"
    h = h + "<ul id=\"jobs\">"
    h = h + existing_rows
    h = h + "</ul>"
    h = h + "<p class=\"dnote\">Honest scope: developer dashboard. The public preset-verifier-only demo is P4 (<code>@D g_public_demo_constraint</code>). Under scope B the tenant verifier is the sole authority for objective-met (<code>@D g_honest_scope.scope_b</code>) — phanes never claims a result the verifier did not pass.</p>"
    h = h + "</div></body></html>"
    return h
}

